<div id="geogebra-uploadArea"
     class="form-group"
     data-controller="uppy-upload"
     data-uppy-upload-kind-value="geogebra"
     data-uppy-upload-endpoint-value="/ggbs/upload"
     data-uppy-upload-failure-message-value="<%= t('submission.upload_failure') %>"
     data-uppy-upload-hidden-input-selector-value="#upload-geogebra-hidden"
     data-uppy-upload-warning-selector-value="#medium-basics-warning">
  <input type="hidden"
         name="medium[geogebra]"
         value="<%= medium.cached_geogebra_data %>"
         id="upload-geogebra-hidden">
  <div data-uppy-upload-target="dashboard"></div>
  <div class="row p-2">
    <div id="geogebra-meta"
         class="col-12 meta rounded"
         style="display:<%= show(medium.geogebra.present?) %>">
      <div class="row">
        <div class="col-11">
          <%= t('basics.file') %>:
          <span id="geogebra-file">
            <%= medium.geogebra_filename %>
          </span>
        </div>
        <div class="col-1 text-end">
          <button type="button" class="btn-close" aria-label="Close" id="detach-geogebra"></button>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <%= t('basics.size') %>:
          <span id="geogebra-size">
            <%= number_to_human_size(medium.geogebra_size) %>
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
