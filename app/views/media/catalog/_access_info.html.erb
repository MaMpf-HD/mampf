<% if medium.locked? %>
<i id="locked_medium_item"
  class="fas fa-lock"
  style="padding-top: 12px;"
  data-bs-toggle="tooltip"
  title="<%= t('admin.catalog.info.locked_medium') %>">
</i>
<% end %>
<% if medium.free? %>
<i id="locked_medium_item"
  class="fas fa-globe-europe"
  style="padding-top: 12px;"
  data-bs-toggle="tooltip"
  title="<%= t('admin.catalog.info.free_medium') %>">
</i>
<% end %>
<% if medium.for_users? %>
<i id="locked_medium_item"
  class="fas fa-user"
  style="padding-top: 12px;"
  data-bs-toggle="tooltip"
  title="<%= t('admin.catalog.info.user_medium') %>">
</i>
<% end %>
<% if medium.restricted? %>
<i id="locked_medium_item"
  class="fas fa-user-plus"
  style="padding-top: 12px;"
  data-bs-toggle="tooltip"
  title="<%= t('admin.catalog.info.subscriber_medium') %>">
</i>
<% end %>
<% if !medium.published? %>
<i id="locked_medium_item"
  class="fas fa-eye-slash"
  style="padding-top: 12px;"
  data-bs-toggle="tooltip"
  title="<%= t('admin.catalog.info.unpublished_medium') %>">
</i>
<% end %>
