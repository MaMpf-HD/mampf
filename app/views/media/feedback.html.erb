<%= vite_javascript_tag "js/thyme/thyme_feedback" %>

<% content_for :title, "THymE - \"#{@medium.caption}\"" %>
<div id="thyme-feedback-container" class="thyme-container-layout">
  <div id="thyme-feedback" class="thyme-generic" data-medium="<%= @medium.id %>">
    <figure id="hypervideo-container">

      <!-- VIDEO + CONTROL BAR -->
      <div id="video-container">

        <video id="video" crossorigin="anonymous" data-paused="true" data-time="<%= @time %>">
          <source src="<%= @medium.video.url(host: host) %>">
        </video>

        <div id="video-controlBar">
          <div id="video-controls">

            <div id="timeline">
              <i id="play-pause" class="material-icons clickable">
                play_arrow
              </i>
              <span id="current-time" data-cy="current-time">
                0:00:00
              </span>
              <span id="heatmap">
                <!-- JavaScript inserts heatmap here -->
              </span>
              <span id="feedback-markers" class="annotation-marker"
                data-cy="feedback-markers">
                <!-- JavaScript inserts markers here -->
              </span>
              <input
                id="seek-bar"
                type="range"
                max="100"
                min="0"
                step="0.1"
                value="0"
              >
              <span id="max-time">
                0:00:00
              </span>
            </div>

            <!-- Category switches (see annotation_category_toggle.js) -->
            <div id="annotation-switches">
              <div id="abc" class="form-check form-switch">
                <input
                  id="annotation-category-mistake-switch"
                  type="checkbox"
                  class="form-check-input"
                  checked
                  role="switch"
                  title="<%= t('admin.annotation.toggle.mistake')%> (Q)"
                  value="mistake"
                >
              </div>

              <div class="form-check form-switch">
                <input
                  id="annotation-category-content-switch"
                  type="checkbox"
                  class="form-check-input"
                  checked
                  role="switch"
                  title="<%= t('admin.annotation.toggle.content')%> (W)"
                  value="content"
                >
              </div>

              <div class="form-check form-switch">
                <input
                  id="annotation-category-presentation-switch"
                  type="checkbox"
                  class="form-check-input"
                  checked
                  role="switch"
                  title="<%= t('admin.annotation.toggle.presentation')%> (E)"
                  value="presentation"
                >
              </div>

              <div class="form-check form-switch">
                <input
                  id="annotation-category-note-switch"
                  type="checkbox"
                  class="form-check-input"
                  checked
                  role="switch"
                  title="<%= t('admin.annotation.toggle.note')%> (R)"
                  value="note"
                >
              </div>
            </div>

            <div id="feedback-special-buttons" class="special-buttons-layout">
              <i id="minus-ten" class="material-icons clickable">
                replay_10
              </i>
              <i id="plus-ten" class="material-icons clickable">
                forward_10
              </i>
            </div>

            <div id="feedback-volume-controls" class="volume-controls-layout">
              <i id="mute" class="material-icons clickable">
                volume_up
              </i>
              <input
                id="volume-bar"
                type="range"
                max="1"
                min="0"
                step="0.1"
                value="1"
              >
            </div>

          </div>
        </div>
      </div>

      <!-- RIGHT-HAND SIDE AREA -->
      <%= render partial: "annotations/annotation_area" %>
    </figure>
  </div>
</div>

<%= render partial: "annotations/annotation_locales" %>
