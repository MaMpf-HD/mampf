<div class="row mb-3">
  <div class="col-12">
    <%= question.description %>
  </div>
  <div class="col-12">
    <% if !local_success[question.id][:rel_correct].nil? %>
    <div class="progress">
      <div class="progress-bar bg-success"
        style="width: <%= "#{local_success[question.id][:rel_correct]}%" %>"
        role="progressbar">
        <%= "#{local_success[question.id][:rel_correct]}%" %>
      </div>
      <div class="progress-bar bg-danger"
        style="width: <%= "#{local_success[question.id][:rel_incorrect]}%" %>"
        role="progressbar">
        <%= "#{local_success[question.id][:rel_incorrect]}%" %>
      </div>
    </div>
    <% else %>
    <%= t('statistics.no_question_statistics') %>
    <% end %>
  </div>
</div>
