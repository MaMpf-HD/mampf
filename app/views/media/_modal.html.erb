<div
  id="mediumModal"
  class="modal fade"
  aria-hidden="true"
  aria-labelledby="mediumModalLabel"
  data-backdrop="static"
  role="dialog"
  tabindex="-1"
>
  <div class="modal-dialog modal-lg"
    role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 id="mediumModalLabel" class="modal-title">
          <%= t('admin.medium.new') %>
        </h5>
        <button type="button"
          class="btn-close"
          aria-label="Close"
          data-bs-dismiss="modal">
        </button>
      </div>
      <div id="medium-modal-content" class="modal-body">
      </div>
    </div>
  </div>
</div>
