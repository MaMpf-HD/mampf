<div id="manuscript-uploadArea"
  class="form-group"
  data-controller="uppy-upload"
  data-uppy-upload-kind-value="manuscript"
  data-uppy-upload-endpoint-value="/pdfs/upload"
  data-uppy-upload-failure-message-value="<%= t('submission.upload_failure') %>"
  data-uppy-upload-invalid-message-value="<%= t('submission.upload_failure') %>"
  data-uppy-upload-hidden-input-selector-value="#upload-manuscript-hidden"
  data-uppy-upload-warning-selector-value="#medium-basics-warning">
  <input type="hidden"
      name="medium[manuscript]"
      value="<%= medium.cached_manuscript_data %>"
      id="upload-manuscript-hidden">
  <div data-uppy-upload-target="dashboard"></div>
  <div class="row p-2">
    <div id="manuscript-meta"
         class="col-12 meta rounded"
         style="display:<%= show(medium.manuscript.present?) %>">
      <div class="row">
        <div class="col-11">
          <%= t('basics.file') %>:
          <span id="manuscript-file">
            <%= medium.manuscript_filename %>
          </span>
        </div>
        <div class="col-1 text-end p-2">
          <button type="button" class="btn-close" aria-label="Close" id="detach-manuscript"></button>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <%= t('basics.size') %>:
          <span id="manuscript-size">
            <%= number_to_human_size(medium.manuscript_size) %>
          </span>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <%= t('manuscript.length') %>:
          <span id="manuscript-pages">
            <%= "#{medium.manuscript_pages} #{t('manuscript.pages')}" %>
          </span>
        </div>
      </div>
      <% if medium.manuscript_destinations.present? %>
        <div id="manuscript-destinations"
             class="row">
          <div class="col-12">
            <%= t('manuscript.destinations') %>:
            <span>
              <%= medium.manuscript_destinations.count %>
            </span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
