<div
  id="watchlistModal"
  class="modal fade"
  aria-hidden="true"
  aria-labelledby="watchlistModalLabel"
  data-keyboard="true"
  role="dialog"
  tabindex="-1"
>
  <div class="modal-dialog modal-lg"
    role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 id="watchlistModalTitle"
          class="modal-title">
          <%= t('watchlist.add') %>
        </h5>
        <button type="button" class="btn-close" aria-label="Close" data-bs-dismiss="modal"></button>
      </div>
      <div id="watchlistModalBody"
        class="modal-body">
        <div id="watchlist-select-form">
          <%= render partial: 'watchlists/select_form' %>
        </div>
        <div id="collapseNewWatchlist" class="collapse">
          <%= render partial: 'watchlists/new_form' %>
        </div>
      </div>
      <div class="modal-footer">
        <button id="watchlistEntrySubmitButton"
          type="submit"
          class="btn btn-primary"
          form="watchlistSelectForm"
          <%= "disabled" if Watchlist.where(user: current_user).empty? %>><%= t('watchlist.add') %></button>
        <button type="button" class="btn btn-secondary me-auto" data-bs-dismiss="modal"><%= t('watchlist.close') %></button>
      </div>
    </div>
  </div>
</div>
