<div id="new_vertex"
  data-quiz="<%= quiz.id %>">
  <div class="row">
    <div class="col-12">
      <div id="new_vertex_card" class="card bg-light m-3">
        <div class="card-header">
          <div class="row">
            <div class="col-8">
              <%= t('buttons.create_vertex') %>
            </div>
            <div class="col-4 text-end">
              <button id="cancelNewVertex"
                type="button"
                class="btn btn-sm btn-secondary">
                <%= t('buttons.cancel') %>
              </button>
            </div>
          </div>
        </div>
        <div class="card-body">
          <ul id="new-edge-tab" class="nav nav-pills mb-3" role="tablist">
            <% if current_user.admin_or_editor? %>
            <li class="nav-item">
              <a
                id="importMedia"
                class="nav-link active"
                aria-controls="import-vertex"
                aria-selected="true"
                data-bs-toggle="pill"
                href="#import-vertex"
                role="tab"
              >
                <%= t('admin.quiz.import_content') %>
              </a>
            </li>
            <% end %>
            <li class="nav-item">
              <a
                id="create-question-tab"
                class="nav-link <%= active(!current_user.admin_or_editor?) %>"
                aria-controls="create-question"
                aria-selected="false"
                data-bs-toggle="pill"
                href="#create-question"
                role="tab"
              >
                <%= t('admin.quiz.create_question') %>
              </a>
            </li>
            <li class="nav-item">
              <a
                id="create-remark-tab"
                class="nav-link"
                aria-controls="create-remark"
                aria-selected="false"
                data-bs-toggle="pill"
                href="#create-remark"
                role="tab"
              >
                <%= t('admin.quiz.create_remark') %>
              </a>
            </li>
          </ul>
          <div id="new-edge-tabContent" class="tab-content">
            <% if current_user.admin_or_editor? %>
            <div id="import-vertex"
              class="tab-pane fade show active"
              aria-labelledby="importMedia" role="tabpanel">
              <div id="import-vertex">
                <%= render partial: 'search/media_search_form',
                locals: { purpose: 'quiz' } %>
                <div id="media-search-results">
                </div>
              </div>
            </div>
            <% end %>
            <div id="create-question"
              class="tab-pane fade
                        <%= show_tab(!current_user.admin_or_editor?) %>"
              aria-labelledby="create-question-tab" role="tabpanel">
              <%= bootstrap_form_with url: quiz_vertices_path(quiz_id: quiz.id),
                                      scope: 'vertex',
              method: 'post' do |f| %>
              <%= f.hidden_field :sort,
                                   value: 'Question',
              id: 'vertex_sort_question' %>
              <%= f.text_field :label,
              label: t('basics.title') %>
              <div class="text-center">
                <%= f.submit t('buttons.save'),
                class: 'btn btn-sm btn-secondary' %>
              </div>
              <% end %>
            </div>
            <div id="create-remark" class="tab-pane fade" aria-labelledby="create-remark-tab"
              role="tabpanel">
              <%= bootstrap_form_with url: quiz_vertices_path(quiz_id: quiz.id),
                                      scope: 'vertex',
              method: 'post' do |f| %>
              <%= f.hidden_field :sort,
                                   value: 'Remark',
              id: 'vertex_sort_remark' %>
              <%= f.text_field :label,
              label: t('basics.title') %>
              <div class="text-center">
                <%= f.submit t('buttons.save'),
                class: 'btn btn-sm btn-secondary' %>
              </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
