<%= form_with model: submission,
              html: { data: { controller: 'submission-upload',
                              submission_upload_endpoint_value: '/submissions/upload',
                              submission_upload_accepted_file_types_value: assignment.accepted_for_file_input,
                              submission_upload_max_file_size_value: 10 * 1024 * 1024,
                              submission_upload_failure_message_value: t('submission.upload_failure'),
                              submission_upload_missing_consent_message_value: t('submission.missing_consent'),
                              submission_upload_upload_button_label_value: t('submission.upload_file') } } do |f| %>
  <div class="card-body submissionBody"
       data-id="<%= assignment.id %>">
    <div class="row mb-3">
      <div class="col-12">
        <%= f.label :tutorial_id,
                    t('basics.tutorial') %>
        <%= f.select :tutorial_id,
                     options_for_select(tutorials_selection(lecture),
                                        submission.tutorial&.id ||
                                          submission
                                            .preceding_tutorial(current_user)
                                           &.id),
                     {},
                     {} %>
        <div class="invalid-feedback"
             id="submission-tutorial-error">
        </div>
        <%= f.hidden_field :lecture_id,
                           value: lecture.id %>
        <%= f.hidden_field :assignment_id,
                           value: assignment.id %>
      </div>
    </div>
    <% unless submission.persisted? %>
      <div class="row">
        <div class="col-12" data-cy="submission-invites">
          <%= f.label :invitee_ids,
                     t('submission.invitations_to') %>
          <%= f.select :invitee_ids,
                       options_for_select(partner_selection(current_user,
                                                            lecture),
                                          partner_preselection(current_user,
                                                               lecture)),
                       {},
                       { multiple: true } %>
        </div>
      </div>
    <% end %>
    <div class="row">
      <div class="col-12">
        <%= f.label :manuscript, t('basics.submission') %>
      </div>
      <div class="col-12 mb-3">
        <%= f.hidden_field :manuscript,
                           value: submission.cached_manuscript_data,
                           id: 'upload-userManuscript-hidden',
                           data: { submission_upload_target: 'hiddenInput' } %>
        <%= f.hidden_field :detach_user_manuscript,
                           value: false %>
        <div data-submission-upload-target="dashboard"></div>
      </div>

      <div class="col-12">
        <i class="fas fa-lg fa-trash-alt me-2 clickable"
           id="removeUserManuscript"
           data-action="click->submission-upload#remove"
           data-submission-upload-target="removeButton"
           style="display: <%= show_inline(submission.manuscript) %>">
        </i>

        <span id="userManuscriptMetadata"
              data-submission-upload-target="metadata"
              style="display: <%= show_inline(submission.manuscript) %>">
          <%= submission.manuscript_filename %>
          (<%= number_to_human_size(submission.manuscript_size) %>)
        </span>
        <span id="noUserManuscript"
              data-submission-upload-target="noMetadata"
              style="display: <%= show_inline(!submission.manuscript) %>">
          <%= t('submission.no_manuscript_yet') %>
        </span>
      </div>
      <div class="col-12 mt-2"
           id="userManuscript-status">
        <div class="col-12 my-1"
             id="file-permission-field"
             data-submission-upload-target="permissionField">
          <div class="form-check">
            <input class="form-check-input"
                   type="checkbox"
                   value="0"
                   id="file-permission-checkbox"
                   data-submission-upload-target="permission">
            <label class="form-check-label" for="file-permission-checkbox">
              <%= t('submission.assure_third_party') %>
            </label>
          </div>
        </div>
        <div class="col-12">
          <div class="col-12">
            <small>
              <%= t('submission.removal_notice_html')%>
            </small>
          </div>
          <div class="col-12">
            <small class="text-danger submission-initially-hidden"
                   id="userManuscript-not-upload-notice"
                   data-submission-upload-target="pendingNotice">
              <%= t('submission.submission_not_upload_notice_html')%>
            </small>
          </div>
          <div class="col-12">
            <small class="text-danger submission-initially-hidden"
                   id="userManuscript-upload-notice"
                   data-submission-upload-target="uploadedNotice">
              <%= t('submission.submission_upload_notice_html')%>
            </small>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="card-footer submissionFooter text-center p-2"
       data-id="<%= assignment.id %>">
    <%= f.submit t('buttons.save'),
                  class: 'btn btn-primary',
                  data: { submission_upload_target: 'saveButton' },
                  "data-cy": "save-submission" %>
    <%= link_to t('buttons.cancel'),
                cancel_editing_submission_path(submission),
                class: 'btn btn-secondary',
                remote: true %>
  </div>
<% end %>
