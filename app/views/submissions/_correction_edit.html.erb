<div class="correction-upload"
      data-controller="correction-upload"
      data-correction-upload-submission-id-value="<%= @submission.id %>">

  <%= render "submissions/correction_upload",
              submission: @submission %>

  <input type="file"
          id="upload-correction-<%= @submission.id %>"
          class="d-none">

  <button id="correction-uploadButton-button-<%= @submission.id %>"
          class="btn btn-outline-secondary">
    <%= t("buttons.upload") %>
  </button>

  <div id="upload-correction-informer-<%= @submission.id %>"></div>
  <div id="upload-correction-statusBar-<%= @submission.id %>"></div>

  <input type="hidden"
          id="upload-correction-hidden-<%= @submission.id %>">

  <div id="upload-correction-metadata-<%= @submission.id %>"></div>

  <button id="correction-uploadButton-button-actual-<%= @submission.id %>"
          class="btn btn-primary d-none">
    Confirm Upload
  </button>

</div>
