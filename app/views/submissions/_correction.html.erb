<div class="row">
  <div class="col-12">
    <% if !@assignment.active? %>
      <%= link_to t('buttons.upload'),
                  edit_correction_path(submission),
                  class: "btn btn-sm btn-outline-secondary",
                  data: { turbo_stream: true } %>
    <% else %>
      <button class="btn btn-sm btn-outline-secondary" disabled>
        <%= t('buttons.upload') %>
      </button>
    <% end %>

    <span class="correction-action-area" data-id="<%= submission.id %>">
      <% if submission.correction %>
        <%= link_to correction_display_mode(submission),
                    show_correction_path(submission),
                    class: "btn btn-sm btn-outline-secondary",
                    data: { turbo: false } %>

        <%= link_to t('buttons.delete'),
                    delete_correction_path(submission),
                    class: "btn btn-sm btn-outline-secondary",
                    data: { turbo_method: :delete,
                            turbo_confirm: t('confirmation.generic'),
                            turbo_stream: true } %>
      <% end %>
    </span>
  </div>
</div>
