<!DOCTYPE html>
<html>
  <head>
    <%= render partial: 'layouts/head' %>
    <%= vite_stylesheet_tag "styles/sidebar.scss" %>

  </head>

  <body class="d-flex flex-column min-vh-100" data-locale="<%= I18n.locale %>">

    <%= render partial: "flash/messages" %>
    <%= render partial: "shared/navbar" %>

    <div class="d-flex container-fluid flex-grow-1">
      <div id="main-content-row" class="row">

        <% lecture = @lecture || current_lecture %>
        <% if lecture %>
        <div id="sidebar-container"
          class="col-sm-4 col-md-3 col-xl-2">
          <nav id="sidebar">
            <%= render partial: 'lectures/show/sidebar',
            locals: { lecture: lecture } %>
          </nav>
        </div>
        <% end %>

        <main class="col-sm-8 ml-auto col-md-9 col-xl-10 pt-3" role="main">
          <%= turbo_frame_tag "main", target: "_top", data: { turbo_action: "advance" } do %>
          <%= yield %>
          <% end %>
        </main>
      </div>
    </div>

    <div id="modal-container"></div>

    <footer class="container-fluid mt-4 p-0">
      <%= render partial: 'shared/footer' %>
    </footer>

  </body>
</html>
