<%= vite_javascript_tag "js/footer_modal" %>

<% I18n.with_locale(current_user.try(:locale)) do %>

<div
  id="sponsors"
  class="modal fade"
  aria-hidden="true"
  aria-labelledby="Sponsors list modal"
  role="dialog"
  tabindex="-1"
>
  <div class="modal-dialog modal-lg">
    <div class="modal-content p-4">
      <%= render partial: 'main/sponsors' %>
    </div>
  </div>
</div>

<%# Footbar %>
<div id="footer-bar" class="container-fluid p-3">
  <div class="row">
    <div class="col text-md-start">
      <%= t('footer.text_html',
             github: link_to('GitHub',
                             'https://github.com/MaMpf-HD/mampf',
                             target: "_blank"),
             rails:  link_to('Rails',
                             'http://rubyonrails.org/',
                             target: :_blank),
             bootstrap: link_to('Bootstrap',
                                'https://getbootstrap.com/',
                                target: :_blank),
             cytoscape: link_to('Cytoscape.js',
                                'https://js.cytoscape.org/',
                                target: :_blank),
             nerdamer: link_to('Nerdamer',
                               'https://nerdamer.com',
                               target: :_blank),
             katex: link_to('KaTeX',
                            'https://katex.org',
                            target: :_blank),
             thredded: link_to('Thredded',
                               'https://github.com/thredded/thredded',
                               target: :_blank),
             docker: link_to('Docker',
                             'https://www.docker.com/',
                             target: :_blank),
             basecamp: link_to('Basecamp',
                               'https://basecamp.com/',
                               target: :_blank),
             bugs: link_to(t('here'),
                            'https://github.com/MaMpf-HD/mampf/issues',
                            target: :_blank),
      feedback: mail_to(DefaultSetting::FEEDBACK_EMAIL, nil)) %>
    </div>
    <div class="col text-md-end">
      <a data-target="#sponsors" data-toggle="modal"
        href="#sponsors"><%= t('basics.sponsors') %></a>
      <span style="margin-left: 20px;"></span>
      <a style="text-decoration: none"
        href="https://hse-heidelberg.de/"
        rel="noreferrer"
        target="_blank">
        <img style="vertical-align: middle;" height="60" src="/HD-HSE-Logo_RGB_210dpi.png">
      </a>
      <a href="https://uni-heidelberg.de"
        rel="noreferrer"
        target="_blank">
        <img style="margin-left: 20px; vertical-align: middle;" height="60"
          src="/uni_hd_logo.png">
      </a>
    </div>
  </div>

  <div class="row">
    <div class="col-sm text-center text-md-end">
      <%= link_to t('disclosure'),
                   'https://www.uni-heidelberg.de/impressum.html',
      target: :_blank, class:'me-2' %>
      <%= link_to t('policy'),
                  'https://www.uni-heidelberg.de/datenschutzerklaerung_web.html',
      target: :_blank %>
    </div>
  </div>

</div>
<% end %>
