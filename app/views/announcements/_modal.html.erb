<div
  id="newAnnouncementModal"
  class="modal fade"
  aria-hidden="true"
  aria-labelledby="newAnnouncementModalLabel"
  role="dialog"
  tabindex="-1"
>
  <div class="modal-dialog modal-lg"
    role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 id="newAnnouncementModalLabel"
          class="modal-title">
          <%= t('buttons.create_announcement') %>
        </h5>
        <button type="button"
          class="btn-close"
          aria-label="Close"
          data-bs-dismiss="modal">
        </button>
      </div>
      <div id="new-announcement-modal-content"
        class="modal-body">
      </div>
    </div>
  </div>
</div>
