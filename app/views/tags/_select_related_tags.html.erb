<div class="mb-3">
  <%= f.label :related_tag_ids,
              t('basics.related_tags'),
  class: "form-label" %>
  <%= helpdesk(t('admin.tag.info.related_tags'), false) %>
  <a
    id="new-tag-button"
    class="fas fa-plus-circle clickable text-dark"
    data-bs-toggle="tooltip"
    data-from="tag"
    data-tag="<%= tag.id %>"
    title="<%= t('buttons.create_tag') %>"
  >
  </a>
  <i id="new-tag-defunct"
    class="fas fa-plus-circle text-secondary"
    style="display: none;">
  </i>
  <%= f.select :related_tag_ids,
                options_for_select(related_tag_ids_selection(tag)
                                     .map { |t| [t.extended_title, t.id]},
                                   related_tag_ids_selection(tag)
                                     .map(&:id)),
                {},
                { multiple: true,
                  class: 'selectize',
                  data: { id: tag.id.to_i,
                          ajax: true,
                          model: 'tag',
                          filled: false,
                          locale: I18n.locale,
                          placeholder: t('basics.enter_two_letters'),
  no_results: t('basics.no_results') } } %>
  <div id="tag-related-tags-error-<%= tag.id.to_i %>"
    class="invalid-feedback">
  </div>
  <div class="row mt-3">
    <div class="col-12 text-center">
      <button id="cancelSelectRelatedTags"
        type="button"
        class="btn btn-sm btn-secondary">
        <%= t('buttons.cancel') %>
      </button>
    </div>
  </div>
</div>
