<div class="col-3">
  <%= tag.extended_title %>
</div>
<div class="col-2">
  <ul class="list-unstyled">
    <% tag.courses.each do |c| %>
    <li>
      <%= course_link_or_text(c, current_user) %>
    </li>
    <% end %>
  </ul>
</div>
<div class="col-6">
  <% tag.related_tags.each do |t| %>
  <%= link_to t.title,
                edit_tag_path(t),
  class:'badge text-dark lecture-tag' %>
  <% end %>
</div>
<div class="col-1">
  <a
    class="text-dark"
    style="text-decoration: none;"
    data-bs-toggle="tooltip"
    data-placement="bottom"
    href="<%= edit_tag_path(tag) %>"
    title="<%= t('buttons.edit') %>"
  >
    <i class="far fa-edit">
    </i>
  </a>
</div>
