<div
  id="manageTagsModal"
  class="modal fade"
  aria-hidden="true"
  aria-labelledby="manageTagsModalLabel"
  role="dialog"
  tabindex="-1"
>
  <div class="modal-dialog modal-lg"
    role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 id="manageTagsModalLabel"
          class="modal-title">
          <%= t('admin.tag.section_association') %>
        </h5>
        <button type="button"
          class="btn-close cancel-section-association"
          aria-label="Close">
        </button>
      </div>
      <div id="manage-tags-modal-content"
        class="modal-body">
      </div>
    </div>
  </div>
</div>
