<div
  id="identifyTagModal"
  class="modal fade"
  aria-hidden="true"
  aria-labelledby="identifyTagModalLabel"
  role="dialog"
  tabindex="-1"
>
  <div class="modal-dialog modal-lg"
    role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 id="identifyTagModalLabel"
          class="modal-title">
          <%= t('admin.tag.identify') %>
        </h5>
        <button type="button"
          class="btn-close"
          aria-label="Close"
          data-bs-dismiss="modal">
        </button>
      </div>
      <div id="identify-tag-modal-content"
        class="modal-body">
        <%= form_with model: tag,
        url: identify_tags_path(tag) do |f| %>
        <%= f.label :identified_tag_id, t('admin.tag.identified_tag') %>:
        <%= f.select :identified_tag_id,
                       options_for_select(Tag.select_by_title_except(Tag.where(id: tag.id))),
                       { prompt: t('basics.select') },
                       { class: 'selectize',
        data: { id: tag.id.to_i } } %>
        <div id="identified_tag_titles"
          style="display: none;">
          <div class="my-2">
            <%= t('admin.tag.identified_titles') %>:
          </div>
          <%= f.fields_for :notions do |n| %>
          <div class="row">
            <div class="mb-3 col-11">
              <div class="input-group">
                <div class="input-group-prepend">
                  <div class="input-group-text">
                    <%= n.object.locale %>
                  </div>
                </div>
                <%= n.select :title,
                                 options_for_select([[]]),
                                 {},
                                 { class: 'form-select',
                                   data: { id: tag.id.to_i,
                locale: n.object.locale } } %>
                <%= n.hidden_field :locale,
                value: n.object.locale %>
              </div>
            </div>
            <div class="col-1">
              <i
                id="link_reappearance_link"
                class="titleWarning fas fa-lg fa-exclamation-circle ms-3"
                style="display: none; margin-top: 10px;"
                data-bs-toggle="tooltip"
                data-locale="<%= n.object.locale.to_s %>"
                data-placement="bottom"
                title="<%= t('admin.tag.contradiction') %>"
              >
              </i>
            </div>
          </div>
          <% end %>
        </div>
        <div class="row mt-3">
          <div class="col-12 text-center">
            <%= f.submit t('buttons.submit'),
                           class: 'btn btn-sm btn-primary',
                           id: 'submit_identified_tag',
            style: 'display: none;' %>
            <button type="button"
              class="btn btn-sm btn-secondary"
              data-bs-dismiss="modal">
              <%= t('buttons.cancel') %>
            </button>
          </div>
        </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
