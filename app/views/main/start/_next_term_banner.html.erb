<%# Transitional banner announcing that lectures for the next term are
  being published and that registration now happens in MaMpf.
  Rendered only when the :next_term_banner feature flag is enabled and
  at least one published lecture for the next term exists
  (see MainController#next_term_banner). %>
<div class="next-term-banner alert alert-primary d-flex align-items-start gap-3 p-3 px-md-4 mx-auto"
     role="alert"
     data-testid="next-term-banner">
  <div class="pt-1" aria-hidden="true">
    <i class="fas fa-bullhorn fa-lg"></i>
  </div>
  <div class="next-term-banner__content d-flex flex-column flex-md-row gap-3">
    <div class="vstack gap-2">
      <p class="alert-heading fs-5 fw-semibold mb-0">
        <%= safe_join(
              t("main.next_term_banner.heading",
                term: next_term.to_label,
                count: lecture_count).split(" — "),
              safe_join([tag.br, "— "])) %>
      </p>

      <p class="mb-0">
        <%= t("main.next_term_banner.registration_intro") %>
      </p>

      <div class="w-100">
        <%= link_to t("main.next_term_banner.cta"),
                    root_path(term_scope: "next", anchor: "lecture-search"),
                    class: "btn btn-primary btn-sm w-100",
                    data: { testid: "next-term-banner-cta" } %>
      </div>
    </div>

    <div class="next-term-banner__transition">
      <p class="mb-0"
         data-testid="next-term-banner-transition-notice">
        <strong><%= t("main.next_term_banner.transition_label") %>:</strong>
        <%= t("main.next_term_banner.transition_notice") %>
        <span class="text-warning ms-1 fs-5 lh-1 align-text-bottom"
              data-testid="next-term-banner-construction-icon"
              title="<%= t("main.next_term_banner.transition_label") %>">
          <span aria-hidden="true">🚧</span>
          <span class="visually-hidden"><%= t("main.next_term_banner.transition_label") %></span>
        </span>
      </p>
    </div>
  </div>
</div>
