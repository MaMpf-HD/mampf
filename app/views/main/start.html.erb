<%= vite_stylesheet_tag "dashboard/dashboard.scss" %>

<div style="min-height: 100vh; display: flex; flex-direction: column; padding-left: 1em; padding-right: 1em;">
  <% if @announcements.present? %>
  <div class="alert alert-secondary"
    role="alert">
    <%= @announcements.html_safe %>
  </div>
  <% end %>
  <div id="subscriptionsAccordion" class="accordion" style="flex: 1;">
    <% if Term.active %>
    <div class="accordion-item">
      <div class="accordion-header">
        <button
          type="button"
          class="accordion-button"
          aria-controls="collapseCurrentStuff"
          aria-expanded="true"
          data-bs-target="#collapseCurrentStuff"
          data-bs-toggle="collapse"
        >
          <h4 id="currentStuffLink"
            class="<%= text_dark_link(@current_stuff.any?) %>">
            <%= t('profile.my_term_html', term: Term.active.to_label) %>
          </h4>
        </button>
      </div>
      <div id="collapseCurrentStuff"
        class="subscriptionsCollapse <%= show_collapse(@current_stuff.any?) %>"
        data-bs-parent="#subscriptionsAccordion"
        data-link="#currentStuffLink">
        <div class="accordion-body">
          <div id="collapseCurrentStuffContent"
            class="row row-cols-1 row-cols-xs-2 row-cols-md-3 row-cols-lg-3 row-cols-xl-4 row-cols-xxl-6">
            <% if @current_stuff.any? %>
            <%= render partial: 'main/start/lecture',
                         collection: @current_stuff,
                         locals: { current: true,
                                    subscribed: true,
                                    parent: 'current_subscribed' },
            as: :lecture %>
            <% end %>
          </div>
          <%= tag.div id: 'emptyCurrentStuff',
          style: @current_stuff.any? ? 'display: none;' : ''  do %>
          <%= t('profile.no_current_stuff') %>
          <% end %>
        </div>
      </div>
    </div>
    <% end %>
    <div class="accordion-item">
      <div class="accordion-header">
        <button
          type="button"
          class="accordion-button collapsed"
          aria-controls="collapseInactiveLectures"
          aria-expanded="false"
          data-bs-target="#collapseInactiveLectures"
          data-bs-toggle="collapse"
        >
          <h4 id="inactiveLecturesLink"
            class="text-dark">
            <%= t('profile.inactive_lectures') %>
          </h4>
        </button>
      </div>
      <div id="collapseInactiveLectures"
        class="subscriptionsCollapse <%= show_collapse(@current_stuff.empty?) %>"
        data-bs-parent="#subscriptionsAccordion" data-link="#inactiveLecturesLink">
        <div class="accordion-body">
          <div id="collapseInactiveLecturesContent"
            class="row row-cols-1 row-cols-xs-2 row-cols-md-3 row-cols-lg-3 row-cols-xl-4 row-cols-xxl-6"
            data-cy="subscribed-inactive-lectures-collapse"
            data-testid="further-subscribed">
            <% if @current_stuff.empty? %>
            <%= render partial: 'main/start/lecture',
                       collection: @inactive_lectures,
                       locals: { current: false,
                                  subscribed: true,
                                  parent: 'inactive' },
            as: :lecture %>
            <% end %>
          </div>
          <%= tag.div id: 'emptyInactiveLectures',
          style: @current_stuff.empty? && @inactive_lectures&.empty? ? '' : 'display: none;' do %>
          <%= t('profile.no_inactive_stuff') %>
          <% end %>
        </div>
      </div>
    </div>
    <% if Term.active %>
    <div class="accordion-item">
      <div class="accordion-header">
        <button
          type="button"
          class="accordion-button collapsed"
          aria-controls="collapseAllCurrent"
          aria-expanded="false"
          data-bs-target="#collapseAllCurrent"
          data-bs-toggle="collapse"
        >
          <h4 id="allCurrentLink"
            class="text-dark">
            <%= t('profile.active_nonsubscribed_lectures_html',
            term: Term.active.to_label) %>
          </h4>
        </button>
      </div>
      <div id="collapseAllCurrent" class="collapse subscriptionsCollapse"
        data-bs-parent="#subscriptionsAccordion" data-link="#allCurrentLink">
        <div class="accordion-body">
          <div id="collapseAllCurrentContent"
            class="row row-cols-1 row-cols-xs-2 row-cols-md-3 row-cols-lg-3 row-cols-xl-4 row-cols-xxl-6">
          </div>
          <%= tag.div id: 'emptyAllCurrent',
          style: 'display: none;' do %>
          <%= t('profile.no_current_at_all') %>
          <% end %>
        </div>
      </div>
    </div>
    <% end %>
    <div class="accordion-item">
      <div class="accordion-header">
        <button
          type="button"
          class="accordion-button collapsed"
          aria-controls="collapseTalks"
          aria-expanded="false"
          data-bs-target="#collapseTalks"
          data-bs-toggle="collapse"
          data-cy="my-talks-collapse-btn"
        >
          <h4 id="talkLink"
            class="text-dark">
            <%= t('profile.my_talks') %>
          </h4>
        </button>
      </div>
      <div id="collapseTalks" class="collapse subscriptionsCollapse"
        data-bs-parent="#subscriptionsAccordion"
        data-cy="my-talks-collapse"
        data-link="#talkLink">
        <div class="accordion-body">
          <%= render partial: 'main/start/talks',
          locals: { talks: @talks } %>
        </div>
      </div>
    </div>
    <div class="accordion-item">
      <div class="accordion-header">
        <button
          type="button"
          class="accordion-button collapsed"
          aria-controls="collapseLectureSearch"
          aria-expanded="false"
          data-bs-target="#collapseLectureSearch"
          data-bs-toggle="collapse"
        >
          <h4 id="lectureSearchLink"
            class="text-dark">
            <%= t('basics.lecture_search') %>
          </h4>
        </button>
      </div>
      <div id="collapseLectureSearch" class="collapse subscriptionsCollapse"
        data-bs-parent="#subscriptionsAccordion"
        data-link="#lectureSearchLink">
        <div class="accordion-body">
          <%= render partial: 'search/lecture_search_form',
          locals: { results_as_list: false } %>
          <div id="lecture-search-results-old">
          </div>
        </div>
      </div>
    </div>
    <div class="accordion-item mb-3">
      <div class="accordion-header">
        <button
          type="button"
          class="accordion-button collapsed"
          aria-controls="collapseMediaSearch"
          aria-expanded="false"
          data-bs-target="#collapseMediaSearch"
          data-bs-toggle="collapse"
        >
          <h4 id="lectureSearchLink"
            class="text-dark">
            <%= t('profile.media_search') %>
          </h4>
        </button>
      </div>
      <div id="collapseMediaSearch" class="collapse subscriptionsCollapse"
        data-bs-parent="#subscriptionsAccordion"
        data-link="#mediaSearchLink">
        <div class="accordion-body">
          <%= render partial: 'search/media_start_search_form',
                   locals: { results_as_list: false,
          purpose: 'media' } %>
          <div id="media-search-results">
          </div>
        </div>
      </div>
    </div>
  </div>

  <a id="go-to-lecture-search" href="#lecture-search">
    <span style="font-size: 0.9em; font-weight: 500;">
      <%= t("lecture.search.go_to_search") %>
    </span>
    <div id="arrow-go-to-lecture-wrapper" style="transition: transform 0.3s ease;">
      <i id="arrow-go-to-lecture" class="fas fa-chevron-down"></i>
    </div>
  </a>
</div>

<%= render partial: 'profile/subscription_modal' %>
<%= render partial: "lectures/search/search" %>
