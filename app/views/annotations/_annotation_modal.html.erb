<div
  id="annotation-modal"
  class="modal fade"
  aria-hidden="true"
  aria-labelledby="annotation-modal-label"
  role="dialog"
  tabindex="-1"
>
  <div id="annotation-modal-dialog"
    class="modal-dialog annotation-dialog-normal" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">
          <span id="modal-title-create-annotation">
            <% I18n.with_locale(current_user.locale) do %>
            <%= t('admin.annotation.annotation_modal_head_create_annotation') %>
            <% end %>
          </span>
          <span id="modal-title-edit-annotation">
            <% I18n.with_locale(current_user.locale) do %>
            <%= t('admin.annotation.annotation_modal_head_edit_annotation') %>
            <% end %>
          </span>
        </h5>
        <button type="button"
          class="btn-close"
          aria-label="Close"
          data-bs-dismiss="modal">
        </button>
      </div>
      <div class="modal-body">
        <section id="annotation-preview-section" style="display: none;">
          <div id="annotation-modal-preview" class="column-adaptable annotation-preview">
            <!--- LATEX-PREVIEW -->
          </div>
        </section>

        <section id="annotation-content-section" class="annotation-content-normal">
          <div id="annotation-modal-content">
            <!--- CONTENT -->
          </div>
        </section>
      </div>
    </div>
  </div>
</div>
