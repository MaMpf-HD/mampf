<figcaption id="annotation-caption" data-cy="annotation-caption">
  <div id="annotation-infobar">
    <!--- ANNOTATION CATEGORY -->
  </div>
  <div id="annotation-comment" data-cy="annotation-comment">
    <!--- ANNOTATION COMMENT -->
  </div>
  <!--- ANNOTATION AREA BUTTONS -->
  <div id="annotation-area-buttons">
    <a id="annotation-previous-button" class="btn" title="<%= t('admin.annotation.previous_annotation') %> (A)">
      <i class="fa fa-arrow-left"></i>
    </a>

    <a id="annotation-next-button" class="btn" title="<%= t('admin.annotation.next_annotation') %> (D)">
      <i class="fa fa-arrow-right"></i>
    </a>

    <a id="annotation-goto-button" class="btn" title="<%= t('admin.annotation.annotation_position') %> (S)">
      <i class="fa fa-map-pin"></i>
    </a>

    <a id="annotation-edit-button" class="btn" title="<%= t('admin.annotation.edit_annotation') %>">
      <i class="fa fa-pen"></i>
    </a>

    <a id="annotation-close-button" class="btn" title="<%= t('admin.annotation.close_annotation_area') %>">
      <i class="far fa-times-circle"></i>
    </a>
  </div>
</figcaption>
