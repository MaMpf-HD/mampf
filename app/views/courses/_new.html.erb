<div class="bg-green-lighten-4 p-3 mb-3 rounded"
  data-controller="administration--index--create-buttons">
<div class="row">
  <div class="col-12">
    <h6>
      <%= t('admin.course.new_course') %>
    </h6>
  </div>
</div>
<%= form_with model: course,
              html: { id: 'new-course-form' },
        data: { turbo: true,
          action: 'turbo:submit-end->administration--index--create-buttons#submitEnd' },
              local: true do |f| %>
  <div class="row">
    <div class="col-12 mb-3">
      <%= f.label :title, t('basics.title'),
                  class: "form-label" %>
      <%= helpdesk(t('admin.course.info.title'), false) %>
      <%= f.text_field :title, { class: "form-control",
                                id: 'new_course_title' } %>
      
    </div>
    <div class="col-12 mb-3">
      <%= f.label :short_title, t('basics.short_title'),
                  class: "form-label" %>
      <%= helpdesk(t('admin.course.info.short_title'), false) %>
      <%= f.text_field :short_title, { class: "form-control",
                                id: 'new_course_short_title' } %>
    </div>
    <div class="col-12 mb-3">
      <%= f.label :editor_ids,
                  t('basics.editors'),
                  class: "form-label" %>
      <%= helpdesk(t('admin.course.info.editors'), false) %>
      <%= f.select :editor_ids,
                   options_for_select([[current_user.info, current_user.id]],
                                       current_user.id),
                   {},
                   { class: 'selectize',
                     required: true,
                     multiple: true,
                     style: 'display: none;',
                     data: { ajax: true,
                             model: 'user',
                             filled: false,
                             placeholder: t('basics.enter_two_letters'),
                             no_results: t('basics.no_results') } } %>
    </div>
    <div class="col-12 mb-3">
      <%= f.label :division_ids,
                  t('admin.course.divisions'),
                  class: "form-label" %>
      <%= helpdesk(t('admin.course.info.divisions'), false) %>
      <%= f.select :division_ids,
                   options_for_select(Division.all.map { |d| [d.name_with_program, d.id] },
                                      course.division_ids),
                   {},
                   { class: 'selectize',
                     multiple: true,
                     style: 'display: none;',
                     data: { ajax: false } } %>
    </div>
    <div class="col-12 mb-3">
      <div class="form-check">
        <%= f.check_box :term_independent,
                        class: 'form-check-input' %>
        <%= f.label :term_independent,
                    t('admin.course.term_independent'),
                    class: "form-label" %>
        <%= helpdesk(t('admin.course.info.term_independent'), false) %>
      </div>
    </div>
  </div>
  <div class="row">
    <div class="col-12 text-center">
      <%= f.submit t('buttons.save'), class: 'btn btn-primary' %>
      <%= link_to t('buttons.cancel'),
                  administration_path,
                  class: 'btn btn-secondary',
                  data: { turbo_frame: dom_id(Course.new),
                          role: 'button',
                          action: 'click->administration--index--create-buttons#cancel' } %>
    </div>
  </div>
<% end %>
</div>
