<div id="image-uploadArea"
     class="form-group"
     data-controller="uppy-upload"
     data-uppy-upload-kind-value="image"
     data-uppy-upload-endpoint-value="/screenshots/upload"
     data-uppy-upload-failure-message-value="<%= t('submission.upload_failure') %>"
     data-uppy-upload-hidden-input-selector-value="#upload-image-hidden"
     data-uppy-upload-warning-selector-value="#course-basics-warning"
     data-uppy-upload-preview-selector-value="#image-preview"
     data-uppy-upload-detach-selector-value="#course_detach_image">
  <div data-uppy-upload-target="dashboard"></div>
  <div class="row p-2">
    <div id="image-meta"
         class="col-12 meta rounded"
         style="display:<%= show(course.image.present?) %>">
      <div class="row">
        <div class="col-11">
          <%= t('basics.file') %>:
          <span id="image-file">
            <%= course.image_filename %>
          </span>
        </div>
        <div class="col-1 text-end">
          <button type="button" class="btn-close" aria-label="Close" id="detach-image"></button>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <%= t('basics.size') %>:
          <span id="image-size">
            <%= number_to_human_size(course.image_size) %>
          </span>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <%= t('image.resolution') %>:
          <span id="image-resolution">
            <%= course.image_resolution %>
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
