<div
  id="newItemModal"
  class="modal fade"
  aria-hidden="true"
  aria-labelledby="newItemModalLabel"
  role="dialog"
  tabindex="-1"
>
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 id="newItemModalLabel"
          class="modal-title">
          <%= t('admin.item.create_external') %>
        </h5>
        <button type="button"
          class="btn-close"
          aria-label="Close" data-bs-dismiss="modal">
        </button>
      </div>
      <div id="new-item-modal-content"
        class="modal-body">
        <%= form_with model: item, id: 'external_item_form' do |f|%>
        <div id="referral_description_field"
          class="mb-3 row">
          <div class="col-2 col-form-label">
            <%= f.label :description, t('basics.title'),
            class: "form-label" %>
            <%= helpdesk(t('admin.item.info.title'), false) %>
          </div>
          <div class="col-8">
            <%= f.text_field :description,
            { size: 50, class: 'form-control' } %>
            <div id="item-description-error" class="invalid-feedback">
            </div>
          </div>
        </div>
        <div id="referral_link_field"
          class="mb-3 row">
          <div class="col-2 col-form-label">
            <%= f.label :link, t('basics.link'),
            class: "form-label" %>
            <%= helpdesk(t('admin.item.info.link'), false) %>
          </div>
          <div class="col-8">
            <%= f.text_field :link,
            { size: 50, class: 'form-control' } %>
            <div id="item-link-error" class="invalid-feedback">
            </div>
          </div>
          <div class="col-2 col-form-label">
            <button id="item-test-link" type="button"
              class="btn btn-sm btn-outline-info">
              <%= t('buttons.test') %>
            </button>
          </div>
        </div>
        <div id="referral_explanation_field"
          class="mb-3 row">
          <div class="col-2 col-form-label">
            <%= f.label :explanation, t('admin.item.explanation'),
            class: "form-label" %>
            <%= helpdesk(t('admin.item.info.explanation'), false) %>
          </div>
          <div class="col-8">
            <%= f.text_area :explanation,
            { class: 'form-control' } %>
            <div id="item-explanation-error" class="invalid-feedback">
            </div>
          </div>
        </div>
        <%= f.hidden_field :sort, value: 'link' %>
        <%= f.hidden_field :from, value: 'referral' %>
        <%= f.hidden_field :locale, value: I18n.locale %>
        <div class="row">
          <div class="col-12 text-center">
            <%= f.submit t('buttons.save'), class: 'btn btn-primary' %>
            <button type="button" class="btn btn-secondary ms-3"
              data-bs-dismiss="modal">
              <%= t('buttons.cancel') %>
            </button>
          </div>
        </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
