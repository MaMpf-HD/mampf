<div
  id="genericUsersModal"
  class="modal fade"
  aria-hidden="true"
  aria-labelledby="genericUsersModalLabel"
  role="dialog"
  tabindex="-1"
>
  <div class="modal-dialog modal-lg"
    role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 id="genericUsersModalLabel"
          class="modal-title">
          <%= t('admin.user.edit_generics') %>
        </h5>
        <button type="button"
          class="btn-close"
          aria-label="Close"
          data-bs-dismiss="modal">
        </button>
      </div>
      <div id="generic-users-modal-content"
        class="modal-body">
        <%= render partial: "users/generic_users",
        locals: { generic_users_count: generic_users_count } %>
      </div>
      <div class="modal-footer">
        <div class="row">
          <div class="col-12 text-center">
            <button type="button"
              class="btn btn-sm btn-secondary"
              data-bs-dismiss="modal">
              <%= t('buttons.close') %>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
