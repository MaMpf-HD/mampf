<%= sanitize(
                  t('roster.mailer.roster_moved_between_groups_email_body',
                        name: @username,
                        lecture_title: @lecture&.title || '',
                        old_rosterable_type: @old_rosterable.model_name.human,
                        old_rosterable_title: @old_rosterable.title,
                        new_rosterable_type: @new_rosterable.model_name.human,
                        new_rosterable_title: @new_rosterable.title),
                  tags: %w[p strong br a],
                  attributes: %w[href]
            ) %>
<% if @rosterable_link %>
      <%= sanitize(
                        t('roster.mailer.link_text',
                              rosterable_link: link_to(t('basics.link'), @rosterable_link)),
                        tags: %w[p strong br a],
                        attributes: %w[href]
                  ) %>
<% end %>
<%= sanitize(t('roster.mailer.end_mail'), tags: %w[p strong br a], attributes: %w[href]) %>
