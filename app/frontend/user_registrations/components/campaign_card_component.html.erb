<div>
  <% if notices_present? %>
    <div class="student-registration-campaign-notices d-flex flex-column gap-2">
      <% if readonly? %>
        <div
          class="
            p-3 rounded <%= "pb-4" unless ineligible? %>
            student-registration-campaign-notice
            student-registration-campaign-notice--readonly
          "
        >
          <div class="student-registration-campaign-notice-title">
            <%= t("registration.user_registration.readonly_notice.title") %>
          </div>

          <p class="student-registration-campaign-notice-body mb-0">
            <%= t("registration.user_registration.readonly_notice.description") %>
          </p>
        </div>
      <% end %>

      <% if ineligible? %>
        <div
          class="
            p-3 pb-4 rounded
            student-registration-campaign-notice
            student-registration-campaign-notice--ineligible
          "
        >
          <div class="student-registration-campaign-notice-title">
            <%= t("registration.user_registration.ineligible_notice.title") %>
          </div>

          <p class="student-registration-campaign-notice-body mb-2">
            <%= t("registration.user_registration.ineligible_notice.description") %>
          </p>

          <ul class="student-registration-campaign-notice-body mb-0 ps-3">
            <% failed_ineligible_policies.each do |policy| %>
              <li class="mb-1">
                <%= eligibility_failure_message(policy,
                                                user: helpers.current_user,
                                                context: :registration) %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if finalization_policy_warning? %>
        <div
          class="
            p-3 pb-4 rounded
            student-registration-campaign-notice
            student-registration-campaign-notice--ineligible
          "
        >
          <div class="student-registration-campaign-notice-title">
            <%= t("registration.user_registration.finalization_policy_notice.title") %>
          </div>

          <p class="student-registration-campaign-notice-body mb-2">
            <%= t("registration.user_registration.finalization_policy_notice.description") %>
          </p>

          <ul class="student-registration-campaign-notice-body mb-0 ps-3">
            <% failed_finalization_policies.each do |policy| %>
              <li class="mb-1">
                <%= eligibility_failure_message(policy,
                                                user: helpers.current_user,
                                                context: :finalization_warning) %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  <% end %>

  <div
    class="
      card campaign-section registration-campaign-card
      student-registration-campaign-card
      <%= "student-registration-campaign-card--with-notice" if notices_present? %>
      <%= "student-registration-campaign-card--inactive" if main_disabled? %>
    "
  >
    <div class="card-header registration-campaign-card-header">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <div>
          <h6 class="mb-0 fw-semibold">
            <%= campaign_title %>
          </h6>
        </div>

        <div>
          <div
            class="
              d-flex align-items-baseline justify-content-start
              justify-content-md-end flex-nowrap text-start text-md-end
              text-muted small
            "
          >
            <span class="me-2">
              <%= t("registration.campaign.index.columns.deadline") %>
            </span>

            <span class="fw-semibold text-body">
              <%= helpers.format_date(campaign.registration_deadline) %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="card-body">
      <% if closed_early? %>
        <div class="alert alert-warning py-2 mb-3">
          <%= t("registration.user_registration.closed_before_deadline") %>
        </div>
      <% end %>

      <% if policy_overview? %>
        <div class="border rounded p-3 mb-3 bg-body-tertiary">
          <div class="fw-semibold mb-2">
            <%= t("registration.user_registration.policy_overview.title") %>
          </div>

          <% policy_overview_sections.each_with_index do |section, index| %>
            <div class="<%= 'mb-3' if index < policy_overview_sections.size - 1 %>">
              <div class="small fw-semibold text-uppercase text-muted mb-1">
                <%= section[:title] %>
              </div>

              <div class="small text-muted mb-2">
                <%= section[:description] %>
              </div>

              <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
                <% section[:policies].each do |policy| %>
                  <li class="d-flex justify-content-between align-items-start gap-2">
                    <div class="small">
                      <%= eligibility_policy_summary(policy) %>
                    </div>

                    <span class="badge flex-shrink-0 <%= eligibility_policy_status_badge_class(policy) %>">
                      <%= eligibility_policy_status_label(policy) %>
                    </span>
                  </li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
      <% end %>

      <% unless main_disabled? %>
        <div class="student-registration-campaign-instruction fw-semibold mb-3">
          <%= instruction %>
        </div>
      <% end %>

      <% if campaign.first_come_first_served? %>
        <%= render partial: "user_registrations/first_come_first_served/" \
                           "select_first_come_first_served",
                   locals: { campaign: campaign,
                             disabled: main_disabled?,
                             items: items } %>
      <% else %>
        <%= render partial: "user_registrations/preference_based/select_preference",
                   locals: { campaign: campaign,
                             disabled: main_disabled?,
                             item_preferences: item_preferences,
                             items: items } %>
      <% end %>
    </div>
  </div>
</div>
