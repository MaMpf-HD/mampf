<% lecture_lesson_highlight_actions = [
    "mouseenter->lecture-highlights#highlightLesson",
    "mouseleave->lecture-highlights#resetLesson"
].join(" ") %>

<%= link_to lesson.date_localized,
            lesson_path(lesson),
            class: 'badge bg-secondary lecture-lesson me-1',
            id: 'lecture-' + dom_id(lesson),
            data: { id: lesson.id,
                    tags: lesson.tags.map(&:id),
                    action: lecture_lesson_highlight_actions }  %>