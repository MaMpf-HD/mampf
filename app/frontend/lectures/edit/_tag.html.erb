<% lecture_tag_highlight_actions = [
    "mouseenter->lecture-highlights#highlightTag",
    "mouseleave->lecture-highlights#resetTag"
].join(" ") %>

<%= link_to shorten(tag.title, 45),
            edit_tag_path(tag),
            id: 'lecture-' + dom_id(tag),
            class: 'badge text-dark lecture-tag lecture-tag',
            title: (tag.title if tag.title.length > 45),
            data: { id: tag.id,
                    lessons: tag.lessons.map(&:id),
                    action: lecture_tag_highlight_actions,
                    toggle: 'tooltip',
                    placement: 'bottom' } %>