<h3 class="lecture-pane-header">
  <%= t("admin.lecture.home_page") %>
</h3>

<p class="text-muted">
  <%= t("admin.lecture.home_intro_lead") %>
  <%= link_to t("admin.lecture.home_preview"),
              lecture_home_path(lecture),
              target: "_blank",
              rel: "noopener" %>
</p>

<%= form_with model: lecture,
              local: true,
              data: {
                turbo_frame: "lecture-area",
                controller: "lecture-home-form",
                action: "change->lecture-home-form#showWarning",
                lecture_home_form_cancel_url_value:
                  edit_lecture_path(lecture, tab: "home")
              },
              html: { id: "lecture-home-form", multipart: true } do |f| %>
  <div class="row">
    <div class="col-12">
      <%= f.label :home_intro,
                  t("admin.lecture.home_intro_label"),
                  class: "form-label" %>
      <%= helpdesk(t("admin.lecture.info.home_intro"), false) %>

      <%# The wrapper scopes the CSS rule hiding Trix's file-attach button,
          see lectures.scss %>
      <div class="lecture-home-trix">
        <%= f.trix_editor :home_intro,
                          id: "lecture-home-intro-trix",
                          data: { content: lecture.home_intro,
                lecture_home_form_target: "editor",
                action: "trix-initialize->lecture-home-form#updatePreview " \
                  "trix-change->lecture-home-form#updatePreview " \
                  "trix-change->lecture-home-form#showWarning " \
                  "trix-file-accept->lecture-home-form#rejectAttachment",
                                  testid: "lecture-home-intro-editor" } %>
      </div>
    </div>
  </div>

  <div class="row mt-2">
    <div class="col-12">
      <div class="form-text mb-1"><%= t("basics.preview") %></div>
      <div class="alert alert-dark bg-mdb-color-lighten-6"
           id="lecture-home-intro-preview"
         data-lecture-home-form-target="preview"
           data-testid="lecture-home-intro-preview"></div>
    </div>
  </div>

  <div class="row mt-3">
    <div class="col-12">
      <%= f.label :home_attachment,
                  t("admin.lecture.home_attachment_label"),
                  class: "form-label" %>

      <% if lecture.home_attachment.present? %>
        <div class="mb-2 d-flex align-items-center gap-2">
          <i class="fas fa-paperclip" aria-hidden="true"></i>
          <%= link_to lecture.home_attachment_filename,
                      lecture_home_attachment_path(lecture),
                      target: "_blank",
                      rel: "noopener" %>

          <%= f.check_box :remove_home_attachment, class: "btn-check" %>
          <%= f.label :remove_home_attachment,
                      class: "btn btn-sm btn-outline-danger",
                      title: t("admin.lecture.home_attachment_remove"),
                      "aria-label": t("admin.lecture.home_attachment_remove") do %>
            <i class="bi bi-trash" aria-hidden="true"></i>
          <% end %>
        </div>
      <% end %>

      <%= f.file_field :home_attachment,
                       class: "form-control",
                       accept: "application/pdf" %>
      <div class="form-text">
        <%= t("admin.lecture.home_attachment_hint") %>
      </div>
    </div>
  </div>

  <div class="row mt-3">
    <div class="col-12 text-center">
      <div id="lecture-home-warning" data-lecture-home-form-target="warning">
        <%= t("warnings.unsaved_changes") %>
        <%= hidden_field_tag :subpage, "home" %>
        <%= f.submit t("buttons.save"), class: "btn btn-primary",
                     data: { testid: "lecture-home-save" } %>
        <button type="button"
          id="cancel-lecture-home"
          class="btn btn-secondary"
          data-action="click->lecture-home-form#cancel">
          <%= t("buttons.cancel") %>
        </button>
      </div>
    </div>
  </div>
<% end %>
