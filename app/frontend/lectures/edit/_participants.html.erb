<div class="col-12">
  <% if show_muesli_transition_banner?(lecture) %>
    <div class="alert alert-warning d-flex align-items-start mb-3"
         role="alert"
         data-testid="roster-transition-banner">
      <i class="bi bi-info-circle-fill flex-shrink-0 me-2 mt-1"
         aria-hidden="true"></i>
      <div><%= t("roster.banners.participants", term: lecture.term.to_label) %></div>
    </div>
  <% end %>

  <%= turbo_frame_tag "roster_participants_panel",
                      src: lecture_roster_participants_path(lecture),
                      loading: "lazy" do %>
    <div class="text-center my-5">
      <div class="spinner-border" role="status">
        <span class="visually-hidden">Loading...</span>
      </div>
    </div>
  <% end %>
</div>
