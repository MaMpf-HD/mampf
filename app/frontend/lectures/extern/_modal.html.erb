<div
  id="newLectureModal"
  class="modal fade"
  aria-hidden="true"
  aria-labelledby="newLectureModalLabel"
  data-backdrop="static"
  data-keyboard="false"
  role="dialog"
  tabindex="-1"
>
  <div class="modal-dialog modal-lg"
    role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 id="newLectureModalLabel"
          class="modal-title">
          <%= t('admin.main.create_lecture') %>
        </h5>
      </div>
      <div id="new-lecture-modal-content"
        class="modal-body">
        <div id="new-lecture-area">
        </div>
      </div>
    </div>
  </div>
</div>
