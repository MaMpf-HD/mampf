<%= vite_stylesheet_tag "lectures/search/_search.scss" %>

<div id="lecture-search"
     data-controller="lecture-search"
     data-testid="lecture-search">

  <div id="lecture-search-wrapper" class="glass">
    <%= form_with url: search_lectures_path,
                  method: :get,
                  data: { remote: false,
                          turbo_stream: true,
                          lecture_search_target: "form" } do |f| %>

      <div id="lecture-search-term-filter"
           class="btn-group mb-3"
           role="group"
           aria-label="<%= t('lecture.search.term_filter') %>">
        <%= radio_button_tag "search[term_scope]", "current", false,
                             class: "btn-check",
                             id: "lecture-search-current-term",
                             autocomplete: "off",
                             data: {
                               action: "pointerdown->lecture-search#rememberTermFilterState " \
                                       "click->lecture-search#toggleTermFilter " \
                                       "keydown.space->lecture-search#clearTermFilterWithKeyboard " \
                                       "change->lecture-search#search"
                             } %>
        <%= label_tag "lecture-search-current-term",
                      class: "btn btn-outline-primary lecture-search-term-filter-label",
                      data: {
                        action: "pointerdown->lecture-search#rememberTermFilterState " \
                                "click->lecture-search#toggleTermFilter"
                      } do %>
           <i class="fas fa-check lecture-search-filter-check" aria-hidden="true"></i>
          <span><%= t('lecture.search.current_term') %></span>
        <% end %>

        <%= radio_button_tag "search[term_scope]", "next", true,
                             class: "btn-check",
                             id: "lecture-search-next-term",
                             autocomplete: "off",
                             data: {
                               action: "pointerdown->lecture-search#rememberTermFilterState " \
                                       "click->lecture-search#toggleTermFilter " \
                                       "keydown.space->lecture-search#clearTermFilterWithKeyboard " \
                                       "change->lecture-search#search"
                             } %>
        <%= label_tag "lecture-search-next-term",
                      class: "btn btn-outline-primary lecture-search-term-filter-label",
                      data: {
                        action: "pointerdown->lecture-search#rememberTermFilterState " \
                                "click->lecture-search#toggleTermFilter"
                      } do %>
           <i class="fas fa-check lecture-search-filter-check" aria-hidden="true"></i>
          <span><%= t('lecture.search.next_term') %></span>
        <% end %>
      </div>

      <div id="lecture-search-input-group">
        <%= f.text_field "search[fulltext]",
                          class: "form-control",
                          id: "lecture-search-bar",
                          placeholder: t('lecture.search.placeholder'),
                          "aria-label": t('lecture.search.placeholder'),
                          data: { action: "input->lecture-search#search",
                                  testid: "lecture-search-bar" } %>
        <i class="fas fa-search" id="lecture-search-icon"></i>
      </div>

    <% end %>
  </div>

  <div id="lecture-search-results-wrapper">
    <!-- filled via Turbo Stream -->
  </div>

</div>
