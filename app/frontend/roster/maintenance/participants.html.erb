<%= turbo_frame_tag "roster_participants_panel" do %>
  <%= vite_stylesheet_tag "roster/roster.scss" %>
  <%= render RosterParticipantsComponent.new(
        lecture: @lecture,
        group_type: @group_type,
        participants: @participants,
        pagy: @pagy,
        filter_mode: @participants_filter,
        search_string: @search_string,
        counts: {
          total: @total_participants_count,
          unassigned: @unassigned_participants_count
        }
      ) %>
<% end %>
