<div class="<%= column_classes %>" id="<%= dom_id(dom_target) %>">
  <% if student_tile? %>
    <div
      class="<%= card_classes %>"
      data-testid="registration-group-tile"
      <% if tile_tooltip_text.present? %>
        tabindex="0"
        title="<%= tile_tooltip_text %>"
        data-bs-toggle="tooltip"
      <% end %>
    >
      <div class="tutorial-gtile-top-bar <%= top_bar_class %>"></div>

      <div class="card-body d-flex flex-column">
        <div
          class="
            d-flex justify-content-between align-items-start
            student-registration-tile-header mb-2
          "
        >
          <div class="flex-grow-1">
            <div class="tutorial-gtile-type"><%= type_text %></div>

            <h6 class="tutorial-gtile-name mt-1" title="<%= title_text %>">
              <%= title_text %>
            </h6>
          </div>

          <% if tile_status_content.present? %>
            <div
              class="
                student-registration-tile-status d-flex flex-column gap-1
                align-items-end
              "
            >
              <%= tile_status_content %>
            </div>
          <% end %>
        </div>

        <div class="student-registration-tile-meta small flex-grow-1">
          <% tile_metadata_rows.each do |row| %>
            <% if row[:icon].present? %>
              <div
                class="text-muted <%= row[:class_name] %>"
                <% if row[:label].present? %>
                  title="<%= row[:label] %>"
                  data-bs-toggle="tooltip"
                <% end %>
              >
                <i class="bi <%= row[:icon] %> me-1" aria-hidden="true"></i>

                <% if row[:label].present? %>
                  <span class="visually-hidden"><%= row[:label] %>:</span>
                <% end %>

                <%= row[:value] %>
              </div>
            <% elsif row[:label].present? %>
              <div class="d-flex gap-1 <%= row[:class_name] %>">
                <span class="fw-medium"><%= row[:label] %>:</span>
                <span><%= row[:value] %></span>
              </div>
            <% else %>
              <div class="small text-muted <%= row[:class_name] %>">
                <%= row[:value] %>
              </div>
            <% end %>
          <% end %>

          <% if tile_footer_content.present? %>
            <div class="student-registration-tile-footer small text-muted">
              <%= tile_footer_content %>
            </div>
          <% end %>
        </div>

        <% if tile_actions_content.present? %>
          <div
            class="
              tutorial-gtile-actions mt-3 pt-2 border-top d-flex gap-2
              justify-content-end
            "
          >
            <%= tile_actions_content %>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div
      class="<%= card_classes %>"
      data-tutorial-roster-panel-target="tile"
      data-action="click->tutorial-roster-panel#openFromTile"
      data-roster-key="<%= roster_key %>"
      data-roster-panel-path="<%= panel_path %>"
      data-roster-type="<%= registerable.class.name.underscore %>"
      data-roster-id="<%= registerable.id %>"
      data-roster-full="<%= registerable.full? %>"
      data-roster-title="<%= registerable.title %>"
      data-roster-add-member-path="<%= add_member_path %>"
    >
      <div class="tutorial-gtile-top-bar <%= top_bar_class %>"></div>

      <div class="card-body d-flex flex-column position-relative">
        <% if show_self_enrollment_dropdown? %>
          <div class="dropdown position-absolute tutorial-gtile-sm-dropdown">
            <button
              class="btn btn-sm p-0 border-0 <%= sm_button_class %>"
              type="button"
              data-bs-toggle="dropdown"
              data-bs-boundary="window"
              aria-expanded="false"
              title="<%= sm_tooltip %>"
            >
              <i class="bi <%= sm_icon_class %>"></i>
            </button>

            <ul
              class="
                dropdown-menu dropdown-menu-end shadow-sm
                tutorial-gtile-sm-menu
              "
            >
              <li>
                <h6 class="dropdown-header">
                  <%= t("roster.self_materialization.label") %>
                </h6>
              </li>

              <% sm_modes.each do |mode| %>
                <% path = sm_update_path(mode) %>
                <% next unless path %>

                <li>
                  <%= link_to path,
                      class: "dropdown-item #{'active' if sm_mode == mode}",
                      data: { turbo_method: :patch } do %>
                    <i class="bi <%= sm_icon_for(mode) %> me-2"></i>

                    <%= t(mode,
                        scope: "roster.self_materialization.modes",
                        default: mode.titleize) %>
                  <% end %>
                </li>
              <% end %>

              <li><hr class="dropdown-divider"></li>

              <li>
                <%= link_to bulk_sm_path,
                    class: "dropdown-item",
                    data: {
                      turbo_method: :patch,
                      turbo_confirm: bulk_sm_confirm
                    } do %>
                  <i class="bi bi-check2-all me-2"></i>

                  <%= t("roster.self_materialization.apply_to_all_free_groups") %>
                <% end %>
              </li>
            </ul>
          </div>
        <% end %>

        <div class="tutorial-gtile-type pe-4"><%= type_text %></div>

        <h6
          class="tutorial-gtile-name text-truncate"
          title="<%= registerable.title %>"
        >
          <%= registerable.title %>
        </h6>

        <div class="text-muted mt-2 flex-grow-1">
          <i class="bi bi-person me-1"></i>
          <%= tutors_text %>
        </div>

        <% if location_text.present? %>
          <div class="text-muted small">
            <i class="bi bi-geo-alt me-1"></i>
            <%= location_text %>
          </div>
        <% end %>

        <% if date_text.present? %>
          <div
            class="text-muted small"
            title="<%= t("basics.date") %>"
            data-bs-toggle="tooltip"
          >
            <i class="bi bi-calendar-event me-1" aria-hidden="true"></i>
            <span class="visually-hidden"><%= t("basics.date") %>:</span>
            <%= date_text %>
          </div>
        <% end %>

        <div class="small text-muted">
          <% if item %>
            <%= registration_count %>
            /
            <%= registerable.capacity || "∞" %>
          <% else %>
            <%= registerable.roster_entries.count %>
            /
            <%= registerable.capacity || "∞" %>
          <% end %>
        </div>

        <div
          class="
            tutorial-gtile-actions mt-3 pt-2 border-top d-flex gap-2
            justify-content-end
          "
        >
          <% if edit_path %>
            <%= link_to edit_path,
                    class: "btn btn-sm btn-primary",
                    title: t("roster.tooltips.edit_settings"),
                    data: { turbo_stream: true, bs_toggle: "tooltip" } do %>
              <i class="bi bi-pencil"></i>
            <% end %>
          <% end %>

          <% if delete_path && delete_disabled? %>
            <span title="<%= delete_disabled_title %>" data-bs-toggle="tooltip">
              <button
                class="btn btn-sm btn-outline-danger opacity-50"
                type="button"
                style="cursor: not-allowed;"
                disabled
              >
                <i class="bi bi-trash"></i>
              </button>
            </span>
          <% elsif delete_path %>
            <%= link_to delete_path,
                    class: "btn btn-sm btn-danger",
                    title: delete_title,
                    data: delete_data do %>
              <i class="bi bi-trash"></i>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
