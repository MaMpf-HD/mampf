<% I18n.with_locale(@lecture.locale_with_inheritance || I18n.default_locale) do %>
  <div class="mb-3">
    <ul
      class="nav nav-tabs mb-3"
      id="rosterTabs"
      role="tablist"
      data-action="shown.bs.tab->tutorial-roster-panel#closeOnLeavingLanes"
    >
      <li class="nav-item" role="presentation">
        <button
          class="nav-link <%= 'active' if @roster_tab == :lanes %>"
          data-bs-toggle="tab"
          data-bs-target="#lanes-pane"
          type="button"
          role="tab"
        >
          <%= t("roster.tabs.groups") %>
        </button>
      </li>

      <li class="nav-item" role="presentation">
        <button
          class="nav-link <%= 'active' if @roster_tab == :enrollment %>"
          id="candidates-tab"
          data-bs-toggle="tab"
          data-bs-target="#candidates-pane"
          type="button"
          role="tab"
        >
          <%= t('roster.tabs.enrollment') %>
        </button>
      </li>
    </ul>

    <div class="tab-content" id="rosterTabsContent">
      <div
        class="tab-pane fade <%= 'show active' if @roster_tab == :lanes %>"
        id="lanes-pane"
        role="tabpanel"
      >
        <%= render "registration/campaigns/index", lecture: @lecture %>
      </div>

      <div
        class="tab-pane fade <%= 'show active' if @roster_tab == :enrollment %>"
        id="candidates-pane"
        role="tabpanel"
      >
        <%= render "roster/components/enrollment_tab", component: self,
                                                        lecture: @lecture,
                                                        group_type: @group_type,
                                                        participants: @participants,
                                                        pagy: @pagy,
                                                        filter_mode: @filter_mode,
                                                        counts: @counts %>
      </div>
    </div>
  </div>
<% end %>
