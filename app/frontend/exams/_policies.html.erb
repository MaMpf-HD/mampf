<% campaign = exam.registration_campaign %>
<% frame_id = "exam_#{exam.id}_policies" %>

<div id="<%= frame_id %>">
  <% if exam.skip_campaigns %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle me-2"></i>
      <%= t("assessment.registration_tab.skip_campaigns_info") %>
    </div>
  <% elsif campaign.nil? %>
    <div class="alert alert-warning">
      <i class="bi bi-exclamation-triangle me-2"></i>
      <%= t("assessment.registration_tab.no_campaign") %>
    </div>
  <% else %>
    <div class="card mb-3">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">
          <%= t("registration.policy.index.title") %>

          <% if campaign.draft? %>
            <%= helpdesk(t("registration.policy.helpdesk.policies"), false) %>
          <% else %>
            <%= helpdesk(t("registration.policy.helpdesk.policies_frozen"),
                         false) %>
          <% end %>
        </h5>

        <% if campaign.draft? %>
          <%= link_to t("registration.policy.index.add"),
                      new_registration_campaign_policy_path(campaign,
                        frame_id: frame_id),
                      class: "btn btn-sm btn-primary",
                      role: "button",
                      data: { turbo_frame: "policy_form" } %>
        <% end %>
      </div>

      <div class="card-body">
        <%= turbo_frame_tag "policy_form" %>
        <%= render "registration/policies/list", campaign: campaign %>
      </div>
    </div>
  <% end %>
</div>
