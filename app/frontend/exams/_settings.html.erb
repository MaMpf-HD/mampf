<div id="exam-settings">
  <div
    class="
      d-flex flex-wrap align-items-center gap-2 mb-3 px-2 py-2
      bg-light rounded border text-muted small
    "
  >
    <span>
      <i class="bi bi-calendar-event me-1"></i>

      <% if exam.date %>
        <%= l(exam.date, format: :long) %>
      <% else %>
        <%= t('basics.not_specified') %>
      <% end %>
    </span>

    <span class="text-black-50">·</span>

    <span>
      <i class="bi bi-geo-alt me-1"></i>
      <%= exam.location.presence || t('basics.not_specified') %>
    </span>

    <span class="text-black-50">·</span>

    <span>
      <i class="bi bi-people me-1"></i>

      <% campaign = exam.registration_campaign if Flipper.enabled?(:registration_campaigns)
        in_registration = campaign && !campaign.completed?

        if in_registration
          count = campaign.total_registrations_count
          label = t("assessment.info_bar.registered")
        else
          count = exam.roster_entries_count
          label = t("assessment.info_bar.participants")
        end %>

      <% if exam.capacity %>
        <%= count %>
        /
        <%= exam.capacity %>
        <%= label %>
      <% else %>
        <%= count %>
        <%= label %>
      <% end %>
    </span>
  </div>

  <div class="row">
    <div class="col-12">
      <%= render "exams/delete_button", exam: exam %>

      <%= form_with model: exam,
                    url: exam_path(exam, tab: 'settings'),
                    html: { id: 'exam-form' },
                    data: { turbo: true, controller: "exams--form" } do |f| %>
        <%= render "exams/form_fields", f: f, exam: exam %>
      <% end %>
    </div>
  </div>
</div>
