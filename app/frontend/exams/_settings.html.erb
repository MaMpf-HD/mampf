<div id="exam-settings">
  <% unless exam.new_record? %>
    <% campaigns_enabled = Flipper.enabled?(:registration_campaigns)
       campaign = campaigns_enabled ? exam.registration_campaign : nil
       needs_opening = !exam.skip_campaigns &&
                       campaigns_enabled &&
                       (campaign.nil? || campaign.draft?)
       in_registration = campaign && !campaign.completed?
       bar_bg = needs_opening ? "bg-warning-subtle" : "bg-info-subtle"
       if in_registration
         count = campaign.total_registrations_count
         count_label = t("assessment.info_bar.registered")
       else
         count = exam.roster_entries_count
         count_label = t("assessment.info_bar.participants")
       end %>
    <div
      class="
        d-flex flex-wrap align-items-center gap-2 mb-3 px-2 py-2
        <%= bar_bg %> rounded border text-muted small
      "
    >
      <span>
        <i class="bi bi-calendar-event me-1"></i>
        <%= exam.date ? l(exam.date, format: :long) : t("basics.not_specified") %>
      </span>

      <span class="text-black-50">·</span>

      <span>
        <i class="bi bi-geo-alt me-1"></i>
        <%= exam.location.presence || t("basics.not_specified") %>
      </span>

      <span class="text-black-50">·</span>

      <span>
        <i class="bi bi-people me-1"></i>
        <%= count %>

        <% if exam.capacity %>
          /
          <%= exam.capacity %>
        <% end %>

        <%= count_label %>
      </span>

      <% if needs_opening %>
        <span class="text-black-50">·</span>
        <span class="text-warning-emphasis fw-semibold">
          <i class="bi bi-exclamation-triangle-fill me-1"></i>
          <%= t("assessment.settings_tab.registration_hint.inline") %>
        </span>
      <% end %>
    </div>
  <% end %>

  <% if exam.new_record? %>
    <div class="mb-3">
      <%= link_to exams_path(lecture_id: exam.lecture_id),
                  class: "btn btn-sm btn-outline-secondary",
                  role: "button",
                  data: { turbo_stream: true } do %>
        <i class="bi bi-arrow-left"></i> <%= t("back") %>
      <% end %>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3><%= t("assessment.new_exam") %></h3>
    </div>
  <% end %>

  <div class="row">
    <div class="col-12">
      <%= render "exams/delete_button", exam: exam unless exam.new_record? %>

      <% form_url = exam.new_record? ? exams_path : exam_path(exam, tab: 'settings') %>

      <%= form_with model: exam,
                    url: form_url,
                    html: { id: 'exam-form' },
                    data: { turbo: true, controller: "exams--form" } do |f| %>
        <%= render "exams/form_fields", f: f, exam: exam %>
      <% end %>
    </div>
  </div>
</div>
