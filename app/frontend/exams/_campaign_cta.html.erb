<div class="alert alert-warning d-flex align-items-center mt-3" role="alert">
  <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
  <div class="flex-grow-1">
    <%= t("assessment.campaign_cta.message") %>
  </div>
  <%= link_to edit_lecture_path(exam.lecture,
                tab: "campaigns",
                new_campaign: true),
              class: "btn btn-sm btn-warning ms-3 text-nowrap",
              data: { turbo_frame: "_top" } do %>
    <i class="bi bi-plus-circle me-1"></i><%= t("assessment.campaign_cta.create") %>
  <% end %>
</div>
