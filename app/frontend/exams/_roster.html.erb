<div id="exam-roster">
  <div class="row">
    <div class="col-12">
      <% if exam.roster_entries_count && exam.roster_entries_count > 0 %>
        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th scope="col"><%= t("basics.name") %></th>
                <th scope="col"><%= t("basics.email") %></th>
                <th scope="col"><%= t("roster.registered_at") %></th>
                <th scope="col"><%= t('student_performance.points') %></th>
                <th scope="col"><%= t('student_performance.achievements') %></th>
                <th scope="col"><%= t('student_performance.status') %></th>
                <th scope="col" class="text-end"><%= t("basics.actions") %></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td colspan="7" class="text-center py-4 text-muted">
                  <%= t("roster.roster_data_loading") %>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-5 bg-light rounded">
          <i class="bi bi-people display-1 text-muted mb-3 d-block"></i>
          <h6 class="text-muted"><%= t("roster.no_participants_yet") %></h6>
          <p class="text-muted small">
            <% if Flipper.enabled?(:registration_campaigns) %>
              <%= t("roster.participants_via_campaign") %>
            <% else %>
              <%= t("roster.participants_manual") %>
            <% end %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>
