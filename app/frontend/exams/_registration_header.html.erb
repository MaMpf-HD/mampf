<% reopen_after_deadline_fix ||= false %>

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
  <div class="d-flex flex-wrap align-items-center gap-2">
    <% if campaign.draft? %>
      <span class="badge bg-secondary">
        <%= t("assessment.registration_tab.status.not_open") %>
      </span>
    <% elsif !campaign.completed? %>
      <%= render "exams/registration_campaign_status", campaign: campaign %>
    <% end %>

    <% if campaign.completed? && campaign.updated_at %>
      <span class="text-muted small">
        <%= t("assessment.registration_tab.finalized_on",
              date: l(campaign.updated_at, format: :long)) %>
      </span>
    <% elsif campaign.open? || campaign.closed? || campaign.processing? %>
      <span class="text-muted small">
        <%= t("assessment.registration_tab.registered_count",
              count: campaign.total_registrations_count) %>
      </span>
    <% end %>
  </div>

  <div class="d-flex flex-wrap gap-2">
    <% if campaign.draft? %>
      <%= open_campaign_button(campaign, params: bp) %>
    <% elsif campaign.open? %>
      <%= close_campaign_button(campaign, params: bp) %>
    <% elsif campaign.closed? %>
      <% unless reopen_after_deadline_fix %>
        <%= reopen_campaign_button(campaign, params: bp) %>
      <% end %>
      <%= review_and_finalize_button(campaign,
                                     params: { frame_id: allocation_workspace_id }) %>
    <% elsif campaign.processing? %>
      <%= review_and_finalize_button(campaign,
                                     params: { frame_id: allocation_workspace_id }) %>
    <% end %>
  </div>
</div>
