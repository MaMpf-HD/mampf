<hr class="my-4">

<%= render "exams/participants_table",
           entries: exam.exam_rosters.includes(:user)
                        .joins(:user).merge(User.order(:name)),
           editable: true,
           exam: exam %>

<% rejected = campaign.user_registrations.where(status: :rejected) %>

<% if rejected.any? %>
  <h6 class="text-muted fw-semibold small text-uppercase mt-4 mb-2">
    <i class="bi bi-person-slash me-1"></i>
    <%= t("assessment.registration_tab.rejected_heading") %>
    <span class="badge bg-secondary ms-1"><%= rejected.count %></span>
  </h6>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th><%= t("basics.name") %></th>
          <th><%= t("basics.email") %></th>
        </tr>
      </thead>

      <tbody>
        <% rejected.includes(:user).each do |reg| %>
          <tr>
            <td><%= reg.user.name %></td>
            <td class="text-muted"><%= reg.user.email %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
