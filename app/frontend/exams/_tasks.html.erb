<div id="exam-tasks">
  <div class="alert alert-info" role="alert">
    <i class="bi bi-info-circle me-2"></i>
    <strong><%= t('basics.coming_soon') %>:</strong>
    <%= t('assessment.tasks_placeholder') %>
  </div>

  <div class="card">
    <div class="card-body text-center py-5">
      <i class="bi bi-clipboard-check display-1 text-muted mb-3"></i>
      <h5 class="card-title"><%= t('assessment.tasks_management') %></h5>
      <p class="card-text text-muted">
        <%= t('assessment.tasks_description') %>
      </p>
    </div>
  </div>
</div>
