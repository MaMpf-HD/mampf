<% entries ||= [] %>

<% if entries.any? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th><%= t("basics.name") %></th>
          <th><%= t("basics.email") %></th>
        </tr>
      </thead>

      <tbody>
        <% entries.each do |entry| %>
          <% user = entry.user %>

          <tr>
            <td><%= user.tutorial_name %></td>
            <td class="text-muted"><%= user.email %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="py-3 text-center text-muted">
    <i class="bi bi-people d-block mb-1" style="font-size: 1.5rem;"></i>
    <small><%= t("roster.no_participants_yet") %></small>
  </div>
<% end %>
