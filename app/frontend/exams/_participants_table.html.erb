<% entries ||= [] %>
<% editable ||= false %>
<% exam ||= nil %>

<% if editable && exam %>
  <% add_form_id = "exam-#{exam.id}-participants-add-form" %>
  <% add_form_open = entries.empty? %>
  <div data-controller="exams--registration-list">
    <div class="d-flex flex-column flex-sm-row gap-2 align-items-sm-end mb-3">
      <% if entries.any? %>
        <div class="flex-grow-1">
          <label
            class="form-label form-label-sm mb-1"
            for="exam-participants-filter"
          >
            <%= t("assessment.registration_tab.filter_label") %>
          </label>

          <input
            id="exam-participants-filter"
            type="text"
            class="form-control form-control-sm"
            placeholder="<%= t("assessment.registration_tab.filter_placeholder") %>"
            autocomplete="off"
            data-action="input->exams--registration-list#filter"
          >
        </div>
      <% end %>

      <div class="flex-shrink-0">
        <button
          class="
            btn btn-sm btn-outline-primary d-inline-flex align-items-center
            gap-1
          "
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#<%= add_form_id %>"
          aria-expanded="<%= add_form_open %>"
          aria-controls="<%= add_form_id %>"
        >
          <i class="bi bi-plus-lg"></i>
          <span><%= t("assessment.registration_tab.add_form_label") %></span>
        </button>
      </div>
    </div>

    <div
      id="<%= add_form_id %>"
      class="collapse <%= "show" if add_form_open %>"
    >
      <div class="border rounded-3 p-3 mb-3 bg-body-tertiary">
        <div class="small fw-semibold mb-2">
          <%= t("assessment.registration_tab.add_form_label") %>
        </div>

        <%= form_with url: participants_exam_path(exam), method: :post,
                      local: true,
                      class: "d-flex flex-column flex-sm-row gap-2" do |f| %>
          <%= f.email_field :email,
                            class: "form-control form-control-sm",
                            placeholder: t("assessment.registration_tab.add_placeholder"),
                            required: true,
                            autocomplete: "off",
                            aria: {
                              label: t("assessment.registration_tab.add_form_label")
                            } %>

          <%= f.submit t("assessment.registration_tab.add_button"),
                       class: "btn btn-sm btn-outline-primary flex-shrink-0" %>
        <% end %>

        <div class="small text-muted mt-2">
          <%= t("assessment.registration_tab.add_form_hint") %>
        </div>
      </div>
    </div>

    <% if entries.any? %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th><%= t("basics.name") %></th>
              <th><%= t("basics.email") %></th>
              <th class="text-end"><%= t("basics.actions") %></th>
            </tr>
          </thead>

          <tbody>
            <% entries.each do |entry| %>
              <% user = entry.user %>
              <% removable = exam.participant_removable?(user) %>

              <tr
                data-exams--registration-list-target="entry"
                data-student-search="<%= "#{user.name} #{user.email}".downcase %>"
              >
                <td><%= user.tutorial_name.presence || user.email %></td>
                <td class="text-muted"><%= user.email %></td>

                <td class="text-end">
                  <% if removable %>
                    <%= button_to remove_participant_exam_path(exam,
                                                               user_id: user.id),
                                  method: :delete,
                                  class: "btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-1",
                                  title: t("assessment.registration_tab.remove_tooltip"),
                                  aria: {
                                    label: t("assessment.registration_tab.remove_tooltip")
                                  },
                                  form: {
                                    class: "d-inline-block mb-0",
                                    data: {
                                      turbo_confirm: t("assessment.registration_tab.remove_confirm")
                                    }
                                  } do %>
                      <i class="bi bi-trash"></i>

                      <span>
                        <%= t("assessment.registration_tab.remove_button") %>
                      </span>
                    <% end %>
                  <% else %>
                    <span
                      class="d-inline-block"
                      title="<%= t("assessment.registration_tab.remove_disabled_tooltip") %>"
                    >
                      <button
                        type="button"
                        class="
                          btn btn-sm btn-outline-danger d-inline-flex
                          align-items-center gap-1
                        "
                        disabled
                        aria-label="<%= t("assessment.registration_tab.remove_disabled_tooltip") %>"
                      >
                        <i class="bi bi-trash"></i>

                        <span>
                          <%= t("assessment.registration_tab.remove_button") %>
                        </span>
                      </button>
                    </span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div
        class="small text-muted mt-2 text-center d-none"
        data-exams--registration-list-target="noResults"
      >
        <%= t("assessment.registration_tab.no_filter_results") %>
      </div>
    <% else %>
      <div class="py-3 text-center text-muted">
        <i class="bi bi-people d-block mb-1" style="font-size: 1.5rem;"></i>
        <small><%= t("roster.no_participants_yet") %></small>
      </div>
    <% end %>
  </div>
<% elsif entries.any? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th><%= t("basics.name") %></th>
          <th><%= t("basics.email") %></th>
        </tr>
      </thead>

      <tbody>
        <% entries.each do |entry| %>
          <% user = entry.user %>

          <tr>
            <td><%= user.tutorial_name %></td>
            <td class="text-muted"><%= user.email %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="py-3 text-center text-muted">
    <i class="bi bi-people d-block mb-1" style="font-size: 1.5rem;"></i>
    <small><%= t("roster.no_participants_yet") %></small>
  </div>
<% end %>