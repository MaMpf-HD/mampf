<% ui_state = ExamCampaignUiState.new(exam: exam) %>

<%= turbo_frame_tag "exam_#{exam.id}_registration_tab_label",
                    class: "d-inline" do %>
  <%= ui_state.registration_tab_label %>

  <% if ui_state.registration_tab_needs_attention? %>
    <span
      class="badge rounded-pill bg-warning ms-1"
      style="width: 0.5rem; height: 0.5rem; padding: 0;"
      title="<%= ui_state.registration_tab_tooltip %>"
      aria-label="<%= ui_state.registration_tab_tooltip %>"
    ></span>
  <% end %>
<% end %>
