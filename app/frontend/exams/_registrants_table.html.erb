<% cap = exam.capacity %>
<% grouped = campaign.user_registrations_grouped_by_user %>
<% rejected = local_assigns.fetch(:rejected_registrations, Registration::UserRegistration.none) %>

<hr class="my-4">

<% if cap.present? %>
  <div class="text-muted small mb-3">
    <%= t("assessment.registration_tab.capacity_label", capacity: cap) %>
  </div>
<% end %>

<% if grouped.any? || rejected.any? %>
  <div data-controller="exams--registration-list">
    <input
      type="text"
      class="form-control form-control-sm mb-3"
      placeholder="<%= t("assessment.registration_tab.filter_placeholder") %>"
      autocomplete="off"
      data-action="input->exams--registration-list#filter"
    >

    <% if grouped.any? %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th><%= t("basics.name") %></th>
              <th><%= t("basics.email") %></th>
              <th class="text-end"><%= t("basics.actions") %></th>
            </tr>
          </thead>

          <tbody>
            <% grouped.each do |user, _registrations| %>
              <tr
                data-exams--registration-list-target="entry"
                data-student-search="<%= "#{user.name} #{user.email}".downcase %>"
              >
                <td><%= user.tutorial_name.presence || user.email %></td>
                <td class="text-muted"><%= user.email %></td>

                <td class="text-end">
                  <%= button_to reject_for_user_registration_campaign_registrations_path(
                                  campaign, user_id: user.id,
                                  source: "registrations"),
                                method: :delete,
                                class: "btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-1",
                                title: t("assessment.registration_tab.reject_tooltip"),
                                aria: {
                                  label: t("assessment.registration_tab.reject_tooltip")
                                },
                                form: {
                                  class: "d-inline-block mb-0",
                                  data: {
                                    turbo_confirm: t("assessment.registration_tab.reject_confirm")
                                  }
                                } do %>
                    <i class="bi bi-trash"></i>

                    <span>
                      <%= t("assessment.registration_tab.reject_button") %>
                    </span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <% if rejected.any? %>
      <h6 class="text-muted fw-semibold small text-uppercase mt-4 mb-2">
        <i class="bi bi-person-slash me-1"></i>
        <%= t("assessment.registration_tab.rejected_heading") %>
        <span class="badge bg-secondary ms-1"><%= rejected.count %></span>
      </h6>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th><%= t("basics.name") %></th>
              <th><%= t("basics.email") %></th>
              <th><%= t("registration.user_registration.reason") %></th>
            </tr>
          </thead>

          <tbody>
            <% rejected.each do |registration| %>
              <% user = registration.user %>

              <tr
                data-exams--registration-list-target="entry"
                data-student-search="<%= "#{user.name} #{user.email}".downcase %>"
              >
                <td><%= user.tutorial_name.presence || user.email %></td>
                <td class="text-muted"><%= user.email %></td>
                <td><%= registration.localized_rejection_reason_label %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <div
      class="small text-muted mt-2 text-center d-none"
      data-exams--registration-list-target="noResults"
    >
      <%= t("assessment.registration_tab.no_filter_results") %>
    </div>
  </div>
<% end %>
