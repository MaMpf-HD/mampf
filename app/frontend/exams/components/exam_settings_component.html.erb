<div id="exam-settings" data-cy="exam-settings">
  <% if show_back_button? %>
    <div class="mb-3">
      <%= link_to back_path,
                  class: "btn btn-sm btn-outline-secondary",
                  role: "button",
                  data: { turbo_stream: true } do %>
        <i class="bi bi-arrow-left"></i> <%= t("back") %>
      <% end %>
    </div>
  <% end %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3><%= heading %></h3>
  </div>

  <% unless exam.new_record? %>
    <div class="d-flex flex-wrap align-items-center gap-2 mb-3 px-2 py-2 bg-light rounded border text-muted small">
      <span>
        <i class="bi bi-calendar-event me-1"></i>
        <%= display_date %>
      </span>

      <span class="text-black-50">·</span>

      <span>
        <i class="bi bi-geo-alt me-1"></i>
        <%= display_location %>
      </span>

      <span class="text-black-50">·</span>

      <span>
        <i class="bi bi-people me-1"></i>
        <%= display_capacity %>
      </span>
    </div>
  <% end %>

  <div class="row">
    <div class="col-12">
      <%= render "exams/delete_button", exam: exam if show_delete_button? %>

      <%= form_with model: exam,
                    url: form_url,
                    html: { id: "exam-form" },
                    data: { turbo: true, controller: "exams--form" } do |f| %>
        <%= render "exams/form_fields", f: f, exam: exam %>
      <% end %>
    </div>
  </div>
</div>
