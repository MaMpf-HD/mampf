<% campaign = exam.registration_campaign %>
<% frame_id = "exam_#{exam.id}_registration" %>
<% allocation_workspace_id = "exam_#{exam.id}_allocation_workspace" %>
<% phase = exam.status_phase %>

<% pre_finalization =
  %i[draft registration_open registration_closed].include?(phase) %>

<% exam.load_registration_deadline if campaign && exam.registration_deadline.blank? %>

<div id="<%= frame_id %>">
  <% if exam.skip_campaigns %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle me-2"></i>
      <%= t("assessment.registration_tab.skip_campaigns_info") %>
    </div>
    <%= render "exams/participants_table",
               entries: exam.exam_rosters.includes(:user)
                            .joins(:user).merge(User.order(:name)),
               editable: true,
               exam: exam %>
  <% elsif campaign.nil? %>
    <div class="alert alert-warning">
      <i class="bi bi-exclamation-triangle me-2"></i>
      <%= t("assessment.registration_tab.no_campaign") %>
    </div>
  <% else %>
    <%# Header: status + lifecycle action buttons %>
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
      <div class="d-flex flex-wrap align-items-center gap-2">
        <% if campaign.draft? %>
          <span class="badge bg-secondary">
            <%= t("assessment.registration_tab.status.not_open") %>
          </span>
        <% elsif !campaign.completed? %>
          <%= render "exams/registration_campaign_status", campaign: campaign %>
        <% end %>

        <% if !pre_finalization && campaign.updated_at %>
          <span class="text-muted small">
            <%= t("assessment.registration_tab.finalized_on",
                  date: l(campaign.updated_at, format: :long)) %>
          </span>
        <% elsif campaign.open? || campaign.closed? || campaign.processing? %>
          <span class="text-muted small">
            <%= t("assessment.registration_tab.registered_count",
                  count: campaign.total_registrations_count) %>
          </span>
        <% end %>
      </div>

      <div class="d-flex flex-wrap gap-2">
        <% if campaign.draft? %>
          <%= open_campaign_button(campaign, params: { frame_id: frame_id }) %>
        <% elsif campaign.open? %>
          <%= close_campaign_button(campaign, params: { frame_id: frame_id }) %>
        <% elsif campaign.closed? %>
          <%= reopen_campaign_button(campaign, params: { frame_id: frame_id }) %>
          <%= link_to t("registration.campaign.actions.review_and_finalize"),
                      registration_campaign_allocation_path(campaign,
                                                            frame_id: allocation_workspace_id),
                      class: "btn btn-primary",
                      data: { turbo_stream: true } %>
        <% elsif campaign.processing? %>
          <%= link_to t("registration.campaign.actions.review_and_finalize"),
                      registration_campaign_allocation_path(campaign,
                                                            frame_id: allocation_workspace_id),
                      class: "btn btn-primary",
                      data: { turbo_stream: true } %>
        <% end %>
      </div>
    </div>
    <%# Settings: deadline + policies %>
    <% unless campaign.completed? %>
      <%= form_with model: exam,
                  url: exam_path(exam, tab: "registration"),
                  data: {
                    turbo: true,
                    controller: "exams--registration-settings",
                    action: "turbo:submit-end->exams--registration-settings#resetAfterSave"
                  } do |f| %>
        <div class="row mb-3">
          <div class="col-md-2">
            <%= f.label :registration_deadline,
                      t("assessment.registration_deadline_label"),
                      class: "col-form-label" %>
          </div>

          <div class="col-md-5">
            <div
              class="input-group td-picker flex-nowrap align-items-start"
              id="exam-settings-deadline-picker"
              data-controller="datetimepicker"
              data-td-target-input="nearest"
              data-td-target-toggle="nearest"
            >
              <div class="flex-grow-1">
                <%= f.text_field :registration_deadline,
                               class: class_names(
                                 "form-control td-input",
                                 "is-invalid": exam.errors[:registration_deadline].present?
                               ),
                               disabled: campaign.completed?,
                               data: {
                                 td_target: "#exam-settings-deadline-picker",
                                 exams__registration_settings_target: "registrationDeadline",
                                 action: "change->exams--registration-settings#checkForChanges input->exams--registration-settings#checkForChanges"
                               },
                               value: exam.registration_deadline.try(:strftime, "%Y-%m-%d %H:%M") ||
                                      exam.registration_deadline,
                               autocomplete: "off" %>

                <% if exam.errors[:registration_deadline].present? %>
                  <div class="invalid-feedback d-block">
                    <%= exam.errors[:registration_deadline].join(", ") %>
                  </div>
                <% end %>
              </div>

              <span
                class="input-group-text td-picker-button"
                style="height: 38px"
                role="button"
                data-td-target="#exam-settings-deadline-picker"
                data-td-toggle="datetimepicker"
              >
                <i class="fas fa-calendar" data-td-toggle="datetimepicker"></i>
              </span>
            </div>

            <% if campaign.completed? %>
              <small class="text-muted d-block mt-1">
                <%= t("assessment.registration_deadline_locked_hint") %>
              </small>
            <% end %>
          </div>
        </div>

        <% unless campaign.completed? %>
          <div
            class="mt-3 text-center d-none"
            data-exams--registration-settings-target="warning"
          >
            <div class="d-inline-block">
              <div
                class="alert alert-warning d-flex align-items-center mb-3"
                role="alert"
              >
                <i class="fas fa-exclamation-triangle me-2"></i>
                <%= t("warnings.unsaved_changes") %>
              </div>

              <%= f.submit t("buttons.save"),
                         class: "btn btn-primary me-2 d-none",
                         data: { exams__registration_settings_target: "submitButton" } %>

              <%= button_tag t("buttons.cancel"),
                           type: "button",
                           class: "btn btn-secondary d-none",
                           data: {
                             exams__registration_settings_target: "cancelButton",
                             action: "click->exams--registration-settings#cancel"
                           } %>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
    <div class="row mb-3">
      <div class="col-md-2">
        <span class="col-form-label">
          <%= t("registration.policy.index.title") %>
        </span>
      </div>

      <div class="col-md-9">
        <%= render "registration/policies/inline_badges",
                   campaign: campaign,
                   frame_id: frame_id,
                   embedded: true %>
      </div>
    </div>
    <%# Allocation workspace container (filled by review-and-finalize) %>
    <% if campaign.closed? || campaign.processing? %>
      <div id="<%= allocation_workspace_id %>"></div>
    <% end %>
    <%# Pre-finalization: registrants list (after registration has been opened) %>
    <% if pre_finalization && !campaign.draft? %>
      <% cap = exam.capacity %>
      <% grouped = campaign.user_registrations_grouped_by_user %>
      <hr class="my-4">
      <% if cap.present? %>
        <div class="text-muted small mb-3">
          <%= t("assessment.registration_tab.capacity_label", capacity: cap) %>
        </div>
      <% end %>
      <% if grouped.any? %>
        <div data-controller="exams--registration-list">
          <input
            type="text"
            class="form-control form-control-sm mb-3"
            placeholder="<%= t("assessment.registration_tab.filter_placeholder") %>"
            autocomplete="off"
            data-action="input->exams--registration-list#filter"
          >

          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th><%= t("basics.name") %></th>
                  <th><%= t("basics.email") %></th>
                  <th class="text-end"><%= t("basics.actions") %></th>
                </tr>
              </thead>

              <tbody>
                <% grouped.each do |user, _registrations| %>
                  <tr
                    data-exams--registration-list-target="entry"
                    data-student-search="<%= "#{user.name} #{user.email}".downcase %>"
                  >
                    <td><%= user.tutorial_name.presence || user.email %></td>
                    <td class="text-muted"><%= user.email %></td>

                    <td class="text-end">
                      <%= button_to destroy_for_user_registration_campaign_registrations_path(
                                      campaign, user_id: user.id,
                                      source: "registrations"),
                                    method: :delete,
                                    class: "btn btn-sm btn-outline-danger",
                                    form: {
                                      class: "d-inline-block mb-0",
                                      data: {
                                        turbo_confirm: t("basics.confirm")
                                      }
                                    } do %>
                        <i class="bi bi-trash"></i>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <div
            class="small text-muted mt-2 text-center d-none"
            data-exams--registration-list-target="noResults"
          >
            <%= t("assessment.registration_tab.no_filter_results") %>
          </div>
        </div>
      <% end %>
      <%# Post-finalization: roster + rejected list %>
    <% elsif !pre_finalization %>
      <hr class="my-4">
      <%= render "exams/participants_table",
                 entries: exam.exam_rosters.includes(:user)
                              .joins(:user).merge(User.order(:name)),
                 editable: true,
                 exam: exam %>
      <% rejected = campaign.user_registrations.where(status: :rejected) %>
      <% if rejected.any? %>
        <h6 class="text-muted fw-semibold small text-uppercase mt-4 mb-2">
          <i class="bi bi-person-slash me-1"></i>
          <%= t("assessment.registration_tab.rejected_heading") %>
          <span class="badge bg-secondary ms-1"><%= rejected.count %></span>
        </h6>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th><%= t("basics.name") %></th>
                <th><%= t("basics.email") %></th>
              </tr>
            </thead>

            <tbody>
              <% rejected.includes(:user).each do |reg| %>
                <tr>
                  <td><%= reg.user.name %></td>
                  <td class="text-muted"><%= reg.user.email %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
