<% campaign = exam.registration_campaign %>
<% frame_id = "exam_#{exam.id}_registration" %>
<% bp = { frame_id: frame_id } %>

<div id="<%= frame_id %>">
  <% if exam.skip_campaigns %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle me-2"></i>
      <%= t("assessment.registration_tab.skip_campaigns_info") %>
    </div>
  <% elsif campaign.nil? %>
    <div class="alert alert-warning">
      <i class="bi bi-exclamation-triangle me-2"></i>
      <%= t("assessment.registration_tab.no_campaign") %>
    </div>
  <% else %>
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div class="d-flex align-items-center gap-2">
        <span class="badge bg-<%= campaign_badge_color(campaign) %> fs-6">
          <%= t("registration.campaign.status.#{campaign.status}") %>
        </span>

        <% if campaign.registration_deadline %>
          <span class="text-muted small">
            <i class="bi bi-calendar-range me-1"></i>
            <%= t("registration.campaign.deadline_label") %>:
            <%= l(campaign.registration_deadline, format: :long) %>
          </span>
        <% end %>
      </div>

      <div class="d-flex gap-2">
        <% if campaign.draft? %>
          <%= open_campaign_button(campaign, params: bp) %>
        <% elsif campaign.open? %>
          <%= close_campaign_button(campaign, params: bp) %>
        <% elsif campaign.closed? %>
          <%= reopen_campaign_button(campaign, params: bp) %>
          <%= link_to t("registration.campaign.actions.review_and_finalize"),
                      registration_campaign_allocation_path(campaign),
                      class: "btn btn-primary" %>
        <% elsif campaign.processing? %>
          <%= link_to t("registration.campaign.actions.review_and_finalize"),
                      registration_campaign_allocation_path(campaign),
                      class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
    <% unless campaign.draft? %>
      <% count = campaign.total_registrations_count %>
      <% cap = exam.capacity %>
      <div class="mb-3" data-controller="exams--registration-list">
        <div class="d-flex align-items-baseline gap-2 mb-3">
          <span class="fs-4 fw-bold">
            <%= t("assessment.registration_tab.registered_count",
                  count: count) %>
          </span>

          <span class="text-muted">&middot;</span>

          <span class="text-muted">
            <%= t("assessment.registration_tab.capacity_label",
                  capacity: cap.present? ? cap : t("assessment.registration_tab.unlimited_capacity")) %>
          </span>
        </div>

        <% grouped = campaign.user_registrations_grouped_by_user %>

        <% if grouped.any? %>
          <input
            type="text"
            class="form-control form-control-sm mb-3"
            placeholder="<%= t("assessment.registration_tab.filter_placeholder") %>"
            autocomplete="off"
            data-action="input->exams--registration-list#filter"
          >
          <div class="d-grid gap-2">
            <% grouped.each do |user, registrations| %>
              <div
                class="exam-registration-entry card rounded-3"
                data-exams--registration-list-target="entry"
                data-student-search="<%= "#{user.name} #{user.email}".downcase %>"
              >
                <div class="card-body border-0 py-2 px-3 d-flex gap-2">
                  <div>
                    <div class="fw-semibold">
                      <%= user.tutorial_name.presence || user.email %>
                    </div>

                    <div class="text-muted small">
                      <i class="bi bi-envelope me-1"></i>
                      <%= user.email %>
                    </div>
                  </div>

                  <% unless campaign.completed? %>
                    <%= button_to destroy_for_user_registration_campaign_registrations_path(
                                    campaign, user_id: user.id,
                                    source: "registrations"),
                                  method: :delete,
                                  class: "btn btn-sm btn-outline-danger " \
                                         "exam-registration-remove",
                                  form: {
                                    class: "mb-0",
                                    data: {
                                      turbo_confirm: t("basics.confirm")
                                    }
                                  } do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
          <div
            class="small text-muted mt-2 d-none"
            data-exams--registration-list-target="noResults"
          >
            <%= t("assessment.registration_tab.no_filter_results") %>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <hr class="my-4">

  <h5 class="mb-3">
    <%= t("assessment.registration_tab.participants_heading") %>
  </h5>

  <%= render ExamParticipantsComponent.new(exam: exam) %>
</div>
