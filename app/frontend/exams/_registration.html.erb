<%= vite_stylesheet_tag "registration/allocations/allocation.css" %>

<% campaign = exam.registration_campaign %>
<% frame_id = "exam_#{exam.id}_registration" %>
<% bp = { frame_id: frame_id } %>

<% allocation_workspace_id =
     Registration::Campaign.exam_workspace_frame_id(exam) %>

<% phase = exam.status_phase %>

<% pre_finalization =
     %i[draft registration_open registration_closed].include?(phase) %>

<div id="<%= frame_id %>">
  <% if exam.skip_campaigns %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle me-2"></i>
      <%= t("assessment.registration_tab.skip_campaigns_info") %>
    </div>
    <%= render "exams/participants_table",
               entries: exam.exam_rosters.includes(:user)
                            .joins(:user).merge(User.order(:name)),
               editable: true,
               exam: exam %>
  <% elsif campaign.nil? %>
    <div class="alert alert-warning">
      <i class="bi bi-exclamation-triangle me-2"></i>
      <%= t("assessment.registration_tab.no_campaign") %>
    </div>
  <% else %>
    <%= render "exams/registration_header",
               exam: exam,
               campaign: campaign,
               bp: bp,
               allocation_workspace_id: allocation_workspace_id %>
    <% unless campaign.completed? %>
      <%= render "exams/registration_deadline_form", exam: exam %>
    <% end %>
    <div class="row mb-3">
      <div class="col-md-2">
        <span class="col-form-label">
          <%= t("registration.policy.index.title") %>
        </span>
      </div>

      <div class="col-md-9">
        <%= render "registration/policies/inline_badges",
                   campaign: campaign,
                   frame_id: frame_id,
                   embedded: true %>
      </div>
    </div>
    <% if campaign.closed? || campaign.processing? %>
      <div id="<%= allocation_workspace_id %>"></div>
    <% end %>
    <% if campaign.open? %>
      <%= render "exams/registrants_table",
                 exam: exam,
                 campaign: campaign %>
    <% elsif !pre_finalization %>
      <%= render "exams/registration_post_finalization",
                 exam: exam,
                 campaign: campaign %>
    <% end %>
  <% end %>
</div>
