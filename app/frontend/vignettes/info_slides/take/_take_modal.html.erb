<div
  id="vignette-info-slide-modal-<%= index %>"
  class="modal fade vignette-info-slide-modal"
  aria-hidden="true"
  aria-labelledby="Submit feedback"
  data-info-slide-id="<%= info_slide.id %>"
  role="dialog"
  tabindex="-1"
>
  <div class="modal-dialog modal-lg">
    <div class="modal-content p-4">
      <%= render partial: 'vignettes/info_slides/take/take_modal_content',
      locals: { info_slide: info_slide } %>
    </div>
  </div>
</div>
