<%= turbo_frame_tag "performance-rules-frame" do %>
  <div class="card">
    <div class="card-header bg-white border-bottom">
      <h4 class="mb-1"><%= t("student_performance.rules.show.title") %></h4>

      <p class="text-muted small mb-0">
        <%= t("student_performance.rules.show.subtitle") %>
      </p>
    </div>

    <div class="card-body">
      <% if @rule.nil? %>
        <div class="text-center text-muted py-4">
          <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
          <p><%= t("student_performance.rules.show.no_rule") %></p>
        </div>
      <% else %>
        <div class="mb-4">
          <h5 class="fw-semibold">
            <%= t("student_performance.rules.show.point_threshold") %>
          </h5>

          <% if @rule.min_percentage.present? %>
            <p class="fs-5 mb-0">
              <span class="badge bg-primary">
                <%= number_to_percentage(@rule.min_percentage, precision: 0) %>
              </span>

              <%= t("student_performance.rules.show.of_total_points") %>
            </p>
          <% elsif @rule.min_points_absolute.present? %>
            <p class="fs-5 mb-0">
              <span class="badge bg-primary">
                <%= @rule.min_points_absolute %>
              </span>

              <%= t("student_performance.rules.show.points_absolute") %>
            </p>
          <% else %>
            <p class="text-muted">
              <%= t("student_performance.rules.show.no_point_threshold") %>
            </p>
          <% end %>
        </div>
        <% if @rule.required_achievements.any? %>
          <div class="mb-4">
            <h5 class="fw-semibold">
              <%= t("student_performance.rules.show.required_achievements") %>
            </h5>

            <div class="list-group">
              <% @rule.rule_achievements.includes(:achievement).order(:position).each do |ra| %>
                <div
                  class="
                    list-group-item d-flex justify-content-between
                    align-items-center
                  "
                >
                  <div>
                    <strong><%= ra.achievement.title %></strong>

                    <% if ra.achievement.description.present? %>
                      <br>
                      <small class="text-muted">
                        <%= ra.achievement.description %>
                      </small>
                    <% end %>
                  </div>

                  <div>
                    <% case ra.achievement.value_type %>
                    <% when "boolean" %>
                      <span class="badge bg-secondary">
                        <%= t("student_performance.rules.show.value_types.boolean") %>
                      </span>
                    <% when "numeric" %>
                      <span class="badge bg-secondary">
                        <%= t("student_performance.rules.show.value_types.numeric",
                              threshold: ra.achievement.threshold) %>
                      </span>
                    <% when "percentage" %>
                      <span class="badge bg-secondary">
                        <%= t("student_performance.rules.show.value_types.percentage",
                              threshold: ra.achievement.threshold) %>
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
        <div class="alert alert-info mb-0">
          <i class="bi bi-info-circle me-1"></i>
          <%= t("student_performance.rules.show.edit_hint") %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
