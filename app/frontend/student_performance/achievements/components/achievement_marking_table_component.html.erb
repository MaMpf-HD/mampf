<% if any_participations? %>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <small class="text-muted">
      <%= marked_count %> / <%= participations.size %>
      <%= t("assessment.achievements.marking.marked") %> &middot;
      <%= met_count %> <%= t("assessment.achievements.marking.met_label") %>
    </small>
  </div>
  <table class="table table-hover">
    <thead>
      <tr>
        <th><%= t("basics.name") %></th>

        <th class="text-center">
          <%= t("assessment.achievements.marking.value") %>
        </th>

        <th class="text-center">
          <%= t("assessment.achievements.marking.status") %>
        </th>
      </tr>
    </thead>

    <tbody>
      <% participations.each do |participation| %>
        <% badge = status_badge(participation) %>

        <tr>
          <td><%= participation.user.tutorial_name %></td>

          <td class="text-center"><%= value_display(participation) %></td>

          <td class="text-center">
            <% case badge %>
            <% when :met %>
              <i
                class="bi bi-check-circle-fill text-success"
                title="<%= t("assessment.achievements.marking.met") %>"
              ></i>
            <% when :not_met %>
              <i
                class="bi bi-x-circle text-danger"
                title="<%= t("assessment.achievements.marking.not_met") %>"
              ></i>
            <% when :unmarked %>
              <i
                class="bi bi-dash-circle text-muted"
                title="<%= t("assessment.achievements.marking.unmarked") %>"
              ></i>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="text-center text-muted py-3">
    <i class="bi bi-people me-1"></i>
    <%= t("assessment.achievements.marking.no_participations") %>
  </div>
<% end %>
