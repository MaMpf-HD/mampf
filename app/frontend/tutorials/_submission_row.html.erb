<!-- Column 1: User names + copy emails + late icon -->
<td class="sticky-col team-col">
  <%= submission.users.map(&:tutorial_name).join(', ') %>

  <i class="clipboardpopup far fa-copy clickable
            text-secondary clipboard-btn ms-3 clipboard-button"
      data-clipboard-text="<%= submission.users.map(&:email).join(', ') %>"
      data-bs-toggle="tooltip"
      data-id="<%= submission.id %>"
      title="<%= t('buttons.copy_email_to_clipboard') %>">
    <span class="clipboardpopuptext token-clipboard-popup"
          data-id="<%= submission.id %>">
      <%= t('basics.emails_copied_to_clipboard') %>
    </span>
  </i>

  <% if submission.too_late? %>
    <i class="fas fa-exclamation-triangle"
        data-bs-toggle="tooltip"
        title="<%= late_submission_info(submission, submission.tutorial) %>">
    </i>
  <% end %>
</td>


<% if gradding_enabled?(assignment) %>
  <!-- batch of columns 2: grade zone -->
  <!-- support point by task -->
  <% for assignment_task in assignment.assessment.tasks %>
    <td class="sticky-col task-col">
      <input type="number"
            autocomplete="off"
            name="task_points[<%= assignment_task.id %>]"
            value="<%= extract_task_points(submission, assignment_task) %>"
            step="0.5"
            min="0"
            max="<%= assignment_task.max_points %>"
            data-submission-row-target="input"
            data-task-id="<%= assignment_task.id %>"
            data-action="change->submission-row#markDirty input->submission-row#markDirty"
            class="form-control">
    </td>
  <% end %>

  <!-- Column 3: Total Points -->
  <td class="text-center sticky-col total-col">
    <span data-submission-row-target="totalPoints">0</span>
  </td>

  <!-- Column 4: Status -->
  <td class="text-center sticky-col status-col">
    <% if submission&.participations %>
      <% status = submission&.participations.first&.status %>
      <span class="badge bg-<%= badge_status_participation_color(status) %>">
        <%= status %>
      </span>
    <% end %>
  </td>
<% end %>


<!-- Column 5: Actions buttons -->
<td class="text-center sticky-col action-col" data-id="<%= submission.id %>">
  <div class="d-inline-flex align-items-center flex-nowrap gap-1">
  <!-- Download-->
  <%= link_to show_submission_manuscript_path(submission, params: { download: 'true' }),
              class: "btn btn-sm btn-outline-primary d-inline-flex align-items-center justify-content-center text-nowrap px-2 py-1 lh-1",
              data: { bs_toggle: "tooltip", turbo: false },
              title: t('buttons.download') do %>
    <span class="material-icons fs-6 lh-1">download</span>
  <% end %>
  <!-- Show -->
  <% unless submission.assignment.accepted_file_type.in?(Assignment.non_inline_file_types) %>
    <%= link_to show_submission_manuscript_path(submission),
                class: "btn btn-sm btn-outline-secondary d-inline-flex align-items-center justify-content-center text-nowrap px-2 py-1 lh-1",
                data: { bs_toggle: "tooltip", turbo: false },
                title: t('buttons.show') do %>
      <span class="material-icons fs-6 lh-1">visibility</span>
    <% end %>
  <% end %>

  <!--Save and refresh -->
  <% if current_user.in?(submission.tutorial.tutors) && gradding_enabled?(assignment) %>
    <!-- Hidden form for this row to submit-->
    <%= form_with url: point_submission_tutorial_path(submission, type: "Tutorial"),
                  method: :patch,
                  data: { turbo: true, submission_row_target: "form" },
                  html: { style: "display:none;" } do %>
      <input type="hidden" name="task_points" data-submission-row-target="payload">
    <% end %>
    <!-- Save row -->
    <button type="button"
            class="btn btn-sm btn-success d-inline-flex align-items-center justify-content-center text-nowrap px-2 py-1 lh-1"
            data-bs-toggle="tooltip"
            title="<%= t('buttons.save') %>"
            data-action="click->submission-row#saveRow">
      <span class="material-icons fs-6 lh-1">save</span>
    </button>

    <!-- Refresh row -->
    <%= form_with url: refresh_point_submission_tutorial_path(submission, type: "Tutorial"),
                  method: :patch,
                  data: { turbo: true, submission_row_target: "refreshForm" },
                  html: { style: "display:none;" } do %>
      <input type="hidden" name="task_points" data-submission-row-target="payload">
    <% end %>
    <!-- refresh row -->
    <button type="button"
            class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center justify-content-center text-nowrap px-2 py-1 lh-1"
            data-bs-toggle="tooltip"
            title="<%= t('buttons.refresh') %>"
            data-action="click->submission-row#refreshRow">
      <span class="material-icons fs-6 lh-1">refresh</span>
    </button>
  <% end %>

  <!-- accept / reject late submissions -->
  <% if current_user.in?(submission.tutorial.tutors) %>
    <%= render partial: 'submissions/other_actions',
                locals: { submission: submission } %>
  <% end %>
  </div>
</td>

<!-- Column 6: Correction or download partial -->
<td class="sticky-col correction-col"
    data-id="<%= submission.id %>">
  <% if current_user.in?(submission.tutorial.tutors) %>
    <%= render partial: 'submissions/correction_column',
                locals: { submission: submission } %>
  <% else %>
    <%= render partial: 'submissions/download',
                locals: { submission: submission } %>
  <% end %>
</td>
