<%= helpers.turbo_frame_tag "grading-table" do %>
  <%# ── ZONE 1: has grading records ── %>
  <% if grading_records? %>
    <div data-controller="status-filter">
      <% if grading_enabled? %>
        <div class="d-flex gap-2 mb-3">
          <input <%# herb:disable html-no-duplicate-attributes %> <%# herb:disable html-no-duplicate-attributes %>
            type="text"
            class="form-control form-control-sm w-auto"
            placeholder="<%= t('basics.search') %>"
            autocomplete="off"
            data-action="input->status-filter#search"
          >

          <% ["all", "pending"].each do |status| %>
            <button
              class="btn btn-sm <%= status == 'all' ? 'btn-dark' : 'btn-outline-secondary' %>"
              style="width: 4rem"
              data-action="click->status-filter#filter"
              data-status-filter-value="<%= status %>"
            >
              <%= t("assessment.grading_tutorial.filter_options.filter_#{status}") %>
            </button>
          <% end %>
        </div>
      <% end %>

      <div class="table-wrapper" data-controller="table-fade">
        <div class="table-overflow" data-table-fade-target="inner">
          <table
            class="table align-middle my-3"
            data-cy="tutorial-submissions-table"
          >
            <thead style="background: #fafafa;">
              <%= render(PointingTableHeaderComponent.new(
                mode: @mode,
                grading_enabled: grading_enabled?,
                tasks: tasks,
                total_max_points: total_max_points,
                accepted_file_type: @assignment.accepted_file_type
              )) %>
            </thead>

            <tbody>
              <% if @mode == "tutor" %>
                <% @stack.each do |submission| %>
                  <%= render(SubmissionRowComponent.new(
                    submission: submission, 
                    assignment: @assignment, 
                    tutorial: @tutorial)) %>
                <% end %>
                <% @non_submitters.each do |user| %>
                  <% if user.assessment_participation_in_assignment(@assignment) %>
                    <%= render(ParticipationRowComponent.new(
                      participation: user.assessment_participation_in_assignment(@assignment),
                      mode: @mode,
                      assignment: @assignment, 
                      tutorial: @tutorial)) %>
                  <% end %>
                <% end %>
              <% else %>
                <% view_participations.each do |participation| %>
                  <%= render(ParticipationRowComponent.new(
                      participation: participation,
                      mode: @mode,
                      assignment: @assignment, 
                      tutorial: @tutorial)) %>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% else %>
    <div class="jumbotron mt-3">
      <%= t('assessment.grading_tutorial.no_submissions') %>
    </div>
  <% end %>

  <%# ── ZONE 2: on roster, no submission ── %>
  <% if @non_submitters.present? && grading_enabled? %>
    <div
      style="display: flex; align-items: center; gap: 8px; margin: 20px 0 10px; font-size: 13px; font-weight: 500; color: #888;"
    >
      <%= t('assessment.grading_tutorial.no_submission_zone') %>
      <span style="flex: 1; height: 1px; background: #e5e7eb; display: block;"></span>
    </div>
    <div>
      <table class="table align-middle my-3">
        <thead style="background: #fafafa;">
          <tr>
            <th class="grade-th">
              <%= t('basics.user') %>
            </th>

            <th class="text-center grade-th">
              <%= t('basics.status') %>
            </th>

            <th class="text-end grade-th">
              <%= t('assessment.grading_tutorial.actions') %>
            </th>
          </tr>
        </thead>

        <tbody>
          <% @non_submitters.each do |user| %>
            <tr>
              <td class="sticky-col team-col">
                <%= user.tutorial_name %>

                <i
                  class="
                    clipboardpopup bi bi-clipboard clickable
                    text-secondary clipboard-btn ms-3 clipboard-button
                  "
                  data-clipboard-text="<%= user.email %>"
                  data-bs-toggle="tooltip"
                  title="<%= t('buttons.copy_email_to_clipboard') %>"
                >
                  <span class="clipboardpopuptext token-clipboard-popup">
                    <%= t('basics.emails_copied_to_clipboard') %>
                  </span>
                </i>
              </td>

              <td class="text-center sticky-col action-col">
                <span
                  class="badge rounded-pill bg-light text-muted"
                  style="font-size: 11px;"
                >
                  <%= t('assessment.grading_tutorial.no_submission_badge') %>
                </span>
              </td>

              <td class="text-end">
                <% if user.assessment_participation_in_assignment(@assignment) %>
                  <span
                    style="display:inline-flex; align-items:center; gap:4px; padding:4px 10px; border-radius:6px; background:#eef7ee; font-size:12px; color:#2e7d32;"
                  >
                    <span class="material-icons" style="font-size: 14px;">
                      check_circle
                    </span>

                    <%= t('assessment.grading_tutorial.participated') %>
                  </span>
                <% else %>
                  <%= mark_as_participated_link(user) %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
