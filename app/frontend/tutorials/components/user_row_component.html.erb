<tr id="<%= row_id %>"
    is="turbo-frame"
    data-id="<%= @user.id %>"
    data-controller="submission-row"
    data-user-row-id="<%= @user.id %>"
    data-action="dirty->submission-table#rowDirty clean->submission-table#rowClean">

  <% participation = @user.assessment_participation_in_assignment(@assignment) %>

  <!-- Column 1: User names + copy emails + late icon -->
  <td class="sticky-col team-col">
    <%= @user.tutorial_name %>

    <i class="clipboardpopup far fa-copy clickable
              text-secondary clipboard-btn ms-3 clipboard-button"
        data-clipboard-text="<%= @user.email %>"
        data-bs-toggle="tooltip"
        title="<%= t('buttons.copy_email_to_clipboard') %>">
      <span class="clipboardpopuptext token-clipboard-popup">
        <%= t('basics.emails_copied_to_clipboard') %>
      </span>
    </i>
  </td>


  <% if grading_enabled? %>
    <!-- batch of columns 2: grade zone -->
    <!-- support point by task -->
    <% for assignment_task in @assignment.assessment.tasks %>
      <td class="sticky-col task-col">
        <input type="number"
              autocomplete="off"
              name="task_points[<%= assignment_task.id %>]"
              value="<%= extract_task_points_participation(assignment_task) %>"
              step="0.5"
              min="0"
              max="<%= assignment_task.max_points %>"
              data-submission-row-target="input"
              data-task-id="<%= assignment_task.id %>"
              data-action="change->submission-row#markDirtyUser input->submission-row#markDirtyUser"
              class="form-control">
      </td>
    <% end %>

    <!-- Column 3: Total Points -->
    <td class="text-center sticky-col total-col">
      <span data-submission-row-target="totalPoints">0</span>
    </td>

    <!-- Column 4: Status -->
    <td class="text-center sticky-col status-col">
      <% if @participation %>
        <% status = @participation.status %>
        <span class="badge rounded-pill bg-<%= badge_status_participation_color(status) %>"
          style="font-size: 11px; font-weight: 500; letter-spacing: 0.02em; padding: 4px 10px;">
          <%= status %>
        </span>
      <% end %>
    </td>
  <% end %>


  <!-- Column 5: Actions buttons -->
  <td class="text-center sticky-col action-col">
    <div class="d-inline-flex align-items-center flex-nowrap gap-1">

    <!--Save and refresh -->
    <% if helpers.current_user.in?(tutorial.tutors) && grading_enabled? && @participation %>
      <!-- Hidden form for this row to submit-->
      <%= form_with url: point_user_tutorial_path(@participation, type: "Tutorial"),
                    method: :patch,
                    data: { turbo: true, submission_row_target: "form" },
                    html: { style: "display:none;" } do %>
        <input type="hidden" name="task_points" data-submission-row-target="payload">
      <% end %>
      <!-- Save row -->
      <button type="button"
              class="btn btn-sm btn-success d-inline-flex align-items-center justify-content-center text-nowrap px-2 py-1 lh-1"
              data-bs-toggle="tooltip"
              title="<%= t('buttons.save') %>"
              data-action="click->submission-row#saveRow">
        <span class="material-icons fs-6 lh-1">save</span>
      </button>

      <!-- Refresh row -->
      <%= form_with url: refresh_point_user_tutorial_path(@participation, type: "Tutorial"),
                    method: :patch,
                    data: { turbo: true, submission_row_target: "refreshForm" },
                    html: { style: "display:none;" } do %>
        <input type="hidden" name="task_points" data-submission-row-target="payload">
      <% end %>
      <!-- refresh row -->
      <button type="button"
              class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center justify-content-center text-nowrap px-2 py-1 lh-1"
              data-bs-toggle="tooltip"
              title="<%= t('buttons.refresh') %>"
              data-action="click->submission-row#refreshRow">
        <span class="material-icons fs-6 lh-1">refresh</span>
      </button>
      <!--TODO-->
    <% end %>

    </div>
  </td>

</tr>
