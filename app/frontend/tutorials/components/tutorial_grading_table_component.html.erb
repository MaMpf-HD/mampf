<%= helpers.turbo_frame_tag "grading-table" do %>
  <%# ── ZONE 1: has grading records ── %>
  <% if grading_records? %>
    <div class="table-wrapper" data-controller="table-fade">
      <div class="table-overflow" data-table-fade-target="inner">
        <table
          class="table table-striped align-middle my-3"
          data-cy="tutorial-submissions-table"
        > <%# herb:disable html-no-duplicate-attributes %>
          <thead style="background: #fafafa;">
            <tr>
              <th class="sticky-col team-col grade-th">
                <%= t('basics.team') %>
              </th>

              <% if grading_enabled? %>
                <!-- support point by task -->
                <% for assessment_task in tasks %>
                  <th class="text-center sticky-col task-col grade-th">
                    <%= t('assessment.grading_tutorial.task') %> <%= assessment_task.position %>
                    <br>

                    <small class="text-muted">
                      (<%= assessment_task.max_points || 0 %>
                      <%= t('assessment.grading_tutorial.max_points') %>)
                    </small>
                  </th>
                <% end %>
                <th class="text-center sticky-col total-col grade-th">
                  <%= t('assessment.grading_tutorial.total_points') %>
                  <br>

                  <small class="text-muted">
                    (<%= total_max_points %>
                    <%= t('assessment.grading_tutorial.max_points') %>)
                  </small>
                </th>
                <th class="text-center sticky-col status-col grade-th">
                  <%= t('assessment.grading_tutorial.status') %>
                </th>
              <% end %>

              <th class="text-center sticky-col action-col grade-th">
                <%= t('assessment.grading_tutorial.actions') %>
              </th>

              <th class="text-center sticky-col correction-col grade-th">
                <%= t('basics.correction') %>

                <small class="text-muted">
                  (<%= @assignment.accepted_file_type %>)
                </small>
              </th>
            </tr>
          </thead>

          <tbody>
            <% @stack.each do |submission| %>
              <%= render(SubmissionRowComponent.new(submission: submission, assignment: @assignment, tutorial: @tutorial)) %>
            <% end %>

            <% @non_submitters.each do |user| %>
              <% if user.assessment_participation_in_assignment(@assignment) %>
                <%= render(ParticipationRowComponent.new(user: user, assignment: @assignment, tutorial: @tutorial)) %>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="jumbotron mt-3">
      <%= t('assessment.grading_tutorial.no_submissions') %>
    </div>
  <% end %>

  <%# ── ZONE 2: on roster, no submission ── %>
  <% if @non_submitters.present? && grading_enabled? %>
    <div
      style="display: flex; align-items: center; gap: 8px; margin: 20px 0 10px; font-size: 13px; font-weight: 500; color: #888;"
    >
      <%= t('assessment.grading_tutorial.no_submission_zone') %>
      <span style="flex: 1; height: 1px; background: #e5e7eb; display: block;"></span>
    </div>
    <div>
      <table class="table table-striped align-middle my-3">
        <thead style="background: #fafafa;">
          <tr>
            <th class="grade-th">
              <%= t('basics.user') %>
            </th>

            <th class="text-center grade-th">
              <%= t('basics.status') %>
            </th>

            <th class="text-end grade-th">
              <%= t('assessment.grading_tutorial.actions') %>
            </th>
          </tr>
        </thead>

        <tbody>
          <% @non_submitters.each do |user| %>
            <tr>
              <td class="sticky-col team-col">
                <%= user.tutorial_name %>

                <i
                  class="
                    clipboardpopup bi bi-clipboard clickable
                    text-secondary clipboard-btn ms-3 clipboard-button
                  "
                  data-clipboard-text="<%= user.email %>"
                  data-bs-toggle="tooltip"
                  title="<%= t('buttons.copy_email_to_clipboard') %>"
                > <%# herb:disable html-no-duplicate-attributes %>
                  <span class="clipboardpopuptext token-clipboard-popup">
                    <%= t('basics.emails_copied_to_clipboard') %>
                  </span>
                </i>
              </td>

              <td class="text-center sticky-col action-col">
                <span
                  class="badge rounded-pill bg-light text-muted"
                  style="font-size: 11px;"
                >
                  <%= t('assessment.grading_tutorial.no_submission_badge') %>
                </span>
              </td>

              <td class="text-end">
                <% if user.assessment_participation_in_assignment(@assignment) %>
                  <%= t('assessment.grading_tutorial.participated') %>
                <% else %>
                  <%= link_to mark_user_as_participated_path(
                    user_id: user.id,
                    tutorial_id: @tutorial.id,
                    assignment_id: @assignment.id
                  ),
                  style: "display:inline-flex; align-items:center; gap:4px; padding:4px 10px; border-radius:6px; border:1px solid #e0e0e0; background:#fff; font-size:12px; color:#555; text-decoration:none;",
                  data: { turbo_method: :patch, confirm: t('assessment.grading_tutorial.confirm_unsaved_changes') } do %>
                    <span class="material-icons" style="font-size: 14px;">
                      check
                    </span>

                    <%= t('assessment.grading_tutorial.mark_as_participated') %>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
