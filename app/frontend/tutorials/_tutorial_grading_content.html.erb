<%# ── ZONE 1: has submission ── %>
<% if stack.any? %>
  <div class="table-overflow">
    <table
      class="table table-striped align-middle my-3"
      data-cy="tutorial-submissions-table"
    >
      <thead class="bg-light">
        <tr>
          <th class="sticky-col team-col">
            <%= t('basics.team') %>
          </th>

          <% if gradding_enabled?(assignment) %>
            <!-- support point by task -->
            <% for assessment_task in assignment.assessment.tasks %>
              <th class="text-center sticky-col task-col">
                <%= t('assessment.grading_tutorial.task') %> <%= assessment_task.position %>
                <br>

                <small class="text-muted">
                  (<%= assessment_task.max_points || 0 %>
                  <%= t('assessment.grading_tutorial.max_points') %>)
                </small>
              </th>
            <% end %>
            <th class="text-center sticky-col total-col">
              <%= t('assessment.grading_tutorial.total_points') %>
              <br>

              <small class="text-muted">
                (<%= assignment.assessment.tasks.map(&:max_points).compact.sum %>
                <%= t('assessment.grading_tutorial.max_points') %>)
              </small>
            </th>
            <th class="text-center sticky-col status-col">
              <%= t('assessment.grading_tutorial.status') %>
            </th>
          <% end %>

          <th class="text-center sticky-col action-col">
            <%= t('assessment.grading_tutorial.actions') %>
          </th>

          <th class="text-center sticky-col correction-col">
            <%= t('basics.correction') %>

            <small class="text-muted">
              (<%= assignment.accepted_file_type %>)
            </small>
          </th>
        </tr>
      </thead>

      <tbody>
        <% stack.each do |submission| %>
          <%= render partial: "tutorials/rows_single",
                   locals: { submission: submission, assignment: assignment, tutorial: tutorial } %>
        <% end %>
        <% non_submitters.each do |user| %>
          <%= render partial: "tutorials/rows_single_user",
                   locals: { user: user, assignment: assignment, tutorial: tutorial } %>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="jumbotron mt-3">
    <%= t('tutorial.no_submissions_for_assignment') %>
  </div>
<% end %>

<%# ── ZONE 2: on roster, no submission ── %>
<% if non_submitters.present? %>
  <h5 class="mt-4 mb-3">
    <%= t('tutorial.no_submissions') %>
  </h5>
  <div>
    <table
      class="table table-striped align-middle my-3"
      data-cy="tutorial-non-submissions-table"
    >
      <thead class="bg-light">
        <tr>
          <th class="sticky-col team-col">
            <%= t('basics.user') %>
          </th>

          <th class="text-center sticky-col action-col">
            <%= t('basics.status') %>
          </th>

          <th>
            Actions
          </th>
        </tr>
      </thead>

      <tbody>
        <% non_submitters.each do |user| %>
          <tr>
            <td class="sticky-col team-col">
              <%= link_to user.tutorial_name, user_path(user) %>
            </td>

            <td class="text-center sticky-col action-col">
              <span class="badge bg-warning">
                <%= t('tutorial.no_submission') %>
              </span>
            </td>

            <td>
              <%= link_to "Mark as participated",
                      mark_user_as_participated_path(
                        user_id: user.id,
                        tutorial_id: tutorial.id,
                        assignment_id: assignment.id
                      ),
                      method: :patch %>

            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
