<%= vite_javascript_tag "js/datetimepicker" %>

<%= form_with model: assignment,
              url: assignments_path,
              method: :post,
              local: true do |f| %>
  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :title, t("basics.title"), class: "form-label" %>

      <%= f.text_field :title,
                       class: "form-control",
                       required: true %>
    </div>

    <div class="col-md-6">
      <%= f.label :deadline, t("basics.deadline"), class: "form-label" %>

      <div
        class="input-group flex-nowrap align-items-start td-picker"
        id="assignment-deadline-picker"
        data-controller="datetimepicker"
        data-td-target-input="nearest"
        data-td-target-toggle="nearest"
      >
        <div class="flex-grow-1">
          <%= f.text_field :deadline,
                           class: "form-control td-input",
                           data: { td_target: "#assignment-deadline-picker" },
                           value: assignment.deadline&.strftime("%Y-%m-%d %H:%M"),
                           autocomplete: "off" %>
        </div>

        <span
          class="input-group-text td-picker-button"
          role="button"
          data-td-target="#assignment-deadline-picker"
          data-td-toggle="datetimepicker"
        >
          <i class="bi bi-calendar-fill"></i>
        </span>
      </div>

      <div
        class="invalid-feedback td-error"
        id="assignment-deadline-error"
        data-td-invalid-date="<%= t("datetimepicker.invalid_date") %>"
      ></div>
    </div>

    <div class="col-md-6">
      <%= f.label :medium_id, t("medium.singular"), class: "form-label" %>

      <%= f.select :medium_id,
                   options_for_select(Medium.where(teachable: lecture, sort: "Exercise")
                                    .map { |m| [m.local_title_for_viewers, m.id] },
                                    assignment.medium_id),
                   { include_blank: t("basics.select") },
                   { class: "form-select selectize" } %>
    </div>

    <div class="col-md-6">
      <%= f.label :accepted_file_type, t("submission.file_format"), class: "form-label" %>

      <%= f.select :accepted_file_type,
                   options_for_select(Assignment.accepted_file_types.map { |t| [t, t] },
                                      assignment.accepted_file_type),
                   {},
                   { class: "form-select" } %>
    </div>

    <div class="col-12">
      <div class="form-check">
        <%= f.check_box :requires_submission,
                        class: "form-check-input",
                        checked: assignment.requires_submission.nil? ? true : assignment.requires_submission %>

        <%= f.label :requires_submission, t("assessment.requires_submission"), class: "form-check-label" %>

        <div class="form-text text-muted">
          <%= t("assessment.requires_submission_hint") %>
        </div>
      </div>
    </div>

    <div class="col-12 mt-4 d-flex justify-content-between">
      <div>
        <%= f.submit t("assessment.form.submit"), class: "btn btn-primary me-2" %>

        <%= link_to t("buttons.cancel"),
                    assessment_assessments_path(lecture_id: lecture.id),
                    class: "btn btn-secondary",
                    data: { turbo_stream: true } %>
      </div>
    </div>
  </div>

  <%= f.hidden_field :lecture_id, value: lecture.id %>
<% end %>
