<div class="mb-3">
  <%= link_to assessment_assessments_path(lecture_id: lecture.id),
              class: "btn btn-sm btn-outline-secondary",
              role: "button",
              data: { turbo_stream: true } do %>
    <i class="bi bi-arrow-left"></i> <%= t("back") %>
  <% end %>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3><%= assessable.title %></h3>
</div>

<% tab ||= "settings" %>
<% pointable = assessable.is_a?(Assessment::Pointable) %>
<% gradable = assessable.is_a?(Assessment::Gradable) %>
<% has_submissions = pointable && assessment.requires_submission %>
<ul class="nav nav-tabs mb-3" id="assessmentTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link <%= 'active' if tab == 'settings' %>"
            id="settings-tab"
            data-bs-toggle="tab"
            data-bs-target="#settings"
            type="button"
            role="tab"
            aria-controls="settings"
            aria-selected="<%= tab == 'settings' %>">
      <%= t("basics.settings") %>
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link <%= 'active' if tab == 'tasks' %>"
            id="tasks-tab"
            data-bs-toggle="tab"
            data-bs-target="#tasks"
            type="button"
            role="tab"
            aria-controls="tasks"
            aria-selected="<%= tab == 'tasks' %>">
      <%= t("assessment.tasks") %>
    </button>
  </li>
  <% if has_submissions %>
    <li class="nav-item" role="presentation">
      <button class="nav-link <%= 'active' if tab == 'submissions' %>"
              id="submissions-tab"
              data-bs-toggle="tab"
              data-bs-target="#submissions"
              type="button"
              role="tab"
              aria-controls="submissions"
              aria-selected="<%= tab == 'submissions' %>">
        <%= t("assessment.submissions") %>
      </button>
    </li>
  <% end %>
  <% if pointable %>
    <li class="nav-item" role="presentation">
      <button class="nav-link <%= 'active' if tab == 'points' %>"
              id="points-tab"
              data-bs-toggle="tab"
              data-bs-target="#points"
              type="button"
              role="tab"
              aria-controls="points"
              aria-selected="<%= tab == 'points' %>">
        <%= t("assessment.points") %>
      </button>
    </li>
  <% end %>
  <% if gradable %>
    <li class="nav-item" role="presentation">
      <button class="nav-link <%= 'active' if tab == 'grades' %>"
              id="grades-tab"
              data-bs-toggle="tab"
              data-bs-target="#grades"
              type="button"
              role="tab"
              aria-controls="grades"
              aria-selected="<%= tab == 'grades' %>">
        <%= t("assessment.grades") %>
      </button>
    </li>
  <% end %>
  <li class="nav-item" role="presentation">
    <button class="nav-link <%= 'active' if tab == 'statistics' %>"
            id="statistics-tab"
            data-bs-toggle="tab"
            data-bs-target="#statistics"
            type="button"
            role="tab"
            aria-controls="statistics"
            aria-selected="<%= tab == 'statistics' %>">
      <%= t("assessment.statistics") %>
    </button>
  </li>
</ul>

<div class="tab-content" id="assessmentTabsContent">
  <div class="tab-pane fade <%= 'show active' if tab == 'settings' %>" id="settings" role="tabpanel" aria-labelledby="settings-tab">
    <%= render 'assessment/assessments/settings',
               assessment: assessment,
               assessable: assessable,
               lecture: lecture %>
  </div>

  <div class="tab-pane fade <%= 'show active' if tab == 'tasks' %>" id="tasks" role="tabpanel" aria-labelledby="tasks-tab">
    <%= render 'assessment/assessments/tasks',
               assessment: assessment,
               assessable: assessable,
               tasks: tasks,
               task: local_assigns[:task] %>
  </div>

  <% if has_submissions %>
    <div class="tab-pane fade <%= 'show active' if tab == 'submissions' %>" id="submissions" role="tabpanel" aria-labelledby="submissions-tab">
      <%= render GradingOverviewComponent.new(assessment: assessment, lecture: lecture) %>
    </div>
  <% end %>

  <% if pointable %>
    <div class="tab-pane fade <%= 'show active' if tab == 'points' %>" id="points" role="tabpanel" aria-labelledby="points-tab">
      <div class="alert alert-secondary">
        <i class="bi bi-grid-3x3"></i>
        <%= t("assessment.points_grid_placeholder") %>
      </div>
    </div>
  <% end %>

  <% if gradable %>
    <div class="tab-pane fade <%= 'show active' if tab == 'grades' %>" id="grades" role="tabpanel" aria-labelledby="grades-tab">
      <%= render GradeTableComponent.new(assessment: assessment) %>
    </div>
  <% end %>

  <div class="tab-pane fade <%= 'show active' if tab == 'statistics' %>" id="statistics" role="tabpanel" aria-labelledby="statistics-tab">
    <div class="alert alert-secondary">
      <i class="bi bi-graph-up"></i>
      <strong>Statistics Tab</strong> - In the future we will have diagrams and analytics for this assessment here
    </div>
  </div>
</div>
