<% if any_participations? %>
  <table class="table table-hover">
    <thead>
      <tr>
        <th><%= t("basics.name") %></th>
        <% if show_tutorial_column? %>
          <th><%= t("basics.tutorial") %></th>
        <% end %>
        <th class="text-center"><%= t("assessment.grade") %></th>
        <th><%= t("assessment.graded_by") %></th>
        <th><%= t("assessment.graded_at") %></th>
      </tr>
    </thead>
    <tbody>
      <% participations.each do |participation| %>
        <tr>
          <td><%= participation.user.tutorial_name %></td>
          <% if show_tutorial_column? %>
            <td><%= participation.tutorial&.title %></td>
          <% end %>
          <td class="text-center">
            <%= grade_display(participation) || "—" %>
          </td>
          <td class="text-muted small"><%= grader_display(participation) %></td>
          <td class="text-muted small"><%= graded_at_display(participation) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="text-center text-muted py-3">
    <i class="bi bi-mortarboard me-1"></i>
    <%= t("assessment.no_grades_yet") %>
  </div>
<% end %>
