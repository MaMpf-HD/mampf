<% if any_displayed? %>
  <% if common_grader_name.present? && !show_grader_column? %>
    <p class="text-muted small mb-2">
      <i class="bi bi-person-check me-1"></i>

      <%= t("assessment.grade_table.all_graded_by",
            grader: common_grader_name) %>
    </p>
  <% end %>
  <table class="table table-hover table-sm align-middle">
    <thead>
      <tr>
        <th><%= t("basics.name") %></th>

        <% if show_tutorial_column? %>
          <th><%= t("basics.tutorial") %></th>
        <% end %>

        <% if show_points_column? %>
          <th class="text-center" style="width: 1%; white-space: nowrap;">
            <%= t("assessment.points") %>
          </th>
        <% end %>

        <th class="text-center" style="width: 1%; white-space: nowrap;">
          <%= t("assessment.grade") %>
        </th>

        <% if show_grader_column? %>
          <th><%= t("assessment.graded_by") %></th>
        <% end %>

        <% if show_graded_at_column? %>
          <th><%= t("assessment.graded_at") %></th>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% displayed_participations.each do |p| %>
        <tr class="<%= 'table-light text-muted' if row_status(p) == :exempt %>">
          <td>
            <% case row_status(p) %>
            <% when :absent %>
              <i
                class="bi bi-person-x text-danger me-1"
                data-bs-toggle="tooltip"
                title="<%= status_label(p) %>"
              ></i>
            <% when :exempt %>
              <i
                class="bi bi-person-dash text-secondary me-1"
                data-bs-toggle="tooltip"
                title="<%= status_label(p) %>"
              ></i>
            <% end %>

            <%= p.user.tutorial_name %>
          </td>

          <% if show_tutorial_column? %>
            <td><%= p.tutorial&.title %></td>
          <% end %>

          <% if show_points_column? %>
            <td class="text-center">
              <% if row_status(p) == :exempt %>
                <span class="text-muted">&mdash;</span>
              <% else %>
                <%= points_display(p) %>
              <% end %>
            </td>
          <% end %>

          <td class="text-center">
            <% case row_status(p) %>
            <% when :absent %>
              <%= absent_grade_display(p) %>
            <% when :exempt %>
              <span class="text-muted">&mdash;</span>
            <% else %>
              <%= grade_display(p) %>
            <% end %>
          </td>

          <% if show_grader_column? %>
            <td class="text-muted small"><%= grader_display(p) %></td>
          <% end %>

          <% if show_graded_at_column? %>
            <td class="text-muted small">
              <% if graded_at_relative(p) %>
                <span title="<%= graded_at_full(p) %>">
                  <%= graded_at_relative(p) %>
                </span>
              <% end %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="text-center text-muted py-3">
    <i class="bi bi-mortarboard me-1"></i>
    <%= t("assessment.no_grades_yet") %>
  </div>
<% end %>
