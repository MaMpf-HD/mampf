<div id="<%= dom_prefix %>" data-cy="assessment-dashboard">
  <div class="mb-3">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1 class="h3 mb-1"><%= assessable.title %></h1>
        <% if subtitle %>
          <p class="text-muted mb-0"><%= subtitle %></p>
        <% end %>
      </div>
      <div>
        <%= link_to t("back"), back_path,
                    class: "btn btn-sm btn-outline-secondary",
                    data: { turbo_stream: true } %>
      </div>
    </div>
  </div>

  <ul class="nav nav-tabs mb-3" role="tablist">
    <% tabs.each do |tab| %>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= 'active' if tab_active?(tab.key) %>"
                data-bs-toggle="tab"
                data-bs-target="#<%= dom_prefix %>-<%= tab.key %>"
                type="button"
                role="tab"
                aria-selected="<%= tab_active?(tab.key) %>">
          <%= tab.label %>
        </button>
      </li>
    <% end %>
  </ul>

  <div class="tab-content">
    <% tabs.each do |tab| %>
      <div class="tab-pane fade <%= 'show active' if tab_active?(tab.key) %>"
           id="<%= dom_prefix %>-<%= tab.key %>" role="tabpanel">
        <%= render tab.component %>
      </div>
    <% end %>
  </div>
</div>
