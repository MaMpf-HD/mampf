<div id="<%= dom_prefix %>" data-cy="assessment-dashboard">
  <div class="mb-3">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1 class="h3 mb-1"><%= assessable.title %></h1>
        <% if subtitle %>
          <p class="text-muted mb-0"><%= subtitle %></p>
        <% end %>
      </div>
      <div>
        <%= link_to t("back"), back_path,
                    class: "btn btn-sm btn-outline-secondary",
                    data: { turbo_stream: true } %>
      </div>
    </div>
  </div>

  <ul class="nav nav-tabs mb-3" role="tablist">
    <% if show_overview? %>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= 'active' if tab_active?('overview') %>"
                data-bs-toggle="tab"
                data-bs-target="#<%= dom_prefix %>-overview"
                type="button"
                role="tab"
                aria-selected="<%= tab_active?('overview') %>">
          <%= t("assessment.overview") %>
        </button>
      </li>
    <% end %>
    <% if show_settings? %>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= 'active' if tab_active?('settings') %>"
                data-bs-toggle="tab"
                data-bs-target="#<%= dom_prefix %>-settings"
                type="button"
                role="tab"
                aria-selected="<%= tab_active?('settings') %>">
          <%= t("basics.settings") %>
        </button>
      </li>
    <% end %>
    <% if show_tasks? %>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= 'active' if tab_active?('tasks') %>"
                data-bs-toggle="tab"
                data-bs-target="#<%= dom_prefix %>-tasks"
                type="button"
                role="tab"
                aria-selected="<%= tab_active?('tasks') %>">
          <%= t("assessment.tasks") %>
        </button>
      </li>
    <% end %>
    <% if show_submissions? %>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= 'active' if tab_active?('submissions') %>"
                data-bs-toggle="tab"
                data-bs-target="#<%= dom_prefix %>-submissions"
                type="button"
                role="tab"
                aria-selected="<%= tab_active?('submissions') %>">
          <%= t("assessment.submissions") %>
        </button>
      </li>
    <% end %>
    <% if show_points? %>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= 'active' if tab_active?('points') %>"
                data-bs-toggle="tab"
                data-bs-target="#<%= dom_prefix %>-points"
                type="button"
                role="tab"
                aria-selected="<%= tab_active?('points') %>">
          <%= t("assessment.points") %>
        </button>
      </li>
    <% end %>
    <% if show_grades? %>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= 'active' if tab_active?('grades') %>"
                data-bs-toggle="tab"
                data-bs-target="#<%= dom_prefix %>-grades"
                type="button"
                role="tab"
                aria-selected="<%= tab_active?('grades') %>">
          <%= t("assessment.grades") %>
        </button>
      </li>
    <% end %>
    <% if show_roster? %>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= 'active' if tab_active?('roster') %>"
                data-bs-toggle="tab"
                data-bs-target="#<%= dom_prefix %>-roster"
                type="button"
                role="tab"
                aria-selected="<%= tab_active?('roster') %>">
          <%= t("assessment.roster") %>
        </button>
      </li>
    <% end %>
    <% if show_statistics? %>
      <li class="nav-item" role="presentation">
        <button class="nav-link <%= 'active' if tab_active?('statistics') %>"
                data-bs-toggle="tab"
                data-bs-target="#<%= dom_prefix %>-statistics"
                type="button"
                role="tab"
                aria-selected="<%= tab_active?('statistics') %>">
          <%= t("assessment.statistics") %>
        </button>
      </li>
    <% end %>
  </ul>

  <div class="tab-content">
    <% if show_overview? %>
      <div class="tab-pane fade <%= 'show active' if tab_active?('overview') %>"
           id="<%= dom_prefix %>-overview" role="tabpanel">
        <%= render partial: "exams/overview",
                   locals: { exam: assessable, lecture: lecture } %>
      </div>
    <% end %>

    <% if show_settings? %>
      <div class="tab-pane fade <%= 'show active' if tab_active?('settings') %>"
           id="<%= dom_prefix %>-settings" role="tabpanel">
        <% if exam? %>
          <%= render partial: "exams/settings",
                     locals: { exam: assessable, lecture: lecture } %>
        <% else %>
          <%= render "assessment/assessments/settings",
                     assessment: assessment,
                     assessable: assessable,
                     lecture: lecture %>
        <% end %>
      </div>
    <% end %>

    <% if show_tasks? %>
      <div class="tab-pane fade <%= 'show active' if tab_active?('tasks') %>"
           id="<%= dom_prefix %>-tasks" role="tabpanel">
        <% if assessment %>
          <%= render "assessment/assessments/tasks",
                     assessment: assessment,
                     assessable: assessable,
                     tasks: tasks,
                     task: task %>
        <% else %>
          <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <%= t("assessment.errors.no_assessment") %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if show_submissions? %>
      <div class="tab-pane fade <%= 'show active' if tab_active?('submissions') %>"
           id="<%= dom_prefix %>-submissions" role="tabpanel">
        <%= render GradingOverviewComponent.new(
              assessment: assessment, lecture: lecture) %>
      </div>
    <% end %>

    <% if show_points? %>
      <div class="tab-pane fade <%= 'show active' if tab_active?('points') %>"
           id="<%= dom_prefix %>-points" role="tabpanel">
        <div class="alert alert-secondary">
          <i class="bi bi-grid-3x3"></i>
          <%= t("assessment.points_grid_placeholder") %>
        </div>
      </div>
    <% end %>

    <% if show_grades? %>
      <div class="tab-pane fade <%= 'show active' if tab_active?('grades') %>"
           id="<%= dom_prefix %>-grades" role="tabpanel">
        <% if assessment %>
          <%= render GradeTableComponent.new(assessment: assessment) %>
        <% end %>
      </div>
    <% end %>

    <% if show_roster? %>
      <div class="tab-pane fade <%= 'show active' if tab_active?('roster') %>"
           id="<%= dom_prefix %>-roster" role="tabpanel">
        <%= render partial: "exams/roster",
                   locals: { exam: assessable } %>
      </div>
    <% end %>

    <% if show_statistics? %>
      <div class="tab-pane fade <%= 'show active' if tab_active?('statistics') %>"
           id="<%= dom_prefix %>-statistics" role="tabpanel">
        <div class="alert alert-info" role="alert">
          <i class="bi bi-info-circle me-2"></i>
          <strong><%= t("basics.coming_soon") %>:</strong>
          <%= t("assessment.statistics_placeholder") %>
        </div>
      </div>
    <% end %>
  </div>
</div>
