<div data-cy="distribution-analysis">
  <% if empty? %>
    <div class="alert alert-secondary d-flex align-items-center">
      <i class="bi bi-bar-chart-line me-2"></i>
      <%= t("assessment.distribution.no_data") %>
    </div>
  <% else %>
    <h5 class="mb-3"><%= t("assessment.distribution.title") %></h5>
    <div class="card mb-4">
      <div class="card-body">
        <h6 class="card-title mb-3">
          <%= t("assessment.distribution.histogram_title") %>
        </h6>

        <div
          class="d-flex align-items-end gap-1"
          style="height: 200px; padding: 0 10px;"
        >
          <% bins.each do |bin| %>
            <% pct = max_bin_count.positive? ? (bin[:count].to_f / max_bin_count * 100).round : 0 %>

            <div
              class="flex-fill rounded-top"
              style="height: <%= pct %>%;
                        min-height: <%= bin[:count].positive? ? 4 : 0 %>px;
                        background-color: #0d6efd;"
              title="<%= bin[:low] %>–<%= bin[:high] %> <%= t('assessment.distribution.points') %>: <%= bin[:count] %>"
              data-bs-toggle="tooltip"
            ></div>
          <% end %>
        </div>

        <div class="d-flex justify-content-between px-2 mt-1">
          <small class="text-muted">0</small>
          <small class="text-muted"><%= distribution[:max_possible] %></small>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-md-6">
        <div class="card mb-3">
          <div class="card-body">
            <h6 class="mb-3">
              <%= t("assessment.distribution.statistics_title") %>
            </h6>

            <table class="table table-sm mb-0">
              <tbody>
                <% stat_rows.each do |label, value, bold| %>
                  <tr>
                    <th style="width: 60%"><%= label %></th>

                    <td class="text-end">
                      <% if bold %>
                        <strong><%= value %></strong>
                      <% else %>
                        <%= value %>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card mb-3">
          <div class="card-body">
            <h6 class="mb-3">
              <%= t("assessment.distribution.percentiles_title") %>
            </h6>

            <table class="table table-sm mb-0">
              <tbody>
                <% percentile_rows.each do |label, value, bold| %>
                  <tr>
                    <th style="width: 60%"><%= label %></th>

                    <td class="text-end">
                      <% if bold %>
                        <strong><%= value %></strong>
                      <% else %>
                        <%= value %>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
