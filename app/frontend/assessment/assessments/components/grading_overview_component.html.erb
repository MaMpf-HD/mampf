<% if !requires_submission? %>
  <div class="alert alert-info">
    <i class="bi bi-info-circle me-2"></i>
    <%= t("assessment.grading_overview.no_submission_required") %>
  </div>

  <div class="text-center py-4">
    <div class="display-4 text-muted mb-2">
      <i class="bi bi-people"></i>
    </div>
    <h4><%= total_expected %> <%= t("assessment.participants") %></h4>
  </div>
<% else %>
  <div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <span class="fw-medium"><%= t("assessment.grading_overview.submission_progress") %></span>
      <span class="text-muted">
        <%= submitted_count %>/<%= total_expected %>
        (<%= progress_percentage %>%)
      </span>
    </div>
    <div class="progress" style="height: 24px;">
      <div class="progress-bar <%= progress_percentage == 100 ? 'bg-success' : 'bg-primary' %>"
           role="progressbar"
           style="width: <%= progress_percentage %>%"
           aria-valuenow="<%= progress_percentage %>"
           aria-valuemin="0"
           aria-valuemax="100">
      </div>
    </div>
  </div>

  <% if total_expected.zero? %>
    <div class="alert alert-warning">
      <i class="bi bi-exclamation-triangle me-2"></i>
      <%= t("assessment.grading_overview.no_participants_yet") %>
    </div>
  <% elsif has_tutorials? && tutorial_stats.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th><%= t("basics.tutorial") %></th>
          <th class="text-center"><%= t("assessment.grading_overview.submitted") %></th>
          <th class="text-center"><%= t("assessment.grading_overview.missing") %></th>
          <th style="width: 30%;"><%= t("assessment.grading_overview.progress") %></th>
        </tr>
      </thead>
      <tbody>
        <% tutorial_stats.each do |stat| %>
          <tr>
            <td><%= stat.name %></td>
            <td class="text-center"><%= stat.submitted %></td>
            <td class="text-center"><%= stat.missing %></td>
            <td>
              <div class="progress" style="height: 16px;">
                <div class="progress-bar <%= stat.progress_percentage == 100 ? 'bg-success' : 'bg-primary' %>"
                     role="progressbar"
                     style="width: <%= stat.progress_percentage %>%"
                     aria-valuenow="<%= stat.progress_percentage %>"
                     aria-valuemin="0"
                     aria-valuemax="100">
                  <small class="px-1"><%= stat.progress_percentage %>%</small>
                </div>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center text-muted py-3">
      <p><%= t("assessment.grading_overview.no_tutorial_breakdown") %></p>
      <p>
        <strong><%= submitted_count %></strong> <%= t("assessment.grading_overview.submitted").downcase %>,
        <strong><%= missing_count %></strong> <%= t("assessment.grading_overview.missing").downcase %>
      </p>
    </div>
  <% end %>
<% end %>
