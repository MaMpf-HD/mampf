<% if tasks.empty? %>
  <div class="text-center text-muted py-3">
    <i class="bi bi-list-task me-1"></i>
    <%= t("assessment.no_tasks_yet") %>
  </div>
<% elsif any_participations? %>
  <div class="table-responsive">
    <table class="table table-hover table-sm">
      <thead>
        <tr>
          <th><%= t("basics.name") %></th>
          <% if show_tutorial_column? %>
            <th><%= t("basics.tutorial") %></th>
          <% end %>
          <% tasks.each do |task| %>
            <th class="text-center">
              <div><%= task.description %></div>
              <small class="text-muted">
                / <%= max_points_display(task) %>
              </small>
            </th>
          <% end %>
          <th class="text-center">
            <div><%= t("assessment.point_grid.total") %></div>
            <small class="text-muted">
              / <%= max_total_display %>
            </small>
          </th>
        </tr>
      </thead>
      <tbody>
        <% participations.each do |participation| %>
          <tr>
            <td><%= participation.user.tutorial_name %></td>
            <% if show_tutorial_column? %>
              <td><%= participation.tutorial&.title %></td>
            <% end %>
            <% tasks.each do |task| %>
              <td class="text-center"><%= points_display(participation, task) %></td>
            <% end %>
            <td class="text-center fw-bold">
              <%= total_display(participation) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="text-center text-muted py-3">
    <i class="bi bi-grid-3x3 me-1"></i>
    <%= t("assessment.no_points_yet") %>
  </div>
<% end %>
