<% campaign ||= @campaign %>

<%= turbo_frame_tag campaign_policy_form_frame_id(campaign) do %>
  <% if campaign.draft? %>
    <%= link_to new_registration_campaign_policy_path(campaign),
              class: "btn btn-sm btn-outline-primary",
              role: "button", data: { turbo_frame: campaign_policy_form_frame_id(campaign) } do %>
      <i class="bi bi-plus-circle"></i>
      <%= t("registration.policy.index.add") %>
    <% end %>
  <% end %>
<% end %>

<%= render "registration/policies/list", campaign: campaign %>
