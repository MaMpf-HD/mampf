<%= vite_stylesheet_tag "registration/main/index.scss" %>

<!-- campaign list -->
<div class="container-md small-width">
  <% if @rosterized_entries.present? %>
    <div class="student-registration-rosterized-notice mb-4">
      <div class="student-registration-rosterized-shell">
        <div class="student-registration-rosterized-kicker">
          <%= t("registration.user_registration.index.confirmed_cases") %>
        </div>

        <div class="student-registration-rosterized-list">
          <% @rosterized_entries.each do |rosterized_entry| %>
            <article class="student-registration-rosterized-entry">
              <div class="student-registration-rosterized-type">
                <%= rosterized_entry_type(rosterized_entry) %>
              </div>

              <h5 class="student-registration-rosterized-title mb-0">
                <%= rosterized_entry.title %>
              </h5>

              <% if rosterized_entry_description(rosterized_entry).present? %>
                <p class="student-registration-rosterized-description mb-0">
                  <%= rosterized_entry_description(rosterized_entry) %>
                </p>
              <% end %>

              <div class="student-registration-rosterized-meta-list">
                <% rosterized_entry_metadata_rows(rosterized_entry).each do |row| %>
                  <div class="student-registration-rosterized-meta-pill">
                    <i class="bi <%= row[:icon] %>" aria-hidden="true"></i>

                    <div class="student-registration-rosterized-meta-copy">
                      <div class="student-registration-rosterized-meta-label">
                        <%= row[:label] %>
                      </div>

                      <div class="student-registration-rosterized-meta-value">
                        <%= row[:value] %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Direct enrollment -->
  <div class="mb-5">
    <div class="mb-3">
      <h5 class="fw-semibold">
        <%= t("roster.self_enrollment.direct_enrollment.title") %>
      </h5>

      <p class="text-muted small">
        <%= t("roster.self_enrollment.direct_enrollment.description") %>
      </p>
    </div>

    <div class="campaign-list d-flex flex-column gap-4">
      <% if @self_rosterables&.rosterables&.any? %>
        <%= turbo_frame_tag "self_roster_options_zone" do %>
          <%= render partial: 'roster/self_roster/options_zone', 
      locals: { self_rosterables: @self_rosterables } %>
        <% end %>
      <% else %>
        <p>
          <%= t("roster.self_enrollment.direct_enrollment.no_active_self_rosterables") %>
        </p>
      <% end %>
    </div>
  </div>

  <div class="mb-3">
    <h5 class="fw-semibold">
      <%= t("roster.self_enrollment.campaign_enrollment.title") %>
    </h5>
  </div>

  <% visible_campaigns = sorted_student_visible_campaigns(@campaigns_details) %>

  <div class="campaign-list d-flex flex-column gap-4">
    <% if visible_campaigns.any? %>
      <% visible_campaigns.each do |campaign_details| %>
        <%= turbo_frame_tag dom_id(campaign_details.campaign, :main_student_registration_campaign) do %>
          <%= render partial: 'registration/main/campaign_card',
                    locals: {
                      details: campaign_details,
                      campaign: campaign_details.campaign
                    } %>
        <% end %>
      <% end %>
    <% else %>
      <%= t("roster.self_enrollment.campaign_enrollment.no_active_campaign") %>
    <% end %>
  </div>
</div>
