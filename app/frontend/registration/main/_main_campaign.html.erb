<%= turbo_frame_tag "main-student-registration-campaign_test" do %>
  <!-- Breadcrumb navigation -->
  <nav class="mb-2">
    <ol class="breadcrumb mb-0">
      <li class="breadcrumb-item">
        <%= link_to t('registration.user_registration.registrations'), user_registrations_path %>
      </li>
      <li class="breadcrumb-item active" aria-current="page">
        <%= campaignable_host.title %> -
        <%= campaign.description %>
        (<%= campaign.campaignable_type %>)
      </li>
    </ol>
  </nav>

  <!-- Campaign info -->
  <div class="mt-3 mb-4">
    <%= render partial: 'registration/main/campaign_info',
               locals: { campaignable_host: campaignable_host,
                         campaign: campaign } %>
  </div>

  <!-- Closed early banner -->
  <% if closed_early?(campaign) %>
    <div class="alert alert-warning py-2 mt-2 mb-3">
      <%= t("registration.user_registration.closed_before_deadline") %>
    </div>
  <% end %>

  <% if campaign.registration_items.size == 1 && campaign.first_come_first_served? %>

    <div class="row g-4">
      <!-- Eligibility -->
      <div class="col-12 col-lg-4">
        <div class="card h-100" data-test="eligibility-card">
          <%= render partial: 'registration/main/eligibility',
                     locals: { eligibility: eligibility } %>
        </div>
      </div>
      <!-- Selection -->
      <div class="col-12 col-lg-8">
        <div class="card h-100">
          <% if campaign.first_come_first_served? %>
            <%= render partial: 'registration/main/fcfs/select_fcfs',
                       locals: { campaign: campaign,
                                 campaignable_host: campaignable_host,
                                 items: items } %>
          <% else %>
            <%= render partial: 'registration/main/pb/select_preference',
                       locals: { campaign: campaign,
                                 campaignable_host: campaignable_host,
                                 item_preferences: item_preferences,
                                 items: items } %>
          <% end %>
        </div>
      </div>
    </div>
    <!-- Campaign details -->
    <div class="card mt-4">
      <%= render partial: 'registration/main/campaign_details',
                 locals: { campaign: campaign, items: items } %>
    </div>
  <% else %>
    <div class="row g-3">
      <!-- Eligibility -->
      <div class="col-12 col-lg-6">
        <div class="card h-100" data-test="eligibility-card">
          <%= render partial: 'registration/main/eligibility',
                     locals: { eligibility: eligibility } %>
        </div>
      </div>
      <!-- Campaign details -->
      <div class="col-12 col-lg-6">
        <div class="card h-100">
          <%= render partial: 'registration/main/campaign_details',
                     locals: { campaign: campaign, items: items } %>
        </div>
      </div>
    </div>
    <!-- Selection -->
    <div class="card mt-3">
      <% if campaign.first_come_first_served? %>
        <%= render partial: 'registration/main/fcfs/select_fcfs',
                   locals: { campaign: campaign,
                             campaignable_host: campaignable_host,
                             items: items } %>
      <% else %>
        <%= render partial: 'registration/main/pb/select_preference',
                   locals: { campaign: campaign,
                             campaignable_host: campaignable_host,
                             item_preferences: item_preferences,
                             items: items } %>
      <% end %>
    </div>
  <% end %>
<% end %>
