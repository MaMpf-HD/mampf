<div data-test="multi-item-fcfs">
  <div>
    <!-- status row -->
    <div
      class="
        d-flex justify-content-between align-items-center small text-muted
        mb-2 mt-2
      "
    >
      <!-- Registered info -->
      <% if campaign.user_registration_confirmed?(current_user) && campaign.status != "completed" %>
        <div class="fw-normal">
          <%= t("registration.user_registration.currently_registered",
                name: campaign.user_registrations_confirmed(current_user)&.first&.registration_item.title) %>
        </div>
      <% end %>

      <% last_updated = campaign.user_registrations_last_updated(current_user) %>

      <!-- Saved time -->
      <% if last_updated %>
        <div class="text-success fw-semibold">
          <%= t("basics.last_saved_at", time: format_date(last_updated)) %>
        </div>
      <% end %>
    </div>

    <!-- Groups -->
    <div>
      <% items.group_by(&:registerable_type).each do |group, group_items| %>
        <!-- Group title -->
        <div class="row align-items-baseline">
          <div class="fw-bold text-dark mb-2 mt-2 w-auto">
            <%= group %>
          </div>

          <% if !freely_registerable?(group) %>
            <div class="text-muted small w-auto">
              (<%= t("registration.user_registration.not_freely_registerable_info") %>)
            </div>
          <% end %>
        </div>

        <div
          class="
            row row-cols-1 row-cols-md-2 row-cols-xl-3
            student-registration-tile-grid
          "
        >
          <% group_items.each do |item| %>
            <% metadata_rows = item_tile_metadata_rows(item) + [{
                 value: "#{item.item_capacity_used} / #{nullable_capacity_display(item.capacity)}"
               }] %>

            <%= render partial: "registration/main/group_tile",
                       locals: {
                         tile_title: item.registerable.title,
                         tile_type: item_display_type(item),
                         tile_metadata_rows: metadata_rows,
                         tile_variant_class: "tutorial-gtile--campaign",
                         tile_top_bar_class: "tutorial-gtile-top-bar--campaign",
                         tile_status_content: capture do
                           if !item.user_registered?(current_user)
                             if item.still_has_capacity?
                               concat(content_tag(
                                 :span,
                                 t("basics.available"),
                                 class: "badge bg-light-blue-lighten-4 text-dark fw-medium small"
                               ))
                             else
                               concat(content_tag(
                                 :span,
                                 t("basics.full"),
                                 class: "badge bg-grey-lighten-4 text-dark fw-medium small"
                               ))
                             end
                           else
                             concat(content_tag(
                               :span,
                               t("registration.user_registration.registered"),
                               class: "badge text-bg-success fw-medium small"
                             ))
                           end

                           if campaign.status == "completed"
                             concat(confirm_status_badge(
                               results[:status_items_selected][item.id]
                             ))
                           end
                         end,
                         tile_actions_content: capture do
                           if freely_registerable?(item.registerable_type) ||
                              !campaign.user_registration_confirmed_for_group_type?(
                                current_user,
                                item.registerable_type
                              )
                             if item.user_registered?(current_user)
                               concat(button_to(
                                 t("registration.user_registration.withdraw"),
                                 withdraw_item_path(campaign.id, item.id),
                                 method: :delete,
                                 disabled: !campaign.open_for_withdrawals?,
                                 class: "btn btn-outline-danger btn-sm"
                               ))
                             else
                               concat(button_to(
                                 t("registration.user_registration.register_now"),
                                 register_item_path(campaign.id, item.id),
                                 method: :post,
                                 disabled: !campaign.open_for_registrations? ||
                                           !nil_or_positive_integer?(item.remaining_capacity),
                                 class: "btn btn-primary btn-sm"
                               ))
                             end
                           elsif item.user_registered?(current_user)
                             concat(button_to(
                               t("registration.user_registration.withdraw"),
                               withdraw_item_path(campaign.id, item.id),
                               method: :delete,
                               disabled: !campaign.open_for_withdrawals?,
                               class: "btn btn-outline-danger btn-sm"
                             ))
                           else
                             concat(content_tag(
                               :span,
                               t("registration.user_registration.withdraw_first"),
                               class: "text-muted small"
                             ))
                           end
                         end
                       } %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
