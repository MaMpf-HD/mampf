<div>
  <% items_selected = item_preferences.map { |i| i.item.id } %>

  <div class="fw-semibold mt-2 mb-2 text-muted">
    <%= t('registration.user_registration.options_title') %>
  </div>

  <% items.group_by(&:registerable_type).each do |group, group_items| %>
    <div
      class="
        row row-cols-1 row-cols-md-2 row-cols-xl-3
        student-registration-tile-grid
      "
    >
      <% group_items.each do |item| %>
        <% metadata_rows = item_tile_metadata_rows(item) + [{
             value: nullable_capacity_display(item.capacity)
           }] %>

        <%= render partial: "registration/main/group_tile",
                   locals: {
                     tile_title: item.registerable.title,
                     tile_type: item_display_type(item),
                     tile_metadata_rows: metadata_rows,
                     tile_variant_class: "tutorial-gtile--campaign",
                     tile_top_bar_class: "tutorial-gtile-top-bar--campaign",
                     tile_actions_content: capture do
                       concat(content_tag(
                         :button,
                         "playlist_add",
                         type: :submit,
                         name: "add_#{campaign.id}",
                         class: "btn btn-outline-primary btn-sm material-icons clickable border-0 bg-transparent p-0",
                         disabled: items_selected.include?(item.id) ||
                                   items_selected.size >= 3,
                         formaction: add_preference_path(item.id),
                          title: t("buttons.add", default: "Add")
                       ))
                     end
                   } %>
      <% end %>
    </div>
  <% end %>
</div>
