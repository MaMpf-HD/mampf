<div>
  <div
    class="
      row row-cols-1 row-cols-md-2 row-cols-xl-3
      student-registration-tile-grid
    "
  >
    <% sorted_student_registration_items(campaign, items, current_user).each do |item| %>
      <% metadata_rows = item_tile_metadata_rows(item) + [{
           value: item_capacity_row(item)
         }] %>
      <% selected_rank = preference_rank_for(item, item_preferences) %>

      <%= render partial: "registration/main/group_tile",
                 locals: {
                   tile_title: item.registerable.title,
                   tile_type: item_display_type(item),
                   tile_metadata_rows: metadata_rows,
                   tile_variant_class: "tutorial-gtile--campaign",
                   tile_top_bar_class: "tutorial-gtile-top-bar--campaign",
                   tile_status_content: capture do
                     if selected_rank
                       concat(content_tag(
                         :span,
                         class: "badge rounded-pill text-primary border border-primary-subtle px-2 py-1 small student-registration-tile-rank"
                       ) do
                         safe_join([
                           "#{t('registration.user_registration.rank')}: ",
                           content_tag(:span, selected_rank, class: "fw-bold")
                         ])
                       end)
                     end
                   end,
                   tile_actions_content: capture do
                     concat(content_tag(:div, class: "d-flex gap-1") do
                       ranks = 1..Registration::UserRegistration::PreferencesHandler::MAX_PREFERENCES
                       safe_join(ranks.map do |rank|
                         button_to(
                           t("registration.user_registration.preference_rank_options.#{rank}"),
                           add_preference_path(item.id, rank: rank),
                           method: :post,
                           disabled: !campaign.open_for_registrations?,
                           class: class_names(
                             "btn btn-sm student-registration-rank-button",
                             "btn-primary": selected_rank == rank,
                             "btn-outline-primary": selected_rank != rank
                           ),
                           title: preference_rank_button_tooltip(rank),
                           form: { data: { turbo_stream: true } }
                         )
                       end)
                     end)
                   end
                 } %>
    <% end %>
  </div>
</div>
