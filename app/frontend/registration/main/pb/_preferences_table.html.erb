<div>
  <div class="fw-semibold mt-2 mb-2 text-muted">
    <% if campaign.open_for_registrations? %>
      <%= t('registration.user_registration.preferences_title') %>
    <% else %>
      <%= t('registration.user_registration.success_preferences_title') %>
    <% end %>
  </div>

  <div
    class="
      row row-cols-1 row-cols-md-2 row-cols-xl-2
      student-registration-tile-grid
    "
  >
    <% if item_preferences.present? %>
      <% item_preferences.each do |pref| %>
        <% item = pref.item %>

        <% metadata_rows = item_tile_metadata_rows(item) + [{
             value: nullable_capacity_display(item.capacity)
           }] %>

        <%= render partial: "registration/main/group_tile",
                 locals: {
                   tile_title: item.registerable.title,
                   tile_type: item_display_type(item),
                   tile_metadata_rows: metadata_rows,
                   tile_variant_class: "tutorial-gtile--campaign",
                   tile_top_bar_class: "tutorial-gtile-top-bar--campaign",
                   tile_status_content: content_tag(
                     :span,
                     class: "badge rounded-pill text-primary border border-primary-subtle px-2 py-1 small student-registration-tile-rank"
                   ) do
                     safe_join([
                       "#{t('registration.user_registration.rank')}: ",
                       content_tag(:span, pref.rank, class: "fw-bold")
                     ])
                   end,
                   tile_actions_content: capture do
                     concat(content_tag(
                       :button,
                       "arrow_upward",
                       type: :submit,
                       name: "up_#{campaign.id}",
                       title: t("registration.user_registration.actions.increase_priority"),
                       class: "btn btn-outline-secondary btn-sm material-icons clickable border-0 bg-transparent p-0",
                       disabled: pref.rank == 1 || !campaign.open_for_registrations?,
                       formaction: preference_up_path(item.id)
                     ))
                     concat(content_tag(
                       :button,
                       "arrow_downward",
                       type: :submit,
                       name: "down_#{campaign.id}",
                       title: t("registration.user_registration.actions.decrease_priority"),
                       class: "btn btn-outline-secondary btn-sm material-icons clickable border-0 bg-transparent p-0",
                       disabled: pref.rank == item_preferences.size ||
                                 !campaign.open_for_registrations?,
                       formaction: preference_down_path(item.id)
                     ))
                     concat(content_tag(
                       :button,
                       "playlist_remove",
                       type: :submit,
                       name: "remove_#{campaign.id}",
                       title: t("registration.user_registration.actions.remove_option"),
                       class: "btn btn-outline-danger btn-sm material-icons clickable border-0 bg-transparent p-0",
                       disabled: !campaign.open_for_registrations?,
                       formaction: remove_preference_path(item.id)
                     ))
                   end
                 } %>
      <% end %>
    <% else %>
      <%= render partial: 'shared/no_selection' %>
    <% end %>
  </div>

  <!-- Save / Reset -->
  <div class="d-flex justify-content-end gap-3 mt-3">
    <button
      type="submit"
      name="reset_<%= campaign.id %>"
      class="btn btn-outline-primary btn-sm"
      formaction="<%= reset_campaign_preferences_path(campaign.id) %>"
    >
      <%= t('buttons.reset') %>
    </button>

    <button
      type="submit"
      name="save_<%= campaign.id %>"
      class="btn btn-primary btn-sm"
      formaction="<%= save_campaign_preferences_path(campaign.id) %>"
    >
      <%= t('buttons.save') %>
    </button>
  </div>
</div>
