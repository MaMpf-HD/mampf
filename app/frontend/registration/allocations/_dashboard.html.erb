<% campaign = local_assigns[:campaign] || @campaign %>
<% dashboard = local_assigns[:dashboard] || @dashboard || Registration::AllocationDashboard.new(campaign) %>
<% embedded = local_assigns.fetch(:embedded, false) %>
<% allocation_source = embedded ? "allocation_embedded" : "allocation" %>

<div class="<%= embedded ? "" : "container mt-4" %>" id="allocation-dashboard">
  <% if dashboard.policy_violations.present? %>
    <div class="alert alert-danger">
      <i class="bi bi-exclamation-triangle-fill me-1"></i>

      <strong><%= t("registration.allocation.errors.policy_violation_title") %></strong>
      — <%= t("registration.allocation.errors.policy_violation_desc") %>


      <% grouped = dashboard.violations_by_user %>
      <% policy_counts = dashboard.violation_counts_by_policy %>

      <p class="mt-2 mb-2">
        <strong><%= grouped.size %></strong>

        <%= t("registration.allocation.errors.policy_violation_count",
              count: grouped.size) %>

        <small class="text-muted ms-1">
          (
          <% policy_counts.each_with_index do |(kind, count), i| %>
            <%= t("registration.policy.kinds.#{kind}") %>: <%= count %>
            <%= ", " unless i == policy_counts.size - 1 %>
          <% end %>)
        </small>
      </p>

      <%# Policy requirement summaries %>
      <div class="small mb-2">
        <% dashboard.finalization_policies.each do |policy| %>
          <% if policy.kind == "institutional_email" %>
            <div class="mb-1">
              <i class="bi bi-envelope me-1"></i>

              <strong>
                <%= t("registration.policy.kinds.institutional_email") %>:
              </strong>

              <%= t("registration.allocation.policy_summary.required_domain") %>

              <code>@<%= policy.allowed_domains_display %></code>
            </div>
          <% end %>
        <% end %>
      </div>

      <ul class="mt-0 mb-2">
        <% grouped.each do |user_id, violations| %>
          <% first = violations.first %>

          <li class="mb-1">
            <strong><%= first[:name] %></strong> (<%= first[:email] %>)
            <% violations.each do |v| %>
              <span class="badge bg-danger-subtle text-danger ms-1">
                <%= t("registration.policy.kinds.#{v[:policy]}") %>

                <% if v[:policy] == "institutional_email" %>
                  <span class="fw-normal">
                    @<%= email_domain(first[:email]) %>
                  </span>
                <% end %>
              </span>
            <% end %>
            <%= button_to destroy_for_user_registration_campaign_registrations_path(campaign, user_id: user_id, source: allocation_source),
                          method: :delete,
                          class: "btn btn-sm btn-link text-danger p-0 ms-2 align-baseline",
                          data: { confirm: t("basics.confirm") },
                          form: { style: "display:inline-block;" },
                          title: t("registration.user_registration.actions.remove_user") do %>
              <i class="bi bi-trash"></i>
            <% end %>
          </li>
        <% end %>
      </ul>

      <%= button_to t("registration.campaign.actions.force_finalize"),
                    finalize_registration_campaign_allocation_path(campaign, force: true),
                    method: :patch,
                    data: { confirm: t("registration.campaign.confirmations.force_finalize") },
                    class: "btn btn-sm btn-danger" %>
    </div>
  <% end %>

  <% if dashboard.conflicting_registrations.present? %>
    <div class="alert alert-warning">
      <i class="bi bi-exclamation-circle-fill me-1"></i>
      <strong><%= t("registration.allocation.conflicts.title") %></strong> —
      <%= t("registration.allocation.conflicts.desc") %>


      <ul class="mt-2 mb-0">
        <% dashboard.conflicting_registrations.each do |conflict| %>
          <li class="mb-1">
            <strong><%= conflict[:user].name %></strong>
            (<%= conflict[:user].email %>) —
            <%= t("registration.allocation.conflicts.currently_in", tutorial: conflict[:tutorial].title) %>
            <% if conflict[:registration] %>
              <%= button_to destroy_for_user_registration_campaign_registrations_path(campaign, user_id: conflict[:user].id, source: allocation_source),
                            method: :delete,
                            class: "btn btn-sm btn-link text-danger p-0 ms-2 align-baseline",
                            data: { confirm: t("basics.confirm") },
                            form: { style: "display:inline-block;" },
                            title: t("registration.user_registration.actions.remove_user") do %>
                <i class="bi bi-trash"></i>
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% unless embedded %>
    <div class="mb-3">
      <%= link_to registration_campaign_path(campaign),
                class: "btn btn-sm btn-outline-secondary",
                role: "button",
                data: { turbo_stream: true } do %>
        <i class="bi bi-arrow-left"></i>
        <%= t("back") %>
      <% end %>
    </div>
  <% end %>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <span class="fw-medium">
        <%= dashboard.stats.total_registrations %>
        <%= t("registration.allocation.stats.total_registrations") %>
      </span>

      <span class="mx-1 text-muted">·</span>

      <span class="text-success fw-medium">
        <%= dashboard.stats.assigned_users %>
        <%= t("registration.allocation.stats.assigned").downcase %>
        (<%= number_to_percentage(dashboard.stats.assigned_percentage, precision: 0) %>)
      </span>

      <span class="mx-1 text-muted">·</span>

      <span class="<%= dashboard.stats.unassigned_users > 0 ? 'text-danger' : 'text-muted' %> fw-medium">
        <%= dashboard.stats.unassigned_users %>
        <%= t("registration.allocation.stats.unassigned").downcase %>
      </span>
    </div>

    <% if campaign.last_allocation_calculated_at %>
      <small class="text-muted">
        <%= t("registration.allocation.dashboard.last_updated",
              time: l(campaign.last_allocation_calculated_at, format: :short)) %>
      </small>
    <% end %>
  </div>

  <small class="text-muted d-block mb-4">
    <i class="bi bi-info-circle me-1"></i>

    <% if campaign.first_come_first_served? %>
      <%= t("registration.allocation.dashboard.workflow_info_fcfs") %>
    <% else %>
      <%= t("registration.allocation.dashboard.workflow_info") %>
    <% end %>
  </small>

  <% unless campaign.first_come_first_served? %>
    <h6 class="text-muted fw-semibold small text-uppercase mb-2">
      <%= t("registration.allocation.stats.happiness_distribution") %>
    </h6>
    <div class="table-responsive mb-4">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th><%= t("registration.allocation.stats.rank") %></th>

            <th class="text-end">
              <%= t("registration.allocation.stats.count") %>
            </th>

            <th style="width: 40%">
              <%= t("registration.allocation.stats.percentage") %>
            </th>
          </tr>
        </thead>

        <tbody>
          <% sorted_preference_counts(dashboard.stats).each do |rank, count| %>
            <% percentage = dashboard.stats.percentage_of_assigned(count) %>

            <tr>
              <td><%= rank_label(rank) %></td>
              <td class="text-end"><%= count %></td>

              <td>
                <div class="d-flex align-items-center">
                  <div class="flex-grow-1">
                    <%= progress_bar(count, dashboard.stats.assigned_users,
                                     classification: rank_color(rank),
                                     height: "10px",
                                     show_label: false,
                                     container_class: "progress") %>
                  </div>

                  <div class="ms-2 text-end" style="width: 3.5rem;">
                    <%= number_to_percentage(percentage, precision: 0) %>
                  </div>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <h6 class="text-muted fw-semibold small text-uppercase mb-2">
    <%= t("registration.allocation.dashboard.item_capacities") %>
  </h6>

  <div class="table-responsive mb-4">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th><%= t("basics.title") %></th>

          <th class="text-end">
            <%= t("registration.allocation.stats.count") %> /
            <%= t("registration.allocation.stats.capacity") %>
          </th>

          <th style="width: 40%">
            <%= t("registration.allocation.stats.utilization") %>
          </th>
        </tr>
      </thead>

      <tbody>
        <% dashboard.stats.item_stats.each do |data| %>
          <% percentage = data[:percentage] || 0 %>
          <% item = data[:item] %>
          <% registerable = item.registerable %>

          <tr
            class="allocation-item-row"
            data-tutorial-roster-panel-target="tile"
            data-action="click->tutorial-roster-panel#openFromTile"
            data-roster-key="<%= "#{registerable.class.name}-#{registerable.id}" %>"
            data-roster-panel-path="<%= roster_registration_campaign_item_path(campaign, item, source: :panel, format: :turbo_stream) %>"
            data-roster-type="<%= registerable.class.name.underscore %>"
            data-roster-id="<%= registerable.id %>"
            data-roster-title="<%= registerable.title %>"
          >
            <td><%= item.title %></td>

            <td class="text-end">
              <span><%= data[:count] %> / <%= data[:capacity] || "∞" %></span>

              <% if data[:item].registerable_type == "Tutorial" %>
                <details
                  class="allocation-capacity-editor d-inline-block ms-1"
                  ontoggle="if (this.open) { const input = this.querySelector('input[type=number]'); if (input) { input.focus(); input.select(); } }"
                >
                  <summary class="btn btn-sm btn-link text-secondary p-0 align-baseline">
                    <i class="bi bi-pencil"></i>
                  </summary>

                  <%= form_with url: registration_campaign_item_path(campaign, data[:item]),
                                method: :patch,
                                scope: :registration_item,
                                class: "d-inline-flex align-items-center gap-1 ms-1" do |f| %>
                    <%= hidden_field_tag :source, allocation_source %>

                    <%= f.number_field :capacity,
                                       value: data[:capacity],
                                       class: "form-control form-control-sm",
                                       style: "width: 4.5rem;" %>

                    <button
                      type="submit"
                      class="btn btn-sm btn-outline-primary p-1"
                    >
                      <i class="bi bi-check-lg"></i>
                    </button>

                    <button
                      type="button"
                      class="btn btn-sm btn-outline-secondary p-1"
                      onclick="this.closest('details').removeAttribute('open')"
                    >
                      <i class="bi bi-x-lg"></i>
                    </button>
                  <% end %>
                </details>
              <% end %>
            </td>

            <td>
              <% if data[:capacity] %>
                <div class="d-flex align-items-center">
                  <div class="flex-grow-1">
                    <%= progress_bar(data[:count], data[:capacity],
                                     classification: :utilization,
                                     height: "10px",
                                     show_label: false,
                                     container_class: "progress") %>
                  </div>

                  <div class="ms-2 text-end" style="width: 3.5rem;">
                    <%= number_to_percentage(percentage, precision: 0) %>
                  </div>
                </div>
              <% else %>
                <span class="text-muted">—</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <h6 class="text-muted fw-semibold small text-uppercase mb-2">
    <%= t("registration.allocation.dashboard.unassigned_students") %>

    <% if dashboard.unassigned_students.any? %>
      <span class="badge bg-danger ms-1">
        <%= dashboard.unassigned_students.size %>
      </span>
    <% end %>
  </h6>

  <% if dashboard.unassigned_students.any? %>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th><%= t("basics.display_name") %></th>
            <th><%= t("basics.email") %></th>
          </tr>
        </thead>

        <tbody>
          <% dashboard.unassigned_students.each do |student| %>
            <tr>
              <td><%= student.tutorial_name %></td>
              <td class="text-muted"><%= student.email %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="py-3 text-center text-muted">
      <i class="bi bi-check-circle d-block mb-1" style="font-size: 1.5rem;"></i>
      <small><%= t("registration.allocation.dashboard.no_unassigned") %></small>
    </div>
  <% end %>
</div>
