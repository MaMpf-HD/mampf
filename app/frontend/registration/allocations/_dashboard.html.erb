<% embedded = local_assigns.fetch(:embedded, false) %>
<% allocation_source = embedded ? "allocation_embedded" : "allocation" %>
<% partial_locals = { dashboard: dashboard, campaign: campaign, allocation_source: allocation_source } %>

<div class="<%= embedded ? "" : "container mt-4" %>" id="allocation-dashboard">
  <% unless campaign.completed? %>
    <%= render "registration/allocations/finalization_status",
               dashboard: dashboard,
               campaign: campaign %>
  <% end %>

  <%= render "registration/allocations/policy_violations_alert", **partial_locals %>
  <%= render "registration/allocations/conflicting_registrations_alert", **partial_locals %>

  <% unless embedded %>
    <div class="mb-3">
      <%= link_to registration_campaign_path(campaign),
                class: "btn btn-sm btn-outline-secondary",
                role: "button",
                data: { turbo_stream: true } do %>
        <i class="bi bi-arrow-left"></i>
        <%= t("back") %>
      <% end %>
    </div>
  <% end %>

  <h6 class="text-muted fw-semibold small text-uppercase mb-2">
    <%= t(dashboard.current_registration_state? ?
          "registration.allocation.dashboard.current_registration_state" :
          "registration.allocation.dashboard.title") %>
  </h6>

  <%= render "registration/allocations/stats_summary",
             dashboard: dashboard, campaign: campaign %>

  <%= render "registration/allocations/happiness_distribution",
             dashboard: dashboard, campaign: campaign %>

  <%= render "registration/allocations/item_capacities_table",
             **partial_locals %>

  <%= render "registration/allocations/rejected_students",
             dashboard: dashboard %>

  <% if !dashboard.current_registration_state? || dashboard.unassigned_students.any? %>
    <%= render "registration/allocations/unassigned_students",
               dashboard: dashboard %>
  <% end %>
</div>
