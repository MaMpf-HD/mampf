<% dashboard = local_assigns[:dashboard] %>
<% campaign = local_assigns[:campaign] %>
<% allocation_source = local_assigns[:allocation_source] %>

<% blocker_violations = dashboard.blocker_violations %>

<% return unless blocker_violations.present? %>

<% has_configuration_blockers = blocker_violations.any? do |violation|
     violation[:blocker_kind] == Registration::ScreeningService::BLOCKER_KIND_CONFIGURATION
   end %>

<% has_user_blockers = blocker_violations.any? do |violation|
     violation[:blocker_kind] == Registration::ScreeningService::BLOCKER_KIND_USER
   end %>

<div class="alert alert-danger">
  <i class="bi bi-exclamation-triangle-fill me-1"></i>

  <strong><%= t("registration.allocation.errors.policy_violation_title") %></strong>
  — <%= t("registration.allocation.errors.policy_violation_desc") %>


  <% grouped = blocker_violations.group_by { |violation| violation[:user_id] } %>
  <% policy_counts = blocker_violations.group_by { |violation| violation[:policy] }
                                     .transform_values(&:size) %>

  <p class="mt-2 mb-2">
    <strong><%= grouped.size %></strong>

    <%= t("registration.allocation.errors.policy_violation_count",
          count: grouped.size) %>

    <small class="text-muted ms-1">
      (
      <% policy_counts.each_with_index do |(kind, count), i| %>
        <%= t("registration.policy.kinds.#{kind}") %>: <%= count %>
        <%= ", " unless i == policy_counts.size - 1 %>
      <% end %>)
    </small>
  </p>

  <div class="small mb-2">
    <% dashboard.finalization_policies.each do |policy| %>
      <% if policy.kind == "institutional_email" %>
        <div class="mb-1">
          <i class="bi bi-envelope me-1"></i>

          <strong>
            <%= t("registration.policy.kinds.institutional_email") %>:
          </strong>

          <%= t("registration.allocation.policy_summary.required_domain") %>

          <code>@<%= policy.allowed_domains_display %></code>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="small mb-3">
    <% if has_configuration_blockers %>
      <div class="mb-1">
        <strong>
          <%= t("registration.allocation.errors.policy_violation_config_title") %>
        </strong>

        <%= t("registration.allocation.errors.policy_violation_config_desc") %>
      </div>
    <% end %>

    <% if has_user_blockers %>
      <div class="mb-1">
        <strong>
          <%= t("registration.allocation.errors.policy_violation_user_title") %>
        </strong>

        <%= t("registration.allocation.errors.policy_violation_user_desc") %>
      </div>
    <% end %>

    <% if has_user_blockers %>
      <div>
        <strong>
          <%= t("registration.allocation.errors.policy_violation_next_step_title") %>
        </strong>

        <%= t("registration.allocation.errors.policy_violation_next_step_desc") %>
      </div>
    <% end %>
  </div>

  <% perf_lecture = dashboard.performance_lecture %>
  <ul class="mt-0 mb-2 list-unstyled ps-0">
    <% grouped.each do |user_id, violations| %>
      <% first = violations.first %>
      <% ev     = dashboard.performance_evidence_for(user_id) %>
      <% cert   = ev&.dig(:cert) %>
      <% d      = ev&.dig(:eval)&.details || {} %>
      <% has_sp = violations.any? { |v| v[:policy] == "student_performance" } %>

      <li class="d-flex align-items-baseline flex-wrap gap-1 mb-1 small">
        <strong><%= first[:name] %></strong>
        <span class="text-muted">(<%= first[:email] %>)</span>

        <% violations.each do |v| %>
          <span class="badge bg-danger-subtle text-danger">
            <%= t("registration.policy.kinds.#{v[:policy]}") %>

            <% if v[:policy] == "institutional_email" %>
              @
              <%= email_domain(first[:email]) %>
            <% end %>
          </span>
        <% end %>

        <% if has_sp && ev %>
          <% if cert&.failed? %>
            <i
              class="bi bi-patch-x-fill text-danger"
              title="<%= t("student_performance.certifications.status.failed") %>"
            ></i>
          <% elsif cert&.pending? %>
            <i
              class="bi bi-hourglass text-warning"
              title="<%= t("student_performance.certifications.status.pending") %>"
            ></i>
          <% else %>
            <i
              class="bi bi-question-circle text-secondary"
              title="<%= t("registration.allocation.perf_evidence.no_cert") %>"
            ></i>
          <% end %>
          <% if d[:meets_points] == false %>
            <span class="text-danger">
              <% if d[:required_percentage].present? %>
                <%= number_to_percentage(d[:percentage] || 0, precision: 1) %>
                (≥
                <%= number_to_percentage(d[:required_percentage], precision: 1) %>
                )
              <% elsif d[:required_points].present? %>
                <%= d[:points_total] || 0 %>
                /
                <%= d[:points_max] || 0 %>
                <%= t("registration.allocation.perf_evidence.pts_abbr") %>
                (≥
                <%= d[:required_points] %>
                <%= t("registration.allocation.perf_evidence.pts_abbr") %>
                )
              <% end %>
            </span>
          <% end %>
          <% req_ids = Array(d[:achievement_ids_required]) %>
          <% met_ids = Array(d[:achievement_ids_met]) %>
          <% if req_ids.any? && d[:meets_achievements] == false %>
            <span class="text-danger">
              <%= t("registration.allocation.perf_evidence.achievements_short",
                    met: met_ids.size, total: req_ids.size) %>
            </span>
          <% end %>
          <% if cert&.certified_by %>
            <span class="text-muted">
              <%= t("registration.allocation.perf_evidence.certified_by",
                    name: cert.certified_by.name) %>
            </span>
          <% end %>
          <% if cert&.note.present? %>
            <i class="bi bi-chat-text text-muted" title="<%= cert.note %>"></i>
          <% end %>
          <% can_override = cert ? !cert.passed? : ev[:record].present? %>
          <% if perf_lecture && can_override %>
            <% if cert %>
              <%= button_to(
                    lecture_student_performance_certification_path(
                      perf_lecture, cert
                    ),
                    method: :patch,
                    params: {
                      certification: { status: :passed },
                      return_to: registration_campaign_allocation_path(campaign)
                    },
                    class: "btn btn-sm p-0 text-success",
                    title: t("registration.allocation.violations_table.override_pass"),
                    data: {
                      turbo_confirm: t(
                        "registration.allocation.violations_table" \
                        ".confirm_override_pass"
                      )
                    },
                    form: { class: "d-inline-block" }
                  ) do %>
                <i class="bi bi-check-circle-fill"></i>
              <% end %>
            <% else %>
              <%= button_to(
                    lecture_student_performance_certifications_path(perf_lecture),
                    method: :post,
                    params: {
                      certification: { user_id: user_id, status: :passed },
                      return_to: registration_campaign_allocation_path(campaign)
                    },
                    class: "btn btn-sm p-0 text-success",
                    title: t("registration.allocation.violations_table.override_pass"),
                    data: {
                      turbo_confirm: t(
                        "registration.allocation.violations_table" \
                        ".confirm_override_pass"
                      )
                    },
                    form: { class: "d-inline-block" }
                  ) do %>
                <i class="bi bi-check-circle-fill"></i>
              <% end %>
            <% end %>
          <% end %>
        <% end %>

        <% if violations.none? { |violation| violation[:blocker_kind] == Registration::ScreeningService::BLOCKER_KIND_CONFIGURATION } %>
          <%= button_to reject_for_user_registration_campaign_registrations_path(campaign,
                                                                                user_id: user_id,
                                                                                source: allocation_source,
                                                                                reason: Registration::UserRegistration::REJECTION_REASON_CODE_DEFERRED_DUE_TO_BLOCKER),
                        method: :delete,
                        class: "btn btn-sm btn-outline-danger ms-2 align-baseline py-0 px-2",
                        data: {
                          turbo_confirm:
                          t("registration.campaign.confirmations.user_registration_defer_due_to_blocker",
                          email: first[:email])
                        },
                        form: { class: "d-inline-block" },
                        title: t("registration.user_registration.actions.defer_due_to_blocker") do %>
            <i class="bi bi-slash-circle me-1"></i>
            <%= t("registration.user_registration.actions.defer_due_to_blocker") %>
          <% end %>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>
