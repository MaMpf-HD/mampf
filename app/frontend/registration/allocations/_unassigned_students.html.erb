<% dashboard = local_assigns[:dashboard] %>

<h6 class="text-muted fw-semibold small text-uppercase mb-2">
  <%= t("registration.allocation.dashboard.unassigned_students") %>

  <% if dashboard.unassigned_students.any? %>
    <span class="badge bg-danger ms-1">
      <%= dashboard.unassigned_students.size %>
    </span>
  <% end %>
</h6>

<% if dashboard.unassigned_students.any? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th><%= t("basics.display_name") %></th>
          <th><%= t("basics.email") %></th>
        </tr>
      </thead>

      <tbody>
        <% dashboard.unassigned_students.each do |student| %>
          <tr>
            <td><%= student.tutorial_name %></td>
            <td class="text-muted"><%= student.email %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="py-3 text-center text-muted">
    <i class="bi bi-check-circle d-block mb-1 allocation-check-icon"></i>
    <small><%= t("registration.allocation.dashboard.no_unassigned") %></small>
  </div>
<% end %>
