<% dashboard = local_assigns[:dashboard] %>
<% campaign = local_assigns[:campaign] %>
<% allocation_source = local_assigns[:allocation_source] %>

<% return unless dashboard.conflicting_registrations.present? %>

<div class="allocation-status-panel allocation-status-panel--warning">
  <i class="bi bi-exclamation-circle-fill me-1"></i>
  <strong><%= t("registration.allocation.conflicts.title") %></strong> —
  <%= t("registration.allocation.conflicts.desc") %>


  <ul class="mt-2 mb-0">
    <% dashboard.conflicting_registrations.each do |conflict| %>
      <li class="mb-1">
        <strong><%= conflict[:user].name %></strong>
        (<%= conflict[:user].email %>) —
        <%= t("registration.allocation.conflicts.currently_in",
              tutorial: conflict[:registerable].title) %>
        <% if conflict[:registration] %>
          <%= button_to reject_for_user_registration_campaign_registrations_path(campaign,
                                                                                user_id: conflict[:user].id,
                                                                                source: allocation_source,
                                                                                reason: Registration::UserRegistration::REJECTION_REASON_CODE_WITHDRAWN_BY_TEACHER),
                        method: :delete,
                        class: "btn btn-sm btn-link text-danger p-0 ms-2 align-baseline",
                        data: {
                          confirm:
                          t("registration.campaign.confirmations.user_registration_reject_for_user",
                          email: conflict[:user].email)
                        },
                        form: { class: "d-inline-block" },
                        title: t("registration.user_registration.actions.reject_user") do %>
            <i class="bi bi-slash-circle"></i>
          <% end %>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>
