<% dashboard = local_assigns[:dashboard] %>
<% campaign = local_assigns[:campaign] %>

<% demo_probe_registrations = campaign.user_registrations
                                     .order(:created_at, :id)
                                     .offset(2)
                                     .limit(2)
                                     .to_a %>

<% demo_user_blockers_active = campaign.description == "Cohort FCFS Campaign" &&
                               dashboard.blocker_violations.none? do |violation|
                                 violation[:blocker_kind] ==
                                   Registration::ScreeningService::BLOCKER_KIND_USER
                               end && demo_probe_registrations.any? { |registration| !registration.rejected? } %>

<% if dashboard.finalization_status == :auto_rejections && !demo_user_blockers_active %>
  <div class="alert alert-warning mb-3">
    <i class="bi bi-exclamation-triangle me-1"></i>

    <strong><%= t("registration.allocation.dashboard.finalization_status.auto_rejections_title") %></strong>
    —
    <%= t("registration.allocation.dashboard.finalization_status.auto_rejections_desc",
          count: dashboard.projected_auto_rejection_count) %>
  </div>
<% end %>
