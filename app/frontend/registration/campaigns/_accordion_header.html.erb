<% collapse_id = local_assigns[:collapse_id] || campaign_accordion_collapse_id(campaign) %>
<% expanded = local_assigns[:expanded].nil? ? true : local_assigns[:expanded] %>
<% collapsible = local_assigns[:collapsible].nil? ? true : local_assigns[:collapsible] %>

<%= turbo_frame_tag campaign_header_frame_id(campaign) do %>
  <% if collapsible %>
    <button
      type="button"
      class="accordion-button <%= "collapsed" unless expanded %>"
      data-bs-toggle="collapse"
      data-bs-target="#<%= collapse_id %>"
      aria-expanded="<%= expanded %>"
      aria-controls="<%= collapse_id %>"
    >
      <div class="row g-2 align-items-start text-start w-100">
        <div class="col-12 col-md-3">
          <small class="d-block text-muted fw-normal">
            <%= t("registration.campaign.index.columns.description") %>
          </small>

          <div class="fw-semibold">
            <%= campaign.description.presence || "-" %>
          </div>
        </div>

        <div class="col-6 col-md-3">
          <small class="d-block text-muted fw-normal">
            <%= t("registration.campaign.index.columns.mode") %>
          </small>

          <div>
            <%= t("registration.campaign.allocation_mode.#{campaign.allocation_mode}") %>
          </div>
        </div>

        <div class="col-6 col-md-2">
          <small class="d-block text-muted fw-normal">
            <%= t("registration.campaign.index.columns.deadline") %>
          </small>

          <div>
            <%= l(campaign.registration_deadline, format: :short) if campaign.registration_deadline %>
          </div>
        </div>

        <div class="col-6 col-md-2">
          <small class="d-block text-muted fw-normal">
            <%= t("registration.campaign.index.columns.registrations") %>
          </small>

          <div>
            <% if campaign.draft? %>
              <span class="text-muted">&mdash;</span>
            <% else %>
              <%= campaign.total_registrations_count %>
            <% end %>
          </div>
        </div>

        <div class="col-6 col-md-2">
          <small class="d-block text-muted fw-normal">
            <%= t("basics.status") %>
          </small>

          <div>
            <span class="badge bg-<%= campaign_badge_color(campaign) %>">
              <%= t("registration.campaign.status.#{campaign.status}") %>
            </span>
          </div>
        </div>
      </div>
    </button>
  <% else %>
    <div class="p-3 border rounded bg-body-tertiary mb-3">
      <div class="row g-2 align-items-start text-start w-100">
        <div class="col-12 col-md-3">
          <small class="d-block text-muted fw-normal">
            <%= t("registration.campaign.index.columns.description") %>
          </small>

          <div class="fw-semibold">
            <%= campaign.description.presence || "-" %>
          </div>
        </div>

        <div class="col-6 col-md-3">
          <small class="d-block text-muted fw-normal">
            <%= t("registration.campaign.index.columns.mode") %>
          </small>

          <div>
            <%= t("registration.campaign.allocation_mode.#{campaign.allocation_mode}") %>
          </div>
        </div>

        <div class="col-6 col-md-2">
          <small class="d-block text-muted fw-normal">
            <%= t("registration.campaign.index.columns.deadline") %>
          </small>

          <div>
            <%= l(campaign.registration_deadline, format: :short) if campaign.registration_deadline %>
          </div>
        </div>

        <div class="col-6 col-md-2">
          <small class="d-block text-muted fw-normal">
            <%= t("registration.campaign.index.columns.registrations") %>
          </small>

          <div>
            <% if campaign.draft? %>
              <span class="text-muted">&mdash;</span>
            <% else %>
              <%= campaign.total_registrations_count %>
            <% end %>
          </div>
        </div>

        <div class="col-6 col-md-2">
          <small class="d-block text-muted fw-normal">
            <%= t("basics.status") %>
          </small>

          <div>
            <span class="badge bg-<%= campaign_badge_color(campaign) %>">
              <%= t("registration.campaign.status.#{campaign.status}") %>
            </span>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
