<div class="registration-campaign-ghost-zone rounded p-3 mb-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <span class="registration-campaign-ghost-title fw-semibold">
      <%= t("registration.campaign.index.new_campaign") %>

      <span class="registration-campaign-ghost-badge badge bg-secondary ms-1">
        <%= t("registration.campaign.status.draft") %>
      </span>
    </span>

    <%= link_to lecture_registration_campaigns_path(lecture),
                class: "btn btn-sm btn-outline-secondary",
                role: "button",
                data: { turbo_stream: true } do %>
      <i class="bi bi-arrow-left"></i>
      <%= t("back") %>
    <% end %>
  </div>

  <%= render "registration/campaigns/form", campaign: campaign, lecture: lecture %>

  <div class="registration-campaign-ghost-divider mt-3 pt-3">
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-3">
      <div class="col">
        <div class="registration-campaign-ghost-placeholder card h-100">
          <div
            class="
              card-body d-flex flex-column align-items-center
              justify-content-center text-muted py-3
            "
          >
            <i class="bi bi-grid-3x2-gap fs-3 mb-1"></i>

            <small class="text-center">
              <%= t("registration.item.add.tutorial") %>
            </small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
