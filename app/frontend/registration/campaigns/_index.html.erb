<div class="d-flex justify-content-between align-items-center mb-3">
  <h3 class="lecture-pane-header mb-0">
    <%= t("registration.campaign.index.card_title") %>
  </h3>

  <%= link_to t("registration.campaign.index.new_campaign"),
              new_lecture_registration_campaign_path(lecture),
              class: "btn btn-sm btn-primary",
              role: "button",
              data: { turbo_stream: true } %>
</div>

<div id="campaigns_container">
  <%= render "registration/campaigns/card_body_index",
             lecture: lecture,
             new_campaign: local_assigns[:new_campaign],
             expanded_campaign_id: local_assigns[:expanded_campaign_id],
             tab: local_assigns[:tab] %>
</div>
