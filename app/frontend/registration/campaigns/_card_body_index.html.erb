<% if local_assigns[:new_campaign] %>
  <%= render "registration/campaigns/card_body_form",
             campaign: new_campaign,
             lecture: lecture %>
<% elsif lecture.registration_campaigns.any? %>
  <div class="accordion" id="campaigns_accordion">
    <% lecture.registration_campaigns.order(created_at: :desc).each do |campaign| %>
      <% expanded = campaign.id == local_assigns[:expanded_campaign_id] %>
      <% active_tab = expanded ? (local_assigns[:tab] || "items") : "items" %>

      <div
        class="accordion-item"
        id="<%= campaign_accordion_item_id(campaign) %>"
      >
        <h2 class="accordion-header" id="heading-<%= campaign.id %>">
          <%= render "registration/campaigns/accordion_header",
                     campaign: campaign,
                     expanded: expanded,
                     collapse_id: campaign_accordion_collapse_id(campaign) %>
        </h2>

        <div
          id="<%= campaign_accordion_collapse_id(campaign) %>"
          class="accordion-collapse collapse <%= "show" if expanded %>"
          data-bs-parent="#campaigns_accordion"
        >
          <div class="accordion-body">
            <%= render "registration/campaigns/card_body_show",
                       campaign: campaign,
                       tab: active_tab %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-muted"><%= t("registration.campaign.index.none") %></p>
<% end %>
