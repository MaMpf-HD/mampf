<% if local_assigns[:new_campaign] %>
  <%= render "registration/campaigns/card_body_form",
             campaign: new_campaign,
             lecture: lecture %>
<% else %>
  <% campaigns = lecture.registration_campaigns.order(created_at: :desc) %>
  <% no_campaign_groups = no_campaign_registerables(lecture) %>
  <div class="d-flex flex-column gap-2">
    <section>
      <% if campaigns.any? %>
        <div class="d-flex justify-content-end mb-2">
          <%= link_to new_lecture_registration_campaign_path(lecture),
                      class: "btn btn-sm btn-outline-primary",
                      data: { turbo_stream: true } do %>
            <i class="bi bi-plus-circle"></i>
            <%= t("registration.campaign.index.new_campaign") %>
          <% end %>
        </div>
        <% campaigns.each do |campaign| %>
          <% active_tab = campaign.id == local_assigns[:expanded_campaign_id] ?
            (local_assigns[:tab] || "items") : "items" %>

          <div class="card mb-3 campaign-section registration-campaign-card">
            <%= render "registration/campaigns/card_header", campaign: campaign %>

            <div class="card-body">
              <%= render "registration/campaigns/card_body_show",
                         campaign: campaign,
                         tab: active_tab %>
            </div>

            <% if campaign.draft? && campaign.registration_items.any? %>
              <div class="card-footer bg-body">
                <%= button_to open_registration_campaign_path(campaign),
                              method: :patch,
                              form: {
                                data: {
                                  controller: "campaign-action",
                                  "campaign-action-campaign-id-value": campaign.id,
                                  "campaign-action-confirm-message-value":
                                    t("registration.campaign.confirmations.open"),
                                  "campaign-action-warning-message-value":
                                    t("registration.campaign.warnings.unlimited_items"),
                                  action: "submit->campaign-action#confirm",
                                  turbo_stream: true
                                }
                              },
                              class: "btn w-100 registration-campaign-start-btn" do %>
                  <i class="bi bi-play-fill"></i>
                  <%= t("registration.campaign.actions.open") %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="registration-campaign-ghost-zone rounded p-3 mb-3">
          <div class="d-flex align-items-center gap-2 mb-3">
            <span class="registration-campaign-ghost-label text-muted fw-semibold">
              <%= t("registration.campaign.index.sections.registration") %>
            </span>
          </div>

          <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-3">
            <div class="col registration-group-tile-col">
              <%= render "registration/campaigns/add_group_tile",
                         lecture: lecture,
                         section: :campaign %>
            </div>
          </div>
        </div>
      <% end %>
    </section>

    <section>
      <div
        class="
          row row-cols-1 row-cols-md-2 row-cols-xl-4 g-3
          registration-group-grid
        "
      >
        <%= render partial: "registration/campaigns/group_tile",
                   collection: no_campaign_groups,
                   as: :tutorial %>

        <div class="col registration-group-tile-col">
          <%= render "registration/campaigns/add_group_tile",
                     lecture: lecture,
                     section: :no_campaign %>
        </div>
      </div>
    </section>
  </div>
<% end %>
