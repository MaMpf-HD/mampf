<% registerable = local_assigns[:registerable] %>
<% students = local_assigns[:students] || [] %>
<% read_only = local_assigns[:read_only] || false %>
<% is_unassigned = local_assigns[:is_unassigned] || false %>
<% campaign = local_assigns[:campaign] %>
<% is_tutorial = registerable.is_a?(Tutorial) if registerable %>
<% is_cohort = registerable.is_a?(Cohort) if registerable %>
<% is_talk = registerable.is_a?(Talk) if registerable %>

<% tutors_text = if registerable&.respond_to?(:tutor_names)
  registerable.tutor_names.presence || t("basics.tba")
elsif is_talk && registerable.speakers.any?
  registerable.speakers.map(&:tutorial_name).join(", ")
else
  t("basics.tba")
end %>

<% add_member_path = if is_tutorial
  add_member_tutorial_path(registerable, source: :panel)
elsif is_cohort
  add_member_cohort_path(registerable, source: :panel)
elsif is_talk
  add_member_talk_path(registerable, source: :panel)
end %>

<% move_member_path_template = if is_tutorial
  move_member_tutorial_path(registerable, "__USER_ID__")
elsif is_cohort
  move_member_cohort_path(registerable, "__USER_ID__")
elsif is_talk
  move_member_talk_path(registerable, "__USER_ID__")
end %>

<aside
  id="tutorial-roster-side-panel"
  class="card tutorial-roster-side-panel"
  data-tutorial-roster-panel-target="panelCard"
  <% unless read_only %>
    <% if is_unassigned && campaign %>
      data-controller="roster-drag"
      data-roster-drag-source-type-value="unassigned"
      data-roster-drag-source-id-value="<%= campaign.id %>"
      data-roster-drag-move-path-value=""
      data-roster-drag-overbooking-warning-value="<%= t('roster.warnings.confirm_overbooking') %>"
    <% elsif registerable %>
      data-controller="roster-drag"
      data-roster-drag-source-type-value="<%= registerable.class.name.downcase %>"
      data-roster-drag-source-id-value="<%= registerable.id %>"
      data-roster-drag-move-path-value="<%= move_member_path_template %>"
      data-roster-drag-overbooking-warning-value="<%= t('roster.warnings.confirm_overbooking') %>"
    <% end %>
  <% end %>
>
  <div class="p-3 border-bottom d-flex justify-content-between align-items-start gap-2">
    <div>
      <h5 class="mb-1">
        <%= if is_unassigned
          t("roster.candidates.title")
        elsif read_only
          t("registration.user_registration.index.title", default: "Registrations")
        else
          t("roster.details.participants")
        end %>
      </h5>

      <% if is_unassigned && campaign %>
        <div class="text-muted small">
          <span>
            <%= campaign.description.presence || "Campaign ##{campaign.id}" %>
          </span>

          <span class="mx-1">·</span>

          <span>
            <%= "#{students.size} " + t("basics.participants").downcase %>
          </span>
        </div>
      <% elsif registerable %>
        <div class="text-muted small">
          <span><%= registerable.title %></span>
          <span class="mx-1">·</span>
          <span><%= tutors_text %></span>

          <span class="badge text-bg-secondary ms-2">
            <%= "#{students.size} students" %>
          </span>
        </div>
      <% end %>
    </div>

    <button
      type="button"
      class="btn btn-sm btn-outline-secondary tutorial-roster-close-btn"
      data-action="click->tutorial-roster-panel#close"
    >
      <i class="bi bi-x-lg"></i>
    </button>
  </div>

  <div class="card-body border-0">
    <% if registerable || is_unassigned %>
      <% unless read_only || is_unassigned %>
        <div class="mb-3">
          <%= form_with url: add_member_path,
                        method: :post,
                        data: {
                          turbo: true,
                          turbo_confirm: (t("roster.warnings.confirm_overbooking") if registerable.full?)
                        },
                        class: "d-flex flex-column flex-sm-row gap-2" do |f| %>
            <%= f.label :email,
                        t("roster.actions.add_student_label"),
                        class: "visually-hidden" %>

            <%= f.email_field :email,
                              class: "form-control form-control-sm",
                              placeholder: t("roster.actions.add_student_placeholder"),
                              required: true,
                              autocomplete: "on" %>

            <%= f.button type: "submit",
                         class: "btn btn-sm btn-primary text-nowrap" do %>
              <i class="bi bi-plus-lg me-1"></i>
              <%= t("roster.actions.add") %>
            <% end %>
          <% end %>
        </div>
      <% end %>
      <div class="mb-3">
        <label class="visually-hidden" for="tutorial-roster-filter">
          <%= t("roster.actions.search", default: "Filter students") %>
        </label>

        <input
          id="tutorial-roster-filter"
          type="text"
          class="form-control form-control-sm"
          placeholder="Filter by name or email"
          data-action="input->tutorial-roster-panel#filter"
          data-tutorial-roster-panel-target="filterInput"
        >
      </div>
      <div
        class="d-grid gap-2"
        data-tutorial-roster-panel-target="list"
        data-roster-drag-target="studentList"
      >
        <% students.each do |student| %>
          <% student_name = student.name.presence ||
                            student.try(:tutorial_name).presence ||
                            student.email %>

          <div
            class="tutorial-roster-student card rounded-3"
            data-student-search="<%= "#{student_name} #{student.email}".downcase %>"
            data-user-id="<%= student.id %>"
          >
            <div
              class="
                card-body border-0 py-2 px-3 d-flex gap-2 pe-5
                position-relative
              "
            >
              <div>
                <div class="fw-semibold"><%= student_name %></div>

                <div class="text-muted small">
                  <i class="bi bi-envelope me-1"></i>
                  <%= student.email %>
                </div>

                <% if is_unassigned && campaign %>
                  <% relevant_regs = student.user_registrations.select { |r| r.registration_campaign_id == campaign.id } %>
                  <% if relevant_regs.any? %>
                    <div
                      class="small text-truncate mt-1 text-secondary"
                      style="max-width: 250px;"
                    >
                      <% wishes = relevant_regs.sort_by { |r| r.preference_rank || 999 }.map { |r| r.registration_item.registerable.title }.join(", ") %>
                      <%= t('roster.columns.preferences') %>: <%= wishes %>
                    </div>
                  <% end %>
                <% end %>
              </div>

              <% remove_member_path = if is_tutorial
                remove_member_tutorial_path(registerable, student, source: :panel)
              elsif is_cohort
                remove_member_cohort_path(registerable, student, source: :panel)
              end %>

              <% unless read_only || is_unassigned %>
                <%= button_to remove_member_path,
                              method: :delete,
                              class: "btn btn-sm btn-outline-danger " \
                                     "tutorial-roster-student-remove",
                              form: {
                                class: "mb-0 d-flex h-100
                                        position-absolute top-50 end-0 translate-middle-y
                                        ",
                                data: {
                                  turbo_confirm:
                                    t("roster.warnings.confirm_kick_from_group")
                                }
                              } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      <div
        class="small text-muted d-none"
        data-tutorial-roster-panel-target="noResults"
      >
        <%= t("roster.details.empty_filtered") %>
      </div>
    <% else %>
      <div class="tutorial-roster-empty">
        <i class="bi bi-info-circle me-1"></i>

        <%= if read_only
          t("roster.details.select_group",
            default: "Select a group to inspect registrations")
        else
          t("roster.details.select_group",
            default: "Select a group to inspect and manage participants")
        end %>
      </div>
    <% end %>
  </div>

  <% unless read_only || registerable.nil? %>
    <dialog
      class="roster-drag-choice-dialog"
      data-roster-drag-target="choiceDialog"
    >
      <p class="fw-semibold mb-3">
        <%= t("roster.drag.choice_title") %>
        <span data-role="target-name" class="text-primary"></span>
      </p>

      <div class="d-flex gap-2 justify-content-end">
        <button
          type="button"
          class="btn btn-sm btn-outline-secondary"
          data-action="click->roster-drag#cancelChoice"
        >
          <%= t("buttons.cancel") %>
        </button>

        <button
          type="button"
          class="btn btn-sm btn-outline-primary"
          data-action="click->roster-drag#chooseAdd"
        >
          <i class="bi bi-plus-lg me-1"></i>
          <%= t("roster.drag.add_only") %>
        </button>

        <button
          type="button"
          class="btn btn-sm btn-primary"
          data-action="click->roster-drag#chooseMove"
        >
          <i class="bi bi-arrow-right me-1"></i>
          <%= t("roster.drag.move") %>
        </button>
      </div>
    </dialog>
  <% end %>
</aside>
