<% registerable = local_assigns[:tutorial] || local_assigns[:item]&.registerable %>
<% is_tutorial = registerable.is_a?(Tutorial) %>
<% is_cohort = registerable.is_a?(Cohort) %>
<% is_panel_registerable = is_tutorial || is_cohort %>

<% tutors_text = registerable.respond_to?(:tutor_names) ?
   (registerable.tutor_names.presence || t("basics.tba")) : t("basics.tba") %>

<% roster_key = "#{registerable.class.name}-#{registerable.id}" %>

<% roster_panel_path = if is_tutorial
  tutorial_roster_path(registerable, source: :panel, format: :turbo_stream)
elsif is_cohort
  cohort_roster_path(registerable, source: :panel, format: :turbo_stream)
end %>

<% if registerable %>
  <div
    class="col registration-group-tile-col"
    id="<%= dom_id(local_assigns[:item] || registerable) %>"
  >
    <div
      class="card h-100 tutorial-gtile <%= local_assigns[:item] ? "tutorial-gtile--campaign" : "tutorial-gtile--free" %>"
      data-tutorial-roster-panel-target="tile"
      data-action="click->tutorial-roster-panel#openFromTile"
      data-roster-key="<%= roster_key %>"
      data-roster-panel-path="<%= roster_panel_path if is_panel_registerable %>"
    >
      <div class="tutorial-gtile-top-bar <%= local_assigns[:item] ? "tutorial-gtile-top-bar--campaign" : "tutorial-gtile-top-bar--free" %>"></div>

      <div class="card-body d-flex flex-column">
        <div class="tutorial-gtile-type">
          <% if local_assigns[:item] %>
            <%= item_display_type(item) %>
          <% else %>
            <%= t("registration.item.types.tutorial") %>
          <% end %>
        </div>

        <h6
          class="tutorial-gtile-name text-truncate"
          title="<%= registerable.title %>"
        >
          <%= registerable.title %>
        </h6>

        <div class="text-muted mt-2 flex-grow-1">
          <i class="bi bi-person me-1"></i>

          <%= tutors_text %>
        </div>

        <div class="small text-muted">
          <%= registerable.roster_entries.count %> /
          <%= registerable.capacity || "∞" %>
        </div>

        <div
          class="
            tutorial-gtile-actions mt-3 pt-2 border-top d-flex gap-2
            justify-content-end
          "
        >
          <% if is_tutorial %>
            <%= link_to edit_tutorial_path(registerable, group_type: :tutorials),
                      class: "btn btn-sm btn-primary",
                      title: t("roster.tooltips.edit_settings"),
                      data: { turbo_stream: true, bs_toggle: "tooltip" } do %>
              <i class="bi bi-pencil"></i>
            <% end %>
          <% elsif is_cohort %>
            <%= link_to edit_cohort_path(registerable, group_type: :cohorts),
                      class: "btn btn-sm btn-primary",
                      title: t("roster.tooltips.edit_settings"),
                      data: { turbo_stream: true, bs_toggle: "tooltip" } do %>
              <i class="bi bi-pencil"></i>
            <% end %>
          <% end %>

          <% if local_assigns[:item] %>
            <%= link_to registration_campaign_item_path(item.registration_campaign, item),
                      class: "btn btn-sm btn-danger",
                      title: t("registration.item.actions.remove_from_campaign"),
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: t("registration.item.confirm_remove"),
                        bs_toggle: "tooltip"
                      } do %>
              <i class="bi bi-trash"></i>
            <% end %>
          <% elsif is_tutorial %>
            <%= link_to tutorial_path(registerable, group_type: :tutorials),
                      class: "btn btn-sm btn-danger",
                      title: t("roster.tooltips.delete"),
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: t("confirmation.generic"),
                        bs_toggle: "tooltip"
                      } do %>
              <i class="bi bi-trash"></i>
            <% end %>
          <% elsif is_cohort %>
            <%= link_to cohort_path(registerable, group_type: :cohorts),
                      class: "btn btn-sm btn-danger",
                      title: t("roster.tooltips.delete"),
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: t("confirmation.generic"),
                        bs_toggle: "tooltip"
                      } do %>
              <i class="bi bi-trash"></i>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
