<% registerable = local_assigns[:tutorial] || local_assigns[:item]&.registerable %>
<% is_tutorial = registerable.is_a?(Tutorial) %>
<% is_cohort = registerable.is_a?(Cohort) %>
<% is_panel_registerable = is_tutorial || is_cohort %>
<% is_cohort_without_enrollment = is_cohort && !registerable.propagate_to_lecture? %>

<% sm_mode = registerable.try(:self_materialization_mode) || "disabled" %>
<% sm_active = sm_mode != "disabled" %>

<% tutors_text = registerable.respond_to?(:tutor_names) ?
   (registerable.tutor_names.presence || t("basics.tba")) : t("basics.tba") %>

<% type_text = if is_cohort
  t("roster.group_category.flexible_group")
elsif local_assigns[:item]
  item_display_type(item)
else
  t("registration.item.types.tutorial")
end %>

<% roster_key = "#{registerable.class.name}-#{registerable.id}" %>

<% roster_panel_path = if is_tutorial
  tutorial_roster_path(registerable, source: :panel, format: :turbo_stream)
elsif is_cohort
  cohort_roster_path(registerable, source: :panel, format: :turbo_stream)
end %>

<% if local_assigns[:item] && item.registration_campaign.open? %>
  <% roster_panel_path = roster_registration_campaign_item_path(
    item.registration_campaign,
    item,
    source: :panel,
    format: :turbo_stream
  ) %>
<% end %>

<% edit_path = if is_tutorial
  edit_tutorial_path(registerable, group_type: :tutorials)
elsif is_cohort
  edit_cohort_path(registerable, group_type: :cohorts)
end %>

<% delete_path = if local_assigns[:item]
  registration_campaign_item_path(item.registration_campaign, item)
elsif is_tutorial
  tutorial_path(registerable, group_type: :tutorials)
elsif is_cohort
  cohort_path(registerable, group_type: :cohorts)
end %>

<% delete_data = if local_assigns[:item]
  {
    turbo_method: :delete,
    turbo_confirm: t("registration.item.confirm_remove"),
    bs_toggle: "tooltip"
  }
else
  {
    turbo_method: :delete,
    turbo_confirm: t("confirmation.generic"),
    bs_toggle: "tooltip"
  }
end %>

<% delete_title = if local_assigns[:item]
  t("registration.item.actions.remove_from_campaign")
else
  t("roster.tooltips.delete")
end %>

<% if registerable %>
  <div
    class="col registration-group-tile-col"
    id="<%= dom_id(local_assigns[:item] || registerable) %>"
  >
    <% gtile_type_class = if local_assigns[:item]
         "tutorial-gtile--campaign"
       elsif sm_active
         "tutorial-gtile--self-enrollment"
       else
         "tutorial-gtile--free"
       end %>

    <div
      class="card h-100 tutorial-gtile <%= gtile_type_class %> <%= "tutorial-gtile--without-enrollment" if is_cohort_without_enrollment %>"
      data-tutorial-roster-panel-target="tile"
      data-action="click->tutorial-roster-panel#openFromTile"
      data-roster-key="<%= roster_key %>"
      data-roster-panel-path="<%= roster_panel_path if is_panel_registerable %>"
      data-roster-type="<%= registerable.class.name.underscore %>"
      data-roster-id="<%= registerable.id %>"
      data-roster-full="<%= registerable.full? %>"
      data-roster-title="<%= registerable.title %>"
    >
      <% top_bar_class = if local_assigns[:item]
           "tutorial-gtile-top-bar--campaign"
         elsif sm_active
           "tutorial-gtile-top-bar--self-enrollment"
         else
           "tutorial-gtile-top-bar--free"
         end %>

      <div class="tutorial-gtile-top-bar <%= top_bar_class %>"></div>

      <div class="card-body d-flex flex-column position-relative">
        <% if !local_assigns[:item] && registerable.respond_to?(:skip_campaigns) && !registerable.locked? %>
          <div
            class="dropdown position-absolute"
            style="top: 0.5rem; right: 0.5rem;"
          >
            <button
              class="btn btn-sm text-muted p-0 border-0 <%= "text-success" if sm_active %>"
              type="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
              title="<%= t("roster.self_materialization.label", default: "Self-Enrollment") %>"
            >
              <% if sm_mode == "add_only" %>
                <i class="bi bi-box-arrow-in-right"></i>
              <% elsif sm_mode == "remove_only" %>
                <i class="bi bi-box-arrow-right"></i>
              <% elsif sm_mode == "add_and_remove" %>
                <i class="bi bi-arrow-left-right"></i>
              <% else %>
                <i class="bi bi-person-slash"></i>
              <% end %>
            </button>

            <ul
              class="dropdown-menu dropdown-menu-end shadow-sm"
              style="font-size: 0.875rem;"
            >
              <li>
                <h6 class="dropdown-header">
                  <%= t("roster.self_materialization.label", default: "Self-Enrollment") %>
                </h6>
              </li>

              <% registerable.class.self_materialization_modes.keys.each do |mode| %>
                <% update_path = 
                  case registerable
                  when Tutorial then update_self_materialization_tutorial_path(registerable, mode: mode)
                  when Cohort then update_self_materialization_cohort_path(registerable, mode: mode)
                  when Talk then update_self_materialization_talk_path(registerable, mode: mode)
                  end %>

                <% if update_path %>
                  <li>
                    <%= link_to update_path, class: "dropdown-item #{'active' if sm_mode == mode}", data: { turbo_method: :patch } do %>
                      <% if mode == "add_only" %>
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                      <% elsif mode == "remove_only" %>
                        <i class="bi bi-box-arrow-right me-2"></i>
                      <% elsif mode == "add_and_remove" %>
                        <i class="bi bi-arrow-left-right me-2"></i>
                      <% else %>
                        <i class="bi bi-person-slash me-2"></i>
                      <% end %>

                      <%= t(mode, scope: "roster.self_materialization.modes", default: mode.titleize) %>
                    <% end %>
                  </li>
                <% end %>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="tutorial-gtile-type pe-4"><%= type_text %></div>

        <h6
          class="tutorial-gtile-name text-truncate"
          title="<%= registerable.title %>"
        >
          <%= registerable.title %>
        </h6>

        <div class="text-muted mt-2 flex-grow-1">
          <i class="bi bi-person me-1"></i>

          <%= tutors_text %>
        </div>

        <div class="small text-muted">
          <%= registerable.roster_entries.count %> /
          <%= registerable.capacity || "∞" %>
        </div>

        <div
          class="
            tutorial-gtile-actions mt-3 pt-2 border-top d-flex gap-2
            justify-content-end
          "
        >
          <% if edit_path %>
            <%= link_to edit_path,
                      class: "btn btn-sm btn-primary",
                      title: t("roster.tooltips.edit_settings"),
                      data: { turbo_stream: true, bs_toggle: "tooltip" } do %>
              <i class="bi bi-pencil"></i>
            <% end %>
          <% end %>

          <% if delete_path %>
            <%= link_to delete_path,
                      class: "btn btn-sm btn-danger",
                      title: delete_title,
                      data: delete_data do %>
              <i class="bi bi-trash"></i>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
