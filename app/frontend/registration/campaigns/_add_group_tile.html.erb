<% registration_section = section.to_s == "no_campaign" ? "no_campaign" : "campaign" %>
<% campaign = local_assigns[:campaign] %>

<% tutorial_path =
  new_tutorial_path(lecture_id: lecture.id,
                    group_type: :tutorials,
                    registration_section: registration_section,
                    registration_campaign_id: campaign&.id) %>

<% flexible_group_path =
  new_cohort_path(lecture_id: lecture.id,
                  group_type: :cohorts,
                  registration_section: registration_section,
                  registration_campaign_id: campaign&.id,
                  cohort: { propagate_to_lecture: true }) %>

<div class="card h-100 add-group-tile">
  <div class="card-body d-flex flex-column align-items-center justify-content-center">
    <div class="d-grid gap-2 w-100">
      <%= link_to t("registration.item.add.tutorial"),
                  tutorial_path,
                  class: "btn btn-sm btn-outline-primary",
                  data: { turbo_stream: true } %>

      <%= link_to t("registration.item.add.flexible_group"),
                  flexible_group_path,
                  class: "btn btn-sm btn-outline-secondary",
                  data: { turbo_stream: true } %>
    </div>
  </div>
</div>
