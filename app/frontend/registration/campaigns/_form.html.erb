<% cancel_path = campaign.persisted? ?
  registration_campaign_path(campaign) :
  lecture_registration_campaigns_path(lecture) %>

<% cancel_data = { turbo_stream: true } %>
<% picker_id = "registration-deadline-picker-#{campaign.id || "new"}" %>

<%= turbo_frame_tag(campaign.persisted? ? campaign_header_frame_id(campaign) :
                    "new_campaign_form") do %>
  <div class="fs-6 fw-normal <%= campaign.persisted? ? 'p-4 bg-light' : '' %>">
    <%= form_with(model: [lecture, campaign].compact,
                url: campaign.persisted? ? registration_campaign_path(campaign) :
                  lecture_registration_campaigns_path(lecture)) do |f| %>
      <% if campaign.errors[:base].present? %>
        <div class="alert alert-danger">
          <%= campaign.errors[:base].join(", ") %>
        </div>
      <% end %>

      <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
          <%= f.label :description,
                    t("registration.campaign.form.description"),
                    class: "form-label small text-muted mb-1" %>

          <%= helpdesk(t("registration.campaign.helpdesk.description"), false) %>

          <%= f.text_field :description,
                         class: "form-control",
                         disabled: campaign.completed? %>
        </div>

        <div class="col-12 col-md-4">
          <%= f.label :allocation_mode,
                    t("registration.campaign.form.allocation_mode"),
                    class: "form-label small text-muted mb-1" %>

          <% if campaign.draft? %>
            <%= helpdesk(t("registration.campaign.helpdesk.allocation_mode"), false) %>
          <% else %>
            <%= helpdesk(t("registration.campaign.helpdesk.allocation_mode_frozen"), false) %>
          <% end %>

          <%= f.select :allocation_mode,
                     Registration::Campaign.allocation_modes.keys.map { |k| [t("registration.campaign.allocation_mode.#{k}"), k] },
                     {},
                     class: "form-select",
                     disabled: !campaign.draft? %>
        </div>

        <div class="col-12 col-md-4">
          <%= f.label :registration_deadline,
                    t("registration.campaign.form.registration_deadline"),
                    class: "form-label small text-muted mb-1" %>

          <%= helpdesk(t("registration.campaign.helpdesk.registration_deadline"), false) %>

          <div
            class="input-group td-picker"
            id="<%= picker_id %>"
            data-controller="datetimepicker"
            data-td-target-input="nearest"
            data-td-target-toggle="nearest"
          >
            <%= f.text_field :registration_deadline,
                           class: "form-control td-input",
                           data: { td_target: "##{picker_id}" },
                           value: campaign.registration_deadline&.strftime("%Y-%m-%d %H:%M"),
                           autocomplete: "off",
                           disabled: campaign.completed? %>

            <%= tag.span class: "input-group-text td-picker-button",
                        role: "button",
                        data: { td_target: "##{picker_id}",
                                td_toggle: "datetimepicker" },
                        disabled: campaign.completed? || nil do %>
              <i class="bi bi-calendar-fill"></i>
            <% end %>

            <div
              class="invalid-feedback td-error"
              data-td-invalid-date="<%= t('datetimepicker.invalid_date') %>"
            ></div>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit t("registration.campaign.form.submit"), class: "btn btn-primary" %>

        <%= link_to t("buttons.cancel"),
                  cancel_path,
                  class: "btn btn-secondary",
                  role: "button",
                  data: cancel_data %>
      </div>

      <% unless campaign.persisted? %>
        <small class="d-block text-muted mt-2">
          <i class="bi bi-info-circle me-1"></i>
          <%= t("registration.policy.hint.add_after_creation") %>
        </small>
      <% end %>
    <% end %>
  </div>
<% end %>
