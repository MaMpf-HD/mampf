# =============================================================================
# BUILD-TIME DUMMY ENV FILE — NOT USED AT RUNTIME.
#
# None of the values below are real secrets, and none of them reach a running
# production/staging container. The actual runtime configuration is injected by
# the deployment automation, which requires every secret to be set explicitly
# (a deploy aborts otherwise).
#
# This file exists only so that `rails assets:precompile` can fully boot Rails
# during the Docker image build, which needs the env vars present to run the
# initializers. See docker/production/Dockerfile (the ". ./docker-dummy.env"
# step) for the full explanation.
# =============================================================================

# Instance variables
GIT_BRANCH=main
COMPOSE_PROJECT_NAME=mampf
INSTANCE_NAME=mampf

# Specify related websites here
BLOG=https://mampf.blog
MUESLI_SERVER=https://muesli.mathi.uni-heidelberg.de
MUESLI_CAMPAIGN_REGISTRATION_DEFAULT_ALLOWED_DOMAIN=uni-heidelberg.de

# User Cleaner
MAX_DELETIONS_PER_RUN=50

# Email
FROM_ADDRESS=mampf@mathi.uni-heidelberg.de
MAILSERVER=mail.mathi.uni-heidelberg.de
PROJECT_EMAIL=mampf@mathi.uni-heidelberg.de
PROJECT_NOTIFICATION_EMAIL=notificationmail
MAILID_DOMAIN=mathi.uni-heidelberg.de
ERROR_EMAIL=mampf-error@mathi.uni-heidelberg.de
IMAPSERVER=mail.mathi.uni-heidelberg.de
PROJECT_EMAIL_USERNAME=creativeusername
PROJECT_EMAIL_PASSWORD=secretsecret
PROJECT_EMAIL_MAILBOX="Other Users/mampf"
MAMPF_EMAIL_USERNAME=secret
MAMPF_EMAIL_PASSWORD=secret
FEEDBACK_EMAIL=mampf-feedback-mail

# Captcha
CAPTCHA_HMAC_KEY=secure-production-captcha-key

# Upload folder
MEDIA_PATH=/private/media
SUBMISSION_PATH=/private/submissions

# Database configuration
PRODUCTION_DATABASE_ADAPTER=postgresql
PRODUCTION_DATABASE_DATABASE=mampf
PRODUCTION_DATABASE_INTERACTIONS=mampf_interactions
PRODUCTION_DATABASE_HOST=db
PRODUCTION_DATABASE_USERNAME=mampf
PRODUCTION_DATABASE_PASSWORD=supersecret
PRODUCTION_DATABASE_PORT=port
PRODUCTION_DATABASE_URL='postgresql://mampf:supersecret@db:port/mampf'

# Rails configuration
RAILS_ENV=production
# Only needs to be *present* (any value) to satisfy config.require_master_key
# during the build; there is no encrypted credentials file to decrypt here.
RAILS_MASTER_KEY=build-only-dummy
# Overridden in the Dockerfile with `rails secret` for the precompile step, so
# this value is never actually used. The real one is injected at deploy time.
SECRET_KEY_BASE=build-only-dummy-overridden-during-precompile
URL_HOST=mampf.mathi.uni-heidelberg.de
MAMPF_PORT=3000

# Fast caching and indexing need further services
REDIS_URL=redis://redis:6379/0
MEMCACHED_SERVER=cache

# Public HTTP port inside the container that the image healthcheck probes.
APP_HEALTHCHECK_PORT=3000

# Writable cache root prepared by the image for runtime-specific state.
APP_CACHE_ROOT=/caches

# Current app server stack: Thruster serves public assets itself, handles
# X-Sendfile offload, listens publicly on APP_HEALTHCHECK_PORT, proxies Rails
# on THRUSTER_TARGET_PORT, and stores its cache below APP_CACHE_ROOT.
RAILS_SERVE_STATIC_FILES=true
ACTION_DISPATCH_X_SENDFILE_HEADER=X-Sendfile
THRUSTER_HTTP_PORT=3000
THRUSTER_TARGET_PORT=3001
THRUSTER_STORAGE_PATH=/caches/thruster
THRUSTER_GZIP_COMPRESSION_DISABLE_ON_AUTH=true

# Log errors to docker log
RAILS_LOG_TO_STDOUT=true
