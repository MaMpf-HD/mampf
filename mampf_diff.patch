diff --git a/app/services/clamav_scanner.rb b/app/services/clamav_scanner.rb
new file mode 100644
index 000000000..34babf7cd
--- /dev/null
+++ b/app/services/clamav_scanner.rb
@@ -0,0 +1,63 @@
+require "socket"
+require "timeout"
+
+class ClamavScanner
+  CHUNK_SIZE = 1 * 1024 * 1024
+
+  def initialize(host: ENV.fetch("CLAMAV_HOST", "clamav"),
+                 port: ENV.fetch("CLAMAV_PORT", "3310").to_i,
+                 timeout: ENV.fetch("CLAMAV_TIMEOUT", "15").to_i)
+    @host = host
+    @port = port
+    @timeout = timeout
+  end
+
+  def scan(io)
+    return UploadScanResult.clean if Rails.env.test?
+
+    scan_stream(io)
+  rescue Timeout::Error
+    UploadScanResult.timeout
+  rescue SystemCallError, IOError, SocketError => e
+    Rails.logger.warn("[clamav] scanner unavailable: #{e.class}: #{e.message}")
+    UploadScanResult.unavailable(e.message)
+  ensure
+    io.rewind if io.respond_to?(:rewind)
+  end
+
+  private
+
+    def scan_stream(io)
+      reply = Timeout.timeout(@timeout) do
+        Socket.tcp(@host, @port, connect_timeout: @timeout) do |socket|
+          socket.write("zINSTREAM\0")
+
+          io.rewind if io.respond_to?(:rewind)
+          until io.eof?
+            chunk = io.read(CHUNK_SIZE)
+            socket.write([chunk.bytesize].pack("N"))
+            socket.write(chunk)
+          end
+
+          socket.write([0].pack("N"))
+          socket.close_write
+          socket.read
+        end
+      end
+
+      parse_reply(reply.to_s)
+    end
+
+    def parse_reply(reply)
+      response = reply.delete("\0").strip
+
+      return UploadScanResult.clean if response.end_with?(": OK")
+
+      if response.end_with?(" FOUND")
+        signature = response.sub(/\A.*?:\s*/, "").sub(/ FOUND\z/, "")
+        return UploadScanResult.infected(signature)
+      end
+
+      UploadScanResult.unavailable(response.empty? ? nil : response)
+    end
+end
diff --git a/app/services/malware_scan_gate.rb b/app/services/malware_scan_gate.rb
new file mode 100644
index 000000000..188ef699e
--- /dev/null
+++ b/app/services/malware_scan_gate.rb
@@ -0,0 +1,114 @@
+class MalwareScanGate
+  METADATA_KEY = "malware_scan".freeze
+  STATUS_KEY = "status".freeze
+  CLEAN_STATUS = "clean".freeze
+  SCANNER_NAME = "clamav".freeze
+  CONTENT_TYPE_TEXT = "text/plain; charset=utf-8".freeze
+
+  InfectedUploadError = Class.new(StandardError)
+  ScannerUnavailableError = Class.new(StandardError)
+
+  class << self
+    def endpoint_upload(uploader_class, storage_key)
+      lambda do |io, context, request|
+        I18n.with_locale(locale_for(request)) do
+          upload_with_scan(uploader_class, io, storage_key, context: context)
+        rescue InfectedUploadError
+          halt!(422, I18n.t("submission.upload_failure_malware"))
+        rescue ScannerUnavailableError
+          halt!(503, I18n.t("submission.upload_failure_scanner_unavailable"))
+        end
+      end
+    end
+
+    def upload_for_attacher(attacher, io, storage_key, **)
+      upload_with_scan(attacher.shrine_class, io, storage_key,
+                       context: attacher.context, **)
+    end
+
+    def validate_cached_file!(attacher)
+      return unless attacher.file
+      return unless attacher.file.storage_key == attacher.cache_key
+      return if clean_scanned?(attacher.file)
+
+      attacher.errors << I18n.t("submission.upload_failure_scan_required")
+    end
+
+    def ensure_promotable!(uploaded_file)
+      return if clean_scanned?(uploaded_file)
+
+      raise(Shrine::Error, "cached upload is missing clean malware scan metadata")
+    end
+
+    def clean_scanned?(uploaded_file)
+      scan_data = uploaded_file.metadata[METADATA_KEY]
+      scan_data.is_a?(Hash) && scan_data[STATUS_KEY] == CLEAN_STATUS
+    end
+
+    def scanner
+      ClamavScanner.new
+    end
+
+    private
+
+      def upload_with_scan(shrine_class, io, storage_key, context: {}, **options)
+        options = options.dup
+        metadata = options.delete(:metadata)
+        result = scanner.scan(io)
+
+        log_scan_result(result, storage_key)
+
+        unless result.clean?
+          raise(InfectedUploadError, result.signature) if result.infected?
+
+          raise(ScannerUnavailableError, result.detail)
+        end
+
+        io.rewind if io.respond_to?(:rewind)
+
+        shrine_class.upload(io, storage_key, **context, **options,
+                            metadata: merge_metadata(metadata))
+      end
+
+      def merge_metadata(metadata)
+        merged_metadata = metadata.is_a?(Hash) ? metadata.deep_dup : {}
+        merged_metadata[METADATA_KEY] = {
+          STATUS_KEY => CLEAN_STATUS,
+          "scanner" => SCANNER_NAME,
+          "scanned_at" => Time.current.utc.iso8601
+        }
+        merged_metadata
+      end
+
+      def log_scan_result(result, storage_key)
+        case result.status
+        when :clean
+          Rails.logger.info("[clamav] clean storage=#{storage_key}")
+        when :infected
+          Rails.logger.warn(
+            "[clamav] infected storage=#{storage_key} signature=#{result.signature}"
+          )
+        when :timeout
+          Rails.logger.error("[clamav] timeout storage=#{storage_key}")
+        else
+          Rails.logger.error(
+            "[clamav] unavailable storage=#{storage_key} detail=#{result.detail}"
+          )
+        end
+      end
+
+      def locale_for(request)
+        locale = request.params["locale"].presence ||
+                 request.env["warden"]&.user&.locale.presence ||
+                 request.cookies["locale"].presence ||
+                 I18n.default_locale.to_s
+
+        locale = I18n.default_locale.to_s unless locale.in?(I18n.available_locales.map(&:to_s))
+        locale
+      end
+
+      def halt!(status, message)
+        throw(:halt, [status, { "Content-Type" => CONTENT_TYPE_TEXT }, [message]])
+      end
+  end
+end
diff --git a/app/services/upload_scan_result.rb b/app/services/upload_scan_result.rb
new file mode 100644
index 000000000..b880a948b
--- /dev/null
+++ b/app/services/upload_scan_result.rb
@@ -0,0 +1,41 @@
+class UploadScanResult
+  attr_reader :status, :signature, :detail
+
+  def self.clean
+    new(status: :clean)
+  end
+
+  def self.infected(signature)
+    new(status: :infected, signature: signature)
+  end
+
+  def self.unavailable(detail = nil)
+    new(status: :unavailable, detail: detail)
+  end
+
+  def self.timeout
+    new(status: :timeout)
+  end
+
+  def initialize(status:, signature: nil, detail: nil)
+    @status = status
+    @signature = signature
+    @detail = detail
+  end
+
+  def clean?
+    status == :clean
+  end
+
+  def infected?
+    status == :infected
+  end
+
+  def unavailable?
+    status == :unavailable
+  end
+
+  def timeout?
+    status == :timeout
+  end
+end
