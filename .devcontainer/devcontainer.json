// adapted from https://github.com/rails/rails/tree/main/.devcontainer
// For format details, see https://containers.dev/implementors/json_reference/.
//
{
    "name": "MaMpf",
    "dockerComposeFile": [
        "../docker/development/compose.yml",
        "compose.devcontainer.yml"
    ],
    "service": "app",
    // https://github.com/orgs/community/discussions/15506
    "mounts": [
    "source=${localWorkspaceFolder}/../mampf-infra,target=/workspaces/mampf-infra,type=bind",
    "source=${localEnv:HOME}/.local/state/sops,target=/run/host-sops-keyservice,type=bind"
    ],    
    "workspaceFolder": "/workspaces/mampf/",
    // https://containers.dev/features
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {
            "version": "latest"
        },
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
        "ghcr.io/jsburckhardt/devcontainer-features/just:1": {},
        "ghcr.io/mikaello/devcontainer-features/modern-shell-utils:2": {},
        "ghcr.io/devcontainers/features/desktop-lite:1": {
            // https://github.com/devcontainers/features/tree/main/src/desktop-lite
            "vncPort": "5933",
            "password": "noPassword"
        }
    },
    "containerEnv": {
        // in the container itself, we then install zsh
        // (this just serves as a fallback)
        "SHELL": "/bin/bash",
        "SOPS_ENABLE_LOCAL_KEYSERVICE": "false",
        "SOPS_KEYSERVICE": "unix:///run/host-sops-keyservice/keyservice.sock",
        "ANSIBLE_SOPS_ENABLE_LOCAL_KEYSERVICE": "false",
        "ANSIBLE_SOPS_KEYSERVICE": "unix:///run/host-sops-keyservice/keyservice.sock",
        "VNC_RESOLUTION": "1920x1080x24",
        "VNC_DPI": "144"
    },
    // Use 'forwardPorts' to make a list of ports inside the container available locally.
    // This can be used to network with other containers or the host.
    // see the portsAttributes below for details
    "forwardPorts": [
        3000,
        3145,
        3036,
        3037,
        1080,
        5050,
        8060,
        3004,
        5933
    ],
    "portsAttributes": {
        // Main app
        "3000": {
            "label": "MaMpf App (needs manual start)",
            "onAutoForward": "openBrowserOnce"
        },
        // Vite
        "3036": {
            "label": "Vite Server (dev & unit tests, starts with MaMpf App)",
            "onAutoForward": "silent"
        },
        "3037": {
            "label": "Vite Server (e2e tests)",
            "onAutoForward": "silent"
        },
        // Test ports (for Cypress)
        "3145": {
            "label": "MaMpf App (for e2e tests)",
            "onAutoForward": "silent"
        },
        "8060": {
            "label": "Cypress",
            "onAutoForward": "silent"
        },
        // Miscellaneous
        "1080": {
            "label": "mailcatcher",
            "onAutoForward": "silent"
        },
        "3004": {
            "label": "Architecture Book (needs manual start)",
            "onAutoForward": "openBrowser"
        },
        "5050": {
            "label": "pgAdmin",
            "onAutoForward": "silent"
        },
        "5933": {
            "label": "VNC Desktop",
            "onAutoForward": "openBrowser"
        }
    },
    "postCreateCommand": ".devcontainer/boot.sh",
    "customizations": {
        "vscode": {
            // 🎹 keep this in sync with extensions.json
            "extensions": [
                "ms-azuretools.vscode-containers",
                "ms-vscode.remote-explorer",
                "docker.docker",
                "Shopify.ruby-lsp",
                "dbaeumer.vscode-eslint",
                "streetsidesoftware.code-spell-checker",
                "streetsidesoftware.code-spell-checker-german",
                "nefrob.vscode-just-syntax",
                "timonwong.shellcheck",
                "github.copilot-chat",
                "github.vscode-pull-request-github",
                "ms-playwright.playwright",
                "marcoroth.herb-lsp"
            ]
        }
    },
    "overrideCommand": true, // see docker-compose.devcontainer.yml
    "remoteUser": "mampf"
}